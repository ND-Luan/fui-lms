{
    "data": [
        {
            "DSNienKhoa": [],
            "NienKhoa": null,
            "HocKi":"parseInt(HocKi)"
        },
        {
            "API": "lms/NienKhoa_Get",
            "OUT": "DSNienKhoa",
            "CALLBACK": {
                "EXE": "vueData.NienKhoa = vueData.DSNienKhoa.find(nk => nk.IsActive == true).NienKhoa"
            }
        }
    ],
    "watch": {},
    "controls": [
        {
            "prop": "fluid grid-list-md",
            "rows": [
                {
                    "prop": "",
                    "cols": [
                        {
                            "el": "uc-main-page",
                            "attr": {
                                "v-if": "NienKhoa",
                                ":hoc-ki":"HocKi"
                            }
                        }
                    ]
                }
            ]
        }
    ],
    "set": {
        "menu": false,
        "menuLeft": false
    }
}