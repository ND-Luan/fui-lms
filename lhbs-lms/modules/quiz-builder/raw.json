{"ModuleName":"Word to JSON Converter","Description":"Upload file Word và generate JSON quiz structure","watch":{},"controls":[{"prop":"fluid","rows":[{"cols":[{"component":"v-card","props":{"class":"mb-4","color":"primary","variant":"flat"},"children":[{"component":"v-card-title","props":{"class":"text-white"},"text":"📁 Word to JSON Converter"},{"component":"v-card-subtitle","props":{"class":"text-white"},"text":"Upload file Word có tables + images → AI tạo cấu trúc JSON quiz"}]}]},{"cols":[{"component":"v-col","props":{"cols":"12","md":"6"},"children":[{"component":"v-card","props":{"elevation":"2"},"children":[{"component":"v-card-title","text":"📁 Upload File Word"},{"component":"v-card-text","children":[{"component":"v-file-input","props":{"v-model":"selectedFile","label":"Chọn file Word (.docx)","accept":".docx,.doc","prepend-icon":"mdi-file-word","variant":"outlined","show-size":true,"clearable":true,":disabled":"isProcessing","@change":"handleFileChange"}},{"component":"v-alert","props":{"v-if":"uploadInfo","type":"info","variant":"tonal","class":"mt-3"},"text":"File: {{uploadInfo.name}} ({{formatFileSize(uploadInfo.size)}})"},{"component":"v-text-field","props":{"v-model":"quizTitle","label":"Tiêu đề quiz","variant":"outlined","density":"compact","class":"mt-3"}},{"component":"v-text-field","props":{"v-model":"timeLimit","label":"Thời gian (phút)","type":"number","variant":"outlined","density":"compact"}},{"component":"v-checkbox","props":{"v-model":"uploadImages","label":"Upload images"}}]},{"component":"v-card-actions","children":[{"component":"v-btn","props":{"@click":"uploadAndProcess","color":"primary","block":true,":disabled":"!selectedFile || isProcessing",":loading":"isProcessing"},"text":"🚀 Upload & Generate JSON"}]}]}]},{"component":"v-col","props":{"cols":"12","md":"6"},"children":[{"component":"v-card","props":{"elevation":"2"},"children":[{"component":"v-card-title","text":"📋 Kết quả JSON"},{"component":"v-card-text","children":[{"component":"div","props":{"v-if":"!result","class":"text-center py-8"},"children":[{"component":"v-icon","props":{"size":"64","color":"grey"},"text":"mdi-code-json"},{"component":"div","props":{"class":"mt-4"},"text":"Chưa có kết quả"}]},{"component":"div","props":{"v-else":true},"children":[{"component":"v-alert","props":{"v-if":"result.success","type":"success","class":"mb-3"},"text":"✅ {{result.message}}"},{"component":"v-alert","props":{"v-else":true,"type":"error","class":"mb-3"},"text":"❌ {{result.message}}"},{"component":"v-btn-toggle","props":{"v-if":"result.success","v-model":"viewMode","class":"mb-3"},"children":[{"component":"v-btn","props":{"value":"json"},"text":"JSON"},{"component":"v-btn","props":{"value":"html"},"text":"HTML"}]},{"component":"v-textarea","props":{"v-if":"viewMode === 'json' && result.success",":model-value":"formatJSON(result.quiz_json)","readonly":true,"rows":"15","variant":"outlined","class":"font-monospace"}},{"component":"v-textarea","props":{"v-if":"viewMode === 'html' && result.success",":model-value":"result.ckeditor_html || 'No HTML'","readonly":true,"rows":"15","variant":"outlined","class":"font-monospace"}}]}]},{"component":"v-card-actions","props":{"v-if":"result && result.success"},"children":[{"component":"v-btn","props":{"@click":"copyJSON","color":"success","variant":"outlined"},"text":"Copy"},{"component":"v-btn","props":{"@click":"clearResult","variant":"outlined","class":"ml-2"},"text":"Reset"}]}]}]}]}]}],"methods":{"handleFileChange":{"body":["if (this.selectedFile && this.selectedFile.length > 0) {","  const file = this.selectedFile[0];","  this.uploadInfo = {","    name: file.name,","    size: file.size","  };","  if (!this.quizTitle) {","    this.quizTitle = file.name.replace(/\\.(docx?|doc)$/i, '');","  }","} else {","  this.uploadInfo = null;","}"]},"uploadAndProcess":{"body":["if (!this.selectedFile || this.selectedFile.length === 0) {","  this.$toast('Vui lòng chọn file Word', 'warning');","  return;","}","","this.isProcessing = true;","this.result = null;","","// Step 1: Upload file","this.$api.uploadFile('spAPIFILE_UPLOAD_FileData', this.selectedFile[0])",".then(uploadResult => {","  if (!uploadResult.FILE_ID) {","    throw new Error('Upload failed');","  }","  ","  // Step 2: Process with AI","  return this.$api.call('spAPI_FP_AI_WordToQuizJSON_Complete', {","    FileID: uploadResult.FILE_ID,","    TieuDe: this.quizTitle || '',","    ThoiGianLam: parseInt(this.timeLimit) || 30,","    UploadImages: this.uploadImages ? 1 : 0","  });","})",".then(aiResult => {","  this.result = aiResult;","  this.viewMode = 'json';","  ","  if (aiResult.success) {","    this.$toast('🎉 Tạo JSON thành công!', 'success');","  } else {","    this.$toast('❌ ' + aiResult.message, 'error');","  }","})",".catch(error => {","  console.error('Error:', error);","  this.result = {","    success: false,","    message: error.message || 'Unknown error'","  };","  this.$toast('Có lỗi xảy ra', 'error');","})",".finally(() => {","  this.isProcessing = false;","});"]},"formatJSON":{"body":["if (!data) return '';","try {","  if (typeof data === 'string') {","    return JSON.stringify(JSON.parse(data), null, 2);","  } else {","    return JSON.stringify(data, null, 2);","  }","} catch (error) {","  return data.toString();","}"]},"copyJSON":{"body":["if (!this.result || !this.result.quiz_json) return;","","const jsonText = this.formatJSON(this.result.quiz_json);","navigator.clipboard.writeText(jsonText)",".then(() => {","  this.$toast('📋 Đã copy JSON!', 'success');","})",".catch(() => {","  this.$toast('Copy thất bại', 'error');","});"]},"clearResult":{"body":["this.result = null;","this.selectedFile = null;","this.uploadInfo = null;","this.quizTitle = '';","this.$toast('🗑️ Đã reset', 'info');"]},"formatFileSize":{"body":["if (bytes === 0) return '0 Bytes';","const k = 1024;","const sizes = ['Bytes', 'KB', 'MB'];","const i = Math.floor(Math.log(bytes) / Math.log(k));","return Math.round(bytes / Math.pow(k, i)) + ' ' + sizes[i];"]}},"data":{"selectedFile":"null","uploadInfo":"null","quizTitle":"''","timeLimit":"30","uploadImages":"true","isProcessing":"false","result":"null","viewMode":"'json'"}}