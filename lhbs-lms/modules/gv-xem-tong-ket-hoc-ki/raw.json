{
    "data": [
        {
            "EXE": "IsCheck_NotRoleParent(vueData.user)"
        },
        {
            "CapID": "parseInt(capid)",
            "Is_InCaKhoi": false,
            "instance": null,
            "DSKhoi": [],
            "DSLop": [],
            "DSMonHoc": [],
            "DSNhomDiem": [],
            "LopItem": null,
            "KhoiItem": null,
            "MonHocItem": null,
            "MaNhomCotDiemItem": null,
            "keyComp": 0,
            "columnHeader": [],
            "DSHocSinh": [],
            "DSCotDiem": [],
            "DSCotDiem_ByMaNhomCotDiem": [],
            "DSCotDiem_TatCa": [],
            "dataBeforeInsertToDB": [],
            "TinhTrang": null,
            "styleSheet": {},
            "comments": {},
            "StatusButton": null,
            "freezeColumns": 4,
            "Semester": {
                "title": "Học kì 1",
                "value": 1
            },
            "DSSemester": [
                {
                    "title": "Học kì 1",
                    "value": 1
                },
                {
                    "title": "Học kì 2",
                    "value": 2
                },
                {
                    "title": "Cả năm",
                    "value": 0
                }
            ],
            "IsShowDialogReject": false,
            "IsShowDialogTinhTrangDiem": false,
            "DSHocSinh_API_QLD": [],
            "MonHoc_QLD": [],
            "DSHocSinhQLD": [],
            "DSHocSinh_API_TongKet": [],
            "dataDiem": [],
            "DSHocSinhChange": [],
            "IsShowDialogConfirm": false,
            "isLoadingExportGiayKhen": false,
            "DSKhenThuong": []
        },
        {
            "getKhoi": {
                "API": "lms/KhoiHocByCapHoc_Get",
                "IN": {
                    "CapID": "vueData.CapID",
                    "NienKhoa": "vueData.NienKhoa",
                    "HocKi": "vueData.NienKhoaItem?.HocKi"
                },
                "OUT": "DSKhoi"
            }
        },
        {
            "getLop": {
                "API": "lms/Lop_Get_ByKhoiID",
                "IN": {
                    "NienKhoa": "vueData.NienKhoa",
                    "KhoiID": "vueData.KhoiItem?.KhoiID"
                },
                "OUT": "DSLop"
            }
        },
        {
            "MonHoc_QLD_GetByKhoi": {
                "API": "lms/MonHoc_QLD_GetByKhoi",
                "IN": {
                    "NienKhoa": "vueData.NienKhoa",
                    "KhoiID": "vueData.KhoiItem?.KhoiID"
                },
                "OUT": "MonHoc_QLD"
            }
        }
    ],
    "watch": {
        "NienKhoa": [
            {
                "EXE": "vueData.KhoiItem = null; vueData.LopItem = null;vueData.DSHocSinh = []"
            },
            {
                "CALL": "getKhoi"
            }
        ],
        "KhoiItem": {
            "IF": "vueData.KhoiItem?.KhoiID > 0",
            "THEN": [
                {
                    "LopItem": null,
                    "MonHocItem": null,
                    "MaNhomCotDiemItem": null,
                    "DSLop": [],
                    "DSMonHoc": [],
                    "DSNhomDiem": [],
                    "DSHocSinh": [],
                    "columnHeader": []
                },
                {
                    "CALL": "getLop"
                },
                {
                    "CALL": "MonHoc_QLD_GetByKhoi"
                }
            ]
        },
        "LopItem": {
            "IF": "vueData.LopItem?.LopID !== null",
            "THEN": [
                {
                    "DSHocSinh": [],
                    "MonHocItem": null,
                    "MaNhomCotDiemItem": null,
                    "columnHeader": []
                },
                {
                    "EXE": "vueData.LopItem.LopID === 'ALL' ? vueData.getDSLop() : vueData.TongKet_GetDTBMonHocByKhoiLop()"
                }
            ]
        },
        "Semester": {
            "IF": "vueData.Semester != null",
            "THEN": [
                {
                    "KhoiItem": null,
                    "LopItem": null,
                    "DSHocSinh": [],
                    "columnHeader": []
                }
            ]
        }
    },
    "controls": [
        {
            "prop": "fluid pa-0",
            "rows": [
                {
                    "prop": ":no-gutters=true",
                    "cols": [
                        {
                            "el": "uc-main-layout",
                            "attr": {
                                "v-if": "NienKhoa"
                            }
                        }
                    ]
                }
            ]
        }
    ],
    "set": {}
}