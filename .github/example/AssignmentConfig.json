                            },
                            "sourceFiles": {
                                "file": [],
                                "image": []
                            }
                        },
                        "isAdvanced": false,
                        "questionText": "",
                        "options": [
                            {
                                "id": "a",
                                "text": "A. Dựa vào các chất dinh dưỡng có trong thức ăn, người ta chia thức ăn thành 5 nhóm. ",
                                "correctAnswer": null,
                                "inCorrectAnswer": null
                            },
                            {
                                "id": "opt_1775550119992",
                                "text": "B. Chất xơ không có giá trị dinh dưỡng nhưng rất cần thiết, đảm bảo cho cơ quan tiêu hoá hoạt động bình thường.\t",
                                "correctAnswer": null,
                                "inCorrectAnswer": null
                            },
                            {
                                "id": "opt_1775550130476",
                                "text": "C. Hoa quả cần được bảo quản trong ngăn mát tủ lạnh.\t",
                                "correctAnswer": null,
                                "inCorrectAnswer": null
                            },
                            {
                                "id": "opt_1775550132511",
                                "text": "D. Khi thấy thực phẩm có dấu hiệu bị mốc, chúng ta cần cạo lớp mốc đi và ăn phần còn lại. ",
                                "inCorrectAnswer": null,
                                "correctAnswer": null
                            }
                        ]
                    }
                },
                {
                    "id": "q_1775550244346",
                    "type": "QUIZ_MULTIPLE_TRUE_FALSE",
                    "label": "Nhiều đúng / Sai",
                    "skills": [],
                    "ordinalNumber": 3,
                    "points": 2,
                    "gradingType": "auto",
                    "config": {
                        "media": {
