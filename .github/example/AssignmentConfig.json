                                "image": []
                            }
                        },
                        "isAdvanced": false,
                        "questionText": "",
                        "options": [
                            {
                                "id": "a",
                                "text": "A. Chúng ta cần lựa chọn những thực phẩm có nguồn gốc rõ ràng và không có dấu hiệu bị hư hỏng.",
                                "correctAnswer": null,
                                "inCorrectAnswer": null
                            },
                            {
                                "id": "opt_1775550262278",
                                "text": "B. Bảo quản thực phẩm ở nơi có nhiệt độ cao.",
                                "inCorrectAnswer": null,
                                "correctAnswer": null
                            },
                            {
                                "id": "opt_1775550264780",
                                "text": "C. Để đảm bảo thực phẩm an toàn, chúng ta cần rửa sạch trước khi ăn và chế biến. ",
                                "correctAnswer": null,
                                "inCorrectAnswer": null
                            },
                            {
                                "id": "opt_1775550267464",
                                "text": "D. Thực phẩm an toàn được nuôi, trồng, bảo quản và chế biến hợp vệ sinh.",
                                "correctAnswer": null,
                                "inCorrectAnswer": null
                            }
                        ]
                    }
                },
                {
                    "id": "q_1775550248747",
                    "type": "QUIZ_MULTIPLE_TRUE_FALSE",
                    "label": "Nhiều đúng / Sai",
                    "skills": [],
                    "ordinalNumber": 4,
