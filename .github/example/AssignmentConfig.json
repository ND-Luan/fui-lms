                            },
                            "sourceFiles": {
                                "file": [],
                                "image": []
                            }
                        },
                        "isAdvanced": false,
                        "questionText": "",
                        "options": [
                            {
                                "id": "a",
                                "text": "A. Nấm hương có hình tròn, màu nâu.",
                                "correctAnswer": null,
                                "inCorrectAnswer": null
                            },
                            {
                                "id": "opt_1775549961142",
                                "text": "B. Nấm mốc thường phát triển trong môi trường ấm nóng và ẩm ướt.\t",
                                "correctAnswer": null,
                                "inCorrectAnswer": null
                            },
                            {
                                "id": "opt_1775549969793",
                                "text": "C. Các loại nấm đều có màu đỏ.\t",
                                "inCorrectAnswer": null,
                                "correctAnswer": null
                            },
                            {
                                "id": "opt_1775549978959",
                                "text": "D. Tất cả các loại nấm đều có dạng hình tròn.\t",
                                "inCorrectAnswer": null,
                                "correctAnswer": null
                            }
                        ]
                    }
                },
                {
                    "id": "q_1775550115359",
                    "type": "QUIZ_MULTIPLE_TRUE_FALSE",
                    "label": "Nhiều đúng / Sai",
                    "skills": [],
                    "ordinalNumber": 2,
                    "points": 1,
                    "gradingType": "auto",
                    "config": {
                        "media": {
                            "type": "YOUTUBE",
                            "sourceYT": {
                                "id": "",
                                "name": "",
                                "source": ""
                            },
                            "sourceRecord": {
