                        "isAdvanced": false,
                        "questionText": "",
                        "options": [
                            {
                                "id": "a",
                                "text": "A. Khi thực phẩm bị nhiễm nấm mốc, chỉ cần rửa sạch hoặc nấu chín là có thể ăn được.",
                                "correctAnswer": null,
                                "inCorrectAnswer": null
                            },
                            {
                                "id": "opt_1775550398148",
                                "text": "B. Tất cả thực phẩm được bảo quản bằng cách ướp muối.",
                                "inCorrectAnswer": null,
                                "correctAnswer": null
                            },
                            {
                                "id": "opt_1775550400632",
                                "text": "C. Khi để ở nơi nóng ẩm, thực phẩm sẽ nhanh bị hỏng do nhiễm nấm mốc.",
                                "correctAnswer": null,
                                "inCorrectAnswer": null
                            },
                            {
                                "id": "opt_1775550402332",
                                "text": "D. Có nhiều cách để bảo quản thực phẩm như ướp muối, ướp đường, hun khói…",
                                "correctAnswer": null,
                                "inCorrectAnswer": null
                            }
                        ]
                    }
