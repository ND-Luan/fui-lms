                        "isAdvanced": false,
                        "questionText": "",
                        "options": [
                            {
                                "id": "a",
                                "text": "A. Đại bàng ăn cỏ để sinh tồn.\t",
                                "correctAnswer": null,
                                "inCorrectAnswer": null
                            },
                            {
                                "id": "opt_1775550335781",
                                "text": "B. Sâu là thức ăn của chim sẻ.\t",
                                "correctAnswer": null,
                                "inCorrectAnswer": null
                            },
                            {
                                "id": "opt_1775550337447",
                                "text": "C. Thức ăn của thằn lằn là châu chấu.\t",
                                "correctAnswer": null,
                                "inCorrectAnswer": null
                            },
                            {
                                "id": "opt_1775550338847",
                                "text": "D. Tôm là thức ăn của sư tử.",
                                "inCorrectAnswer": null,
                                "correctAnswer": null
                            }
                        ]
                    }
                },
                {
                    "id": "q_1775550393496",
