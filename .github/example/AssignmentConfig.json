                {
                    "id": "q_1775549933657",
                    "type": "QUIZ_MULTIPLE_TRUE_FALSE",
                    "label": "Nhiều đúng / Sai",
                    "skills": [],
                    "ordinalNumber": 1,
                    "points": 1,
                    "gradingType": "auto",
                    "config": {
                        "media": {
