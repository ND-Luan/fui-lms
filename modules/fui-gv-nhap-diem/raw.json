{
    "data": [
        {
            "EXE": "IsCheck_NotRoleParent(vueData.user)"
        },
        {
            "CapID": "parseInt(capid)",
            "instance": null,
            "DSKhoi": [],
            "DSLop": [],
            "DSMonHoc": [],
            "DSNhomDiem": [],
            "LopItem": null,
            "KhoiItem": null,
            "MonHocItem": null,
            "MaNhomCotDiemItem": null,
            "keyComp": 0,
            "columnHeader": [],
            "DSHocSinh": [],
            "DSCotDiem": [],
            "DSCotDiem_ByMaNhomCotDiem": [],
            "DSCotDiem_TatCa": [],
            "dataBeforeInsertToDB": [],
            "TinhTrang": null,
            "styleSheet": null,
            "comments": {},
            "StatusButton": null,
            "freezeColumns": 3,
            "TitleCap": "renderText(parseInt(capid))",
            "TitlePage": "getTitlePageByURL(window.location.pathname + window.location.search)",
            "DSNhomDiem_HK": [
                {
                    "MaNhomCotDiem": "DiemGK_HK1",
                    "TenNhomCotDiem_VI": "Giữa HK1",
                    "TenNhomCotDiem_EN": "Mid-term Points (Semester 1)",
                    "ThuTuNhom": 1,
                    "Semester": "HK1"
                },
                {
                    "MaNhomCotDiem": "DiemCK_HK1",
                    "TenNhomCotDiem_VI": "Cuối HK1",
                    "TenNhomCotDiem_EN": "Final Points (Semester 1)",
                    "ThuTuNhom": 2,
                    "Semester": "HK1"
                },
                {
                    "MaNhomCotDiem": "DiemGK_HK2",
                    "TenNhomCotDiem_VI": "Giữa HK2",
                    "TenNhomCotDiem_EN": "Mid-term Points (Semester 2)",
                    "ThuTuNhom": 3,
                    "Semester": "HK2"
                },
                {
                    "MaNhomCotDiem": "DiemCK_HK2",
                    "TenNhomCotDiem_VI": "Cuối HK2",
                    "TenNhomCotDiem_EN": "Final Points (Semester 2)",
                    "ThuTuNhom": 4,
                    "Semester": "HK2"
                }
            ]
        },
        {
            "getKhoi": {
                "API": "lms/KhoiHocByCapHoc_Get",
                "IN": {
                    "CapID": "vueData.CapID"
                },
                "OUT": "DSKhoi"
            },
            "getLop": {
                "API": "lms/Lop_Get_ByKhoiID",
                "IN": {
                    "NienKhoa": "vueData.NienKhoa",
                    "KhoiID": "vueData.KhoiItem.KhoiID"
                },
                "OUT": "DSLop"
            }
        },
        {
            "getMonHoc": {
                "API": "lms/MonHoc_Get_ByLopID",
                "IN": {
                    "NienKhoa": "vueData.NienKhoa",
                    "LopID": "vueData.LopItem.LopID"
                },
                "OUT": "DSMonHoc"
            }
        },
        {
            "getNhomDiem": {
                "API": "lms/NhomCauTrucDiem_Get_ByTemplateBangDiemID",
                "IN": {
                    "TemplateBangDiemID": "vueData.MonHocItem.TemplateBangDiemID"
                },
                "OUT": "DSNhomDiem",
                "CALLBACK": {
                    "EXE": "if(vueData.DSNhomDiem.find(x => x.MaNhomCotDiem === 'DiemCK_HK2')) vueData.MaNhomCotDiemItem = {'MaNhomCotDiem': 'DiemCK_HK2','TenNhomCotDiem_VI': 'Cuối HK2','TenNhomCotDiem_EN': 'Final Points (Semester 2)','ThuTuNhom': 4,'Semester': 'HK2'}"
                }
            }
        },
        {
            "getHocSinhBangDiem": {
                "API": "lms/HocSinhBangDiem_Get_ByMonHocID_MaNhom",
                "IN": {
                    "LopID": "vueData.LopItem.LopID",
                    "MonHocID": "vueData.MonHocItem.MonHocID",
                    "TemplateBangDiemID": "vueData.MonHocItem.TemplateBangDiemID",
                    "MaNhomCotDiem": "vueData.MaNhomCotDiemItem.MaNhomCotDiem"
                },
                "OUT": "DSCotDiem",
                "CALLBACK": [
                    {
                        "FUN": "fn_IsDisabledTinhTrangDiem",
                        "IN": {
                            "TinhTrang": "fn_ProrityTinhTrang(vueData.DSCotDiem).TinhTrang",
                            "type": "`GV"
                        },
                        "OUT": "TinhTrang"
                    },
                    {
                        "EXE": "convertDSHocSinh()"
                    }
                ]
            }
        },
        {
            "insKQHT_MonHocLop": {
                "API": "lms/KQHT_MonHocLop_Ins",
                "IN": {
                    "NienKhoa": "vueData.NienKhoa",
                    "MonHocLopID": "vueData.MonHocItem.MonHocLopID",
                    "LopID": "vueData.LopItem.LopID",
                    "MonHocID": "vueData.MonHocItem.MonHocID",
                    "TemplateBangDiemID": "vueData.MonHocItem.TemplateBangDiemID",
                    "KetQuaObjArr": "vueData.dataBeforeInsertToDB"
                },
                "CALLBACK": [
                    {
                        "IF": "vueData.StatusButton === 'luu'",
                        "THEN": {
                            "CALL": [
                                {
                                    "IF": "vueData.CapID === 1",
                                    "THEN": {
                                        "CALL": "udpKQHT_MonHocLop_TinhTrang_LuuTam"
                                    }
                                },
                                {
                                    "IF": "vueData.CapID === 2 || vueData.CapID === 3",
                                    "THEN": {
                                        "CALL": "udpKQHT_MonHocLop_TinhTrang_LuuTam_C2_C3"
                                    }
                                }
                            ]
                        },
                        "ELSE": {
                            "CALL": "udpKQHT_MonHocLop_TinhTrang_GuiDiem"
                        }
                    },
                    {
                        "EXE": "vueData.keyComp++"
                    }
                ]
            }
        },
        {
            "udpKQHT_MonHocLop_TinhTrang_LuuTam": {
                "API": "lms/KQHT_MonHocLop_TinhTrang_Udp",
                "IN": {
                    "NienKhoa": "vueData.NienKhoa",
                    "MonHocLopID": "vueData.MonHocItem.MonHocLopID",
                    "LopID": "vueData.LopItem.LopID",
                    "TinhTrang": 1,
                    "MaNhomCotDiem": "vueData.MaNhomCotDiemItem.MaNhomCotDiem",
                    "IsSendToManager": false
                },
                "MESS": "Lưu tạm điểm thành công",
                "CALLBACK": [
                    {
                        "CALL": "getHocSinhBangDiem"
                    },
                    {
                        "dataBeforeInsertToDB": []
                    }
                ]
            },
            "udpKQHT_MonHocLop_TinhTrang_LuuTam_C2_C3": {
                "API": "lms/KQHT_MonHocLop_TinhTrang_Udp_C2_C3",
                "IN": {
                    "NienKhoa": "vueData.NienKhoa",
                    "MonHocLopID": "vueData.MonHocItem.MonHocLopID",
                    "LopID": "vueData.LopItem.LopID",
                    "TinhTrang": 1,
                    "MaNhomCotDiem": "vueData.MaNhomCotDiemItem.MaNhomCotDiem",
                    "IsSendToManager": false
                },
                "MESS": "Lưu tạm điểm thành công",
                "CALLBACK": [
                    {
                        "CALL": "getHocSinhBangDiem"
                    },
                    {
                        "dataBeforeInsertToDB": []
                    }
                ]
            }
        },
        {
            "udpKQHT_MonHocLop_TinhTrang_GuiDiem": {
                "CONFIRM": "Xác nhận gửi điểm tới tổ tưởng",
                "CALL": {
                    "API": "lms/KQHT_MonHocLop_TinhTrang_Udp",
                    "IN": {
                        "NienKhoa": "vueData.NienKhoa",
                        "MonHocLopID": "vueData.MonHocItem.MonHocLopID",
                        "LopID": "vueData.LopItem.LopID",
                        "TinhTrang": 2,
                        "MaNhomCotDiem": "vueData.MaNhomCotDiemItem.MaNhomCotDiem",
                        "IsSendToManager": true
                    },
                    "MESS": "Gửi điểm thành công",
                    "CALLBACK": [
                        {
                            "CALL": "getHocSinhBangDiem"
                        },
                        {
                            "dataBeforeInsertToDB": []
                        }
                    ]
                }
            }
        },
        {
            "CALL": [
                {
                    "CALL": "getKhoi"
                },
                {
                    "EXE": "vueData.onLuuDiem = onLuuDiem; vueData.isShowReasonReject  = isShowReasonReject; vueData.renderText_Person_Reject = renderText_Person_Reject"
                }
            ]
        }
    ],
    "watch": {
        "KhoiItem": {
            "IF": "vueData.KhoiItem.KhoiID > 0",
            "THEN": [
                {
                    "LopItem": null,
                    "MonHocItem": null,
                    "MaNhomCotDiemItem": null,
                    "DSLop": [],
                    "DSMonHoc": [],
                    "DSNhomDiem": [],
                    "DSHocSinh": []
                },
                {
                    "CALL": "getLop"
                }
            ]
        },
        "LopItem": {
            "CALL": [
                {
                    "IF": "typeof vueData.LopItem?.LopID === 'number'",
                    "THEN": {
                        "CALL": [
                            {
                                "DSHocSinh": [],
                                "DSNhomDiem": [],
                                "MonHocItem": null,
                                "MaNhomCotDiemItem": null
                            },
                            {
                                "CALL": "getMonHoc"
                            }
                        ]
                    }
                },
                {
                    "IF": "typeof vueData.LopItem?.LopID === 'string'",
                    "THEN": {
                        "CALL": [
                            {
                                "DSHocSinh": [],
                                "MonHocItem": null,
                                "MaNhomCotDiemItem": null
                            },
                            {
                                "CALL": "getMonHoc"
                            }
                        ]
                    }
                }
            ]
        },
        "MonHocItem": {
            "IF": "vueData.MonHocItem?.MonHocID > 0",
            "THEN": [
                {
                    "MaNhomCotDiemItem": null,
                    "DSHocSinh": []
                },
                {
                    "IF": "vueData.MonHocItem.MonHocID === 13 || vueData.MonHocItem.MonHocID === 14",
                    "THEN": [
                        {
                            "EXE": "vueData.DSNhomDiem = vueData.DSNhomDiem_HK"
                        }
                    ],
                    "ELSE": {
                        "CALL": "getNhomDiem"
                    }
                }
            ]
        },
        "MaNhomCotDiemItem": {
            "IF": "vueData.MaNhomCotDiemItem?.MaNhomCotDiem?.length > 0",
            "THEN": {
                "CALL": "getHocSinhBangDiem"
            }
        }
    },
    "controls": [
        {
            "prop": "fluid grid-list-md",
            "rows": [
                {
                    "prop": "",
                    "cols": [
                        {
                            "el": "v-card",
                            "attr": {},
                            "innerHTML": [
                                {
                                    "el": "v-card-title",
                                    "attr": {
                                        "class": "text-primary px-0 pt-0"
                                    },
                                    "innerHTML": "{{TitlePage}} - {{TitleCap}}"
                                },
                                {
                                    "el": "v-card-text",
                                    "attr": {
                                        "class": " pb-0 px-0"
                                    },
                                    "innerHTML": [
                                        {
                                            "el": "v-row",
                                            "innerHTML": [
                                                {
                                                    "el": "v-col",
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-select",
                                                            "attr": {
                                                                "v-model": "KhoiItem",
                                                                "label": "Chọn khối",
                                                                ":items": "DSKhoi",
                                                                "item-title": "TenKhoiHoc",
                                                                "item-value": "KhoiID",
                                                                ":return-object": true,
                                                                ":hide-details": true
                                                            }
                                                        }
                                                    ]
                                                },
                                                {
                                                    "el": "v-col",
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-select",
                                                            "attr": {
                                                                "v-model": "LopItem",
                                                                "label": "Chọn lớp",
                                                                ":items": "DSLop",
                                                                "item-title": "TenLop",
                                                                "item-value": "LopID",
                                                                ":return-object": true,
                                                                ":hide-details": true
                                                            }
                                                        }
                                                    ]
                                                },
                                                {
                                                    "el": "v-col",
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-select",
                                                            "attr": {
                                                                "v-model": "MonHocItem",
                                                                "label": "Chọn môn học",
                                                                ":items": "DSMonHoc",
                                                                "item-title": "MonHocName",
                                                                "item-value": "MonHocID",
                                                                ":return-object": true,
                                                                "hide-details": "auto"
                                                            }
                                                        }
                                                    ]
                                                },
                                                {
                                                    "el": "v-col",
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-select",
                                                            "attr": {
                                                                "v-model": "MaNhomCotDiemItem",
                                                                "label": "Chọn nhóm điểm",
                                                                ":items": "DSNhomDiem",
                                                                "item-title": "TenNhomCotDiem_VI",
                                                                "item-value": "MaNhomCotDiem",
                                                                ":return-object": true,
                                                                "hide-details": "auto"
                                                            }
                                                        }
                                                    ]
                                                },
                                                {
                                                    "el": "v-col",
                                                    "innerHTML": "<f-button label='Làm mới' variant='outlined' :action='getHocSinhBangDiem' color='primary' />"
                                                }
                                            ]
                                        }
                                    ]
                                }
                            ],
                            "w": 12
                        },
                        {
                            "el": "v-card",
                            "innerHTML": [
                                {
                                    "el": "v-card-title",
                                    "attr": {
                                        "class": "px-0"
                                    },
                                    "innerHTML": [
                                        {
                                            "el": "div",
                                            "attr": {
                                                "class": "text-primary d-flex ga-2"
                                            },
                                            "innerHTML": [
                                                {
                                                    "el": "p",
                                                    "innerHTML": "Nhập điểm / Đánh giá"
                                                },
                                                {
                                                    "el": "v-chip",
                                                    "attr": {
                                                        "color": "primary",
                                                        "class": "font-weight-medium"
                                                    },
                                                    "innerHTML": "Tổng số học sinh: {{DSHocSinh.length}}"
                                                },
                                                {
                                                    "el": "v-chip",
                                                    "attr": {
                                                        "v-if": "DSHocSinh.length > 0 && !DSCotDiem.find(x => x.NhapDiemUser === 'kdiem')",
                                                        ":color": "DSCotDiem[0]?.MauTinhTrang",
                                                        ":text": "DSCotDiem[0]?.TenTinhTrang"
                                                    }
                                                },
                                                {
                                                    "__el": "v-chip",
                                                    "attr": {
                                                        "v-if": "DSCotDiem.find(x => x.NhapDiemUser === 'kdiem')",
                                                        "color": "success",
                                                        "text": "Đã kéo điểm"
                                                    }
                                                }
                                            ]
                                        },
                                        {
                                            "attr": {},
                                            "el": "v-spacer"
                                        },
                                        {
                                            "el": "v-btn",
                                            "attr": {
                                                "v-on:click": "onLuuDiem()",
                                                "color": "primary",
                                                "variant": "outlined",
                                                ":disabled": "DSHocSinh.length === 0"
                                            },
                                            "innerHTML": "Lưu tạm"
                                        },
                                        {
                                            "el": "f-button",
                                            "attr": {
                                                "v-if": "CapID === 2 || CapID === 3",
                                                "class": "ml-2",
                                                "label": "Gửi BGH",
                                                "color": "primary",
                                                "variant": "elevated",
                                                ":disabled": "DSHocSinh.length === 0",
                                                ":action": {
                                                    "CONFIRM": "Xác nhận gửi điểm tới Ban Giám Hiệu",
                                                    "API": "lms/KQHT_MonHocLop_TinhTrang_Udp_C2_C3",
                                                    "IN": {
                                                        "NienKhoa": "vueData.NienKhoa",
                                                        "LopID": "vueData.LopItem.LopID",
                                                        "MonHocLopID": "vueData.MonHocItem.MonHocLopID",
                                                        "MaNhomCotDiem": "vueData.MaNhomCotDiemItem.MaNhomCotDiem",
                                                        "TinhTrang": 2
                                                    },
                                                    "MESS": "Gửi điểm thành công",
                                                    "CALLBACK": {
                                                        "CALL": "getHocSinhBangDiem"
                                                    }
                                                }
                                            }
                                        }
                                    ]
                                },
                                {
                                    "el": "v-card-text",
                                    "attr": {
                                        "class": "d-flex justify-space-between  pb-0 px-0"
                                    },
                                    "innerHTML": [
                                        {
                                            "el": "div",
                                            "attr": {
                                                "v-show": "DSHocSinh.length > 0 && isShowReasonReject().disabled",
                                                "class": "text-black text-body-2"
                                            },
                                            "innerHTML": [
                                                {
                                                    "el": "p",
                                                    "attr": {
                                                        "class": "text-body-2 font-weight-medium"
                                                    },
                                                    "innerHTML": "{{ renderText_Person_Reject( isShowReasonReject().TinhTrang ) }}"
                                                },
                                                {
                                                    "el": "p",
                                                    "innerHTML": "Lý do từ chối: <span class='text-red'>{{ isShowReasonReject().NoiDungNhanXet}}</span>"
                                                }
                                            ]
                                        },
                                        {
                                            "el": "div",
                                            "attr": {
                                                "class": "text-caption "
                                            },
                                            "innerHTML": "Lưu ý: Comment (Màu đỏ) trong ô nhập điểm là các ô điểm <b>Giáo viên khác</b> đã nhập"
                                        }
                                    ]
                                },
                                {
                                    "el": "v-card-text",
                                    "attr": {
                                        "class": "pt-1 px-0"
                                    },
                                    "innerHTML": "<uc-nhap-diem />"
                                }
                            ]
                        }
                    ]
                }
            ]
        }
    ],
    "set": {}
}