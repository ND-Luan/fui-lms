{
    "data": [
        {
            "instance": null,
            "DSKhoi": [],
            "DSLop": [],
            "DSMonHoc": [],
            "DSNhomDiem": [],
            "LopItem": null,
            "KhoiItem": null,
            "MonHocItem": null,
            "MaNhomCotDiemItem": null,
            "keyComp": 0,
            "columnHeader": [],
            "DSHocSinh": [],
            "DSCotDiem": [],
            "DSCotDiem_ByMaNhomCotDiem": [],
            "DSCotDiem_TatCa": [],
            "dataBeforeInsertToDB": [],
            "TinhTrang": null
        },
        {
            "getLop": {
                "API": "lms/Lop_Get_ByKhoiID",
                "IN": {
                    "KhoiID": "vueData.KhoiItem.value"
                },
                "OUT": "DSLop"
            }
        },
        {
            "getMonHoc": {
                "API": "lms/MonHoc_Get_ByLopID",
                "IN": {
                    "LopID": "vueData.LopItem.LopID"
                },
                "OUT": "DSMonHoc"
            }
        },
        {
            "getNhomDiem": {
                "API": "lms/NhomCauTrucDiem_Get_ByTemplateBangDiemID",
                "IN": {
                    "TemplateBangDiemID": "vueData.MonHocItem.TemplateBangDiemID"
                },
                "OUT": "DSNhomDiem"
            }
        },
        {
            "getHocSinhBangDiem": {
                "API": "lms/HocSinhBangDiem_Get_ByMonHocID_MaNhom",
                "IN": {
                    "LopID": "vueData.LopItem.LopID",
                    "MonHocID": "vueData.MonHocItem.MonHocID",
                    "TemplateBangDiemID": "vueData.MonHocItem.TemplateBangDiemID",
                    "MaNhomCotDiem": "vueData.MaNhomCotDiemItem.MaNhomCotDiem"
                },
                "OUT": "DSCotDiem",
                "CALLBACK": [
                    {
                        "EXE": "convertDSHocSinh()"
                    },
                    {
                        "FUN": "fn_IsDisabledTinhTrangDiem",
                        "IN": {
                            "TinhTrang": "vueData.DSCotDiem_ByMaNhomCotDiem[0]?.TinhTrang",
                            "type": "`GV"
                        },
                        "OUT": "TinhTrang"
                    }
                ]
            }
        },
        {
            "insKQHT_MonHocLop": {
                "API": "lms/KQHT_MonHocLop_Ins",
                "IN": {
                    "MonHocLopID": "vueData.MonHocItem.MonHocLopID",
                    "LopID": "vueData.LopItem.LopID",
                    "MonHocID": "vueData.MonHocItem.MonHocID",
                    "TemplateBangDiemID": "vueData.MonHocItem.TemplateBangDiemID",
                    "KetQuaObjArr": "JSON.stringify(vueData.dataBeforeInsertToDB)"
                },
                "CALLBACK": [
                    {
                        "CALL": "getHocSinhBangDiem"
                    },
                    {
                        "dataBeforeInsertToDB": []
                    }
                ]
            }
        },
        {
            "udpKQHT_MonHocLop_TinhTrang": {
                "API": "lms/KQHT_MonHocLop_TinhTrang_Udp",
                "IN": {
                    "MonHocLopID": "vueData.MonHocItem.MonHocLopID",
                    "LopID": "vueData.LopItem.LopID",
                    "TinhTrang": "vueData.TinhTrang",
                    "MaNhomCotDiem": "vueData.MaNhomCotDiemItem.MaNhomCotDiem"
                }
            }
        },
        {
            "EXE": "renderDSKhoi()"
        }
    ],
    "watch": {
        "KhoiItem": {
            "IF": "vueData.KhoiItem.value > 0",
            "THEN": [
                {
                    "LopItem": null,
                    "MonHocItem": null,
                    "MaNhomCotDiemItem": null,
                    "DSLop": [],
                    "DSMonHoc": [],
                    "DSNhomDiem": [],
                    "DSHocSinh": []
                },
                {
                    "CALL": "getLop"
                }
            ]
        },
        "LopItem": {
            "IF": "vueData.LopItem?.LopID > 0",
            "THEN": [
                {
                    "DSHocSinh": [],
                    "MonHocItem": null,
                    "MaNhomCotDiemItem": null
                },
                {
                    "CALL": "getMonHoc"
                }
            ]
        },
        "MonHocItem": {
            "IF": "vueData.MonHocItem?.MonHocID > 0",
            "THEN": [
                {
                    "MaNhomCotDiemItem": null,
                    "DSHocSinh": []
                },
                {
                    "CALL": "getNhomDiem"
                }
            ]
        },
        "MaNhomCotDiemItem": {
            "IF": "vueData.MaNhomCotDiemItem?.MaNhomCotDiem?.length > 0",
            "THEN": {
                "CALL": "getHocSinhBangDiem"
            }
        }
    },
    "controls": [
        {
            "prop": "fluid grid-list-md",
            "rows": [
                {
                    "prop": "",
                    "cols": [
                        {
                            "el": "v-card",
                            "attr": {},
                            "innerHTML": [
                                {
                                    "el": "v-card-title",
                                    "attr": {
                                        "class": "text-primary"
                                    },
                                    "innerHTML": "Tìm kiếm"
                                },
                                {
                                    "el": "v-card-text",
                                    "innerHTML": [
                                        {
                                            "el": "v-row",
                                            "innerHTML": [
                                                {
                                                    "el": "v-col",
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-select",
                                                            "attr": {
                                                                "v-model": "KhoiItem",
                                                                "label": "Chọn khối",
                                                                ":items": "DSKhoi",
                                                                "item-title": "title",
                                                                "item-value": "value",
                                                                ":return-object": true,
                                                                "hide-details": "auto"
                                                            }
                                                        }
                                                    ]
                                                },
                                                {
                                                    "el": "v-col",
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-select",
                                                            "attr": {
                                                                "v-model": "LopItem",
                                                                "label": "Chọn lớp",
                                                                ":items": "DSLop",
                                                                "item-title": "TenLop",
                                                                "item-value": "LopID",
                                                                ":return-object": true,
                                                                "hide-details": "auto"
                                                            }
                                                        }
                                                    ]
                                                },
                                                {
                                                    "el": "v-col",
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-select",
                                                            "attr": {
                                                                "v-model": "MonHocItem",
                                                                "label": "Chọn môn học",
                                                                ":items": "DSMonHoc",
                                                                "item-title": "MonHocName",
                                                                "item-value": "MonHocID",
                                                                ":return-object": true,
                                                                "hide-details": "auto"
                                                            }
                                                        }
                                                    ]
                                                },
                                                {
                                                    "el": "v-col",
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-select",
                                                            "attr": {
                                                                "v-model": "MaNhomCotDiemItem",
                                                                "label": "Chọn nhóm điểm",
                                                                ":items": "DSNhomDiem",
                                                                "item-title": "TenNhomCotDiem_VI",
                                                                "item-value": "MaNhomCotDiem",
                                                                ":return-object": true,
                                                                "hide-details": "auto"
                                                            }
                                                        }
                                                    ]
                                                },
                                                {
                                                    "el": "v-col",
                                                    "innerHTML": "<f-button label='Làm mới' :action='getHocSinhBangDiem' color='primary' />"
                                                }
                                            ]
                                        }
                                    ]
                                }
                            ],
                            "w": 12
                        },
                        {
                            "el": "v-card",
                            "innerHTML": [
                                {
                                    "el": "v-card-title",
                                    "innerHTML": [
                                        {
                                            "el": "div",
                                            "attr": {
                                                "class": "text-primary d-flex ga-2"
                                            },
                                            "innerHTML": [
                                                {
                                                    "el": "p",
                                                    "innerHTML": "Nhập điểm"
                                                },
                                                {
                                                    "el": "v-chip",
                                                    "attr": {
                                                        "v-if": "DSHocSinh.length > 0",
                                                        ":color": "TinhTrang?.color"
                                                    },
                                                    "innerHTML": "{{ TinhTrang?.text }}"
                                                }
                                            ]
                                        },
                                        {
                                            "attr": {},
                                            "el": "v-spacer"
                                        },
                                        {
                                            "el": "div",
                                            "attr": {
                                                "class": "d-flex align-center ga-2"
                                            },
                                            "innerHTML": [
                                                {
                                                    "el": "v-btn",
                                                    "attr": {
                                                        "icon": "mdi-microsoft-excel",
                                                        "color": "primary",
                                                        "variant": "text",
                                                        "v-on:click": "() => instance.download()"
                                                    }
                                                },
                                                {
                                                    "el": "f-button",
                                                    "attr": {
                                                        "label": "Lưu tạm",
                                                        "color": "success",
                                                        ":disabled": "TinhTrang?.isDisabled || !DSHocSinh.length > 0",
                                                        ":action": [
                                                            {
                                                                "EXE": "onLuuDiem()"
                                                            }
                                                        ]
                                                    }
                                                },
                                                {
                                                    "el": "f-button",
                                                    "attr": {
                                                        "label": "Gửi điểm",
                                                        "color": "primary",
                                                        ":disabled": "TinhTrang?.isDisabled || !DSHocSinh.length > 0",
                                                        ":action": [
                                                            {
                                                                "EXE": "onGuiDiem()"
                                                            }
                                                        ]
                                                    }
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "el": "v-card-text",
                                    "innerHTML": "<uc-nhap-diem />"
                                }
                            ]
                        }
                    ]
                }
            ]
        }
    ],
    "set": {}
}