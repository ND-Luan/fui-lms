{
    "data": [
        {
            "CapID": "parseInt(capid)",
            "instance": null,
            "DSKhoi": [],
            "DSLop": [],
            "DSMonHoc": [],
            "DSNhomDiem": [],
            "LopItem": null,
            "KhoiItem": null,
            "MonHocItem": null,
            "MaNhomCotDiemItem": null,
            "keyComp": 0,
            "columnHeader": [],
            "DSHocSinh": [],
            "DSCotDiem": [],
            "DSCotDiem_ByMaNhomCotDiem": [],
            "DSCotDiem_TatCa": [],
            "dataBeforeInsertToDB": [],
            "TinhTrang": null,
            "styleSheet": null,
            "comments": {},
            "StatusButton": null,
            "freezeColumns": 3,
            "Semester": "HK1",
            "DSMonHoc_Selected": [],
            "VaiTro": 0,
            "Is_MonHoc_GiangDay": false,
            "VaiTro_Page": 1,
            "IsShowDialogReject": false,
            "HocSinhItem": null
        },
        {
            "getLop": {
                "API": "lms/Lop_Get_ByKhoiID",
                "IN": {
                    "KhoiID": "vueData.KhoiItem.value"
                },
                "OUT": "DSLop"
            }
        },
        {
            "getMonHoc": {
                "API": "lms/MonHoc_Get_ByLopID",
                "IN": {
                    "LopID": "vueData.LopItem.LopID"
                },
                "OUT": "DSMonHoc",
                "CALLBACK": {
                    "EXE": "vueData.DSMonHoc_Selected = vueData.DSMonHoc.map(x => x.MonHocID)"
                }
            }
        },
        {
            "HocSinhBangDiem_Get_ByMonHocID": {
                "API": "lms/HocSinhBangDiem_Get_ByMonHocID_MaNhom",
                "IN": {
                    "LopID": "vueData.LopItem.LopID",
                    "MonHocID": "vueData.MonHocItem.MonHocID",
                    "TemplateBangDiemID": "vueData.MonHocItem.TemplateBangDiemID",
                    "MaNhomCotDiem": "vueData.MaNhomCotDiemItem.MaNhomCotDiem"
                },
                "OUT": "DSHocSinh_API",
                "CALLBACK": {
                    "EXE": "renderDSHocSinh()"
                }
            },
            "CheckVaiTro_By_GiaoVienID_LopID_MonHocID": {
                "API": "lms/CheckVaiTro_By_GiaoVienID_LopID_MonHocID",
                "IN": {
                    "LopID": "vueData.LopItem.LopID",
                    "MonHocID": "vueData.MonHocItem.MonHocID"
                },
                "OUT": "Respone_VaiTro",
                "CALLBACK": {
                    "VaiTro": 1,
                    "Is_MonHoc_GiangDay": false
                }
            },
            "NhomCauTrucDiem_Get_ByTemplateBangDiemID": {
                "API": "lms/NhomCauTrucDiem_Get_ByTemplateBangDiemID",
                "IN": {
                    "TemplateBangDiemID": "vueData.MonHocItem.TemplateBangDiemID"
                },
                "OUT": "DSNhomDiem"
            }
        },
        {
            "EXE": "renderDSKhoi()"
        },
        {
            "EXE": "vueData.onReject = onReject; vueData.onApprove = onApprove; vueData.renderTextVaiTro = renderTextVaiTro; vueData.isDisabledButtonGuiDiem = isDisabledButtonGuiDiem; vueData.isDisabledButtonTuChoi = isDisabledButtonTuChoi"
        },
        {
            "EXE": "vueData.renderTextDSHocSinh_TuChoi = renderTextDSHocSinh_TuChoi; vueData.renderTextDSHocSinh_GVBM_GuiDiem = renderTextDSHocSinh_GVBM_GuiDiem; vueData.renderTextDSHocSinh_GVCN_GuiDiem = renderTextDSHocSinh_GVCN_GuiDiem"
        }
    ],
    "watch": {
        "KhoiItem": {
            "IF": "vueData.KhoiItem.value > 0",
            "THEN": [
                {
                    "LopItem": null,
                    "MonHocItem": null,
                    "MaNhomCotDiemItem": null,
                    "DSLop": [],
                    "DSMonHoc": [],
                    "DSNhomDiem": [],
                    "DSHocSinh": []
                },
                {
                    "CALL": "getLop"
                }
            ]
        },
        "LopItem": {
            "IF": "vueData.LopItem?.LopID > 0",
            "THEN": [
                {
                    "DSHocSinh": [],
                    "MonHocItem": null,
                    "MaNhomCotDiemItem": null
                },
                {
                    "CALL": "getMonHoc"
                }
            ]
        },
        "MonHocItem": {
            "IF": "vueData.MonHocItem?.MonHocID > 0",
            "THEN": [
                {
                    "MaNhomCotDiemItem": null,
                    "DSHocSinh": []
                },
                {
                    "CALL": "CheckVaiTro_By_GiaoVienID_LopID_MonHocID"
                },
                {
                    "CALL": "NhomCauTrucDiem_Get_ByTemplateBangDiemID"
                }
            ]
        },
        "MaNhomCotDiemItem": {
            "IF": "vueData.MaNhomCotDiemItem !== null",
            "THEN": [
                {
                    "DSHocSinh": []
                },
                {
                    "CALL": "HocSinhBangDiem_Get_ByMonHocID"
                }
            ]
        }
    },
    "controls": [
        {
            "prop": "fluid grid-list-md",
            "rows": [
                {
                    "prop": "",
                    "cols": [
                        {
                            "el": "v-card",
                            "attr": {},
                            "innerHTML": [
                                {
                                    "el": "v-card-title",
                                    "attr": {
                                        "class": "text-primary"
                                    },
                                    "innerHTML": "Tìm kiếm"
                                },
                                {
                                    "el": "v-card-text",
                                    "innerHTML": [
                                        {
                                            "el": "v-row",
                                            "innerHTML": [
                                                {
                                                    "el": "v-col",
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-select",
                                                            "attr": {
                                                                "v-model": "KhoiItem",
                                                                "label": "Chọn khối",
                                                                ":items": "DSKhoi",
                                                                "item-title": "title",
                                                                "item-value": "value",
                                                                ":return-object": true,
                                                                "hide-details": "auto"
                                                            }
                                                        }
                                                    ]
                                                },
                                                {
                                                    "el": "v-col",
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-select",
                                                            "attr": {
                                                                "v-model": "LopItem",
                                                                "label": "Chọn lớp",
                                                                ":items": "DSLop",
                                                                "item-title": "TenLop",
                                                                "item-value": "LopID",
                                                                ":return-object": true,
                                                                "hide-details": "auto"
                                                            }
                                                        }
                                                    ]
                                                },
                                                {
                                                    "el": "v-col",
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-select",
                                                            "attr": {
                                                                "v-model": "MonHocItem",
                                                                "label": "Chọn môn học",
                                                                ":items": "DSMonHoc",
                                                                "item-title": "TenMonHoc_HienThi",
                                                                "item-value": "MonHocID",
                                                                ":return-object": true,
                                                                "hide-details": "auto"
                                                            }
                                                        }
                                                    ]
                                                },
                                                {
                                                    "el": "v-col",
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-select",
                                                            "attr": {
                                                                "v-model": "MaNhomCotDiemItem",
                                                                "label": "Chọn nhóm điểm",
                                                                ":items": "DSNhomDiem",
                                                                "item-title": "TenNhomCotDiem_VI",
                                                                "item-value": "MaNhomCotDiem",
                                                                ":return-object": true,
                                                                "hide-details": "auto"
                                                            }
                                                        }
                                                    ]
                                                },
                                                {
                                                    "el": "v-col",
                                                    "innerHTML": "<f-button label='Làm mới' :action='HocSinhBangDiem_Get_ByMonHocID'  color='primary' />"
                                                }
                                            ]
                                        }
                                    ]
                                }
                            ],
                            "w": 12
                        },
                        {
                            "el": "v-card",
                            "innerHTML": [
                                {
                                    "el": "v-card-title",
                                    "attr": {
                                        "class": "text-primary d-flex  align-center ga-2"
                                    },
                                    "innerHTML": [
                                        {
                                            "el": "div",
                                            "innerHTML": [
                                                {
                                                    "el": "p",
                                                    "innerHTML": "Giáo viên gửi điểm"
                                                },
                                                {
                                                    "el": "p",
                                                    "attr": {
                                                        "v-if": "MonHocItem",
                                                        "class": "text-caption text-black"
                                                    },
                                                    "innerHTML": "Môn <b>{{MonHocItem.TenMonHoc_HienThi}}</b>, bạn đang là <b>{{renderTextVaiTro(VaiTro)}}</b>"
                                                }
                                            ]
                                        },
                                        {
                                            "el": "v-spacer"
                                        },
                                        {
                                            "el": "v-chip",
                                            "attr": {
                                                "v-if": "DSHocSinh.length > 0",
                                                "color": "error",
                                                "class": "font-weight-medium"
                                            },
                                            "innerHTML": "Tổng số học sinh - Từ chối (GVCN): {{renderTextDSHocSinh_TuChoi()}}"
                                        },
                                        {
                                            "el": "v-chip",
                                            "attr": {
                                                "v-if": "VaiTro === 3 && DSHocSinh.length > 0",
                                                "color": "primary",
                                                "class": "font-weight-medium"
                                            },
                                            "innerHTML": "Tổng số học sinh - Gửi điểm (GVBM): {{renderTextDSHocSinh_GVBM_GuiDiem()}}"
                                        },
                                        {
                                            "el": "v-chip",
                                            "attr": {
                                                "v-if": "VaiTro === 1 &&  DSHocSinh.length > 0",
                                                "color": "primary",
                                                "class": "font-weight-medium"
                                            },
                                            "innerHTML": "Tổng số học sinh - Gửi điểm (GVCN): {{renderTextDSHocSinh_GVCN_GuiDiem()}}"
                                        }
                                    ]
                                },
                                {
                                    "el": "uc-tinh-trang-hsl",
                                    "attr": {
                                        "v-model": "DSHocSinh"
                                    }
                                },
                                {
                                    "el": "f-table",
                                    "attr": {
                                        ":headers": "headers",
                                        ":items": "DSHocSinh"
                                    }
                                },
                                {
                                    "el": "f-dialog",
                                    "attr": {
                                        "v-model": "IsShowDialogReject",
                                        "title": "Lý do từ chối",
                                        ":controls": [
                                            {
                                                "el": "v-textarea",
                                                "attr": {
                                                    "v-model": "ReasonReject",
                                                    "placeholder": "Nhập lý do từ chối..."
                                                }
                                            }
                                        ],
                                        ":button": [
                                            {
                                                "label": "Đóng",
                                                "action": [
                                                    {
                                                        "IsShowDialogReject": false
                                                    }
                                                ]
                                            },
                                            {
                                                "label": "Xác nhận",
                                                "action": [
                                                    {
                                                        "CONFIRM": "Xác nhận lý do từ chối",
                                                        "API": "lms/KQHT_MonHocLop_TinhTrang_Udp",
                                                        "IN": {
                                                            "MonHocLopID": "vueData.MonHocItem.MonHocLopID",
                                                            "LopID": "vueData.LopItem.LopID",
                                                            "TinhTrang": 3,
                                                            "MaNhomCotDiem": "vueData.MaNhomCotDiemItem.MaNhomCotDiem",
                                                            "ReasonReject": "ReasonReject",
                                                            "HocSinhID": "vueData.HocSinhItem.HocSinhID"
                                                        },
                                                        "MESS": "Từ chối thành công",
                                                        "CALLBACK": [
                                                            {
                                                                "IsShowDialogReject": false
                                                            },
                                                            {
                                                                "CALL": "HocSinhBangDiem_Get_ByMonHocID"
                                                            }
                                                        ]
                                                    }
                                                ]
                                            }
                                        ]
                                    },
                                    "w": 12
                                }
                            ]
                        }
                    ]
                }
            ]
        }
    ],
    "set": {}
}