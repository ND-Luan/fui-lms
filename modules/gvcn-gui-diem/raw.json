{
    "data": [
        {
            "CapID": "parseInt(capid)",
            "instance": null,
            "DSKhoi": [],
            "DSLop": [],
            "DSMonHoc": [],
            "DSNhomDiem": [],
            "LopItem": null,
            "KhoiItem": null,
            "MonHocItem": null,
            "MaNhomCotDiemItem": null,
            "keyComp": 0,
            "columnHeader": [],
            "DSHocSinh": [],
            "DSCotDiem": [],
            "DSCotDiem_ByMaNhomCotDiem": [],
            "DSCotDiem_TatCa": [],
            "dataBeforeInsertToDB": [],
            "TinhTrang": null,
            "styleSheet": null,
            "comments": {},
            "StatusButton": null,
            "freezeColumns": 3,
            "Semester": "HK1",
            "DSMonHoc_Selected": [],
            "VaiTro": 0,
            "VaiTro_Page": 1
        },
        {
            "getLop": {
                "API": "lms/Lop_Get_ByKhoiID",
                "IN": {
                    "KhoiID": "vueData.KhoiItem.value"
                },
                "OUT": "DSLop"
            }
        },
        {
            "getMonHoc": {
                "API": "lms/MonHoc_Get_ByLopID",
                "IN": {
                    "LopID": "vueData.LopItem.LopID"
                },
                "OUT": "DSMonHoc",
                "CALLBACK": {
                    "EXE": "vueData.DSMonHoc_Selected = vueData.DSMonHoc.map(x => x.MonHocID)"
                }
            }
        },
        {
            "HocSinhBangDiem_Get_ByMonHocID": {
                "API": "lms/HocSinhBangDiem_Get_ByMonHocID",
                "IN": {
                    "LopID": "vueData.LopItem.LopID",
                    "MonHocID": "vueData.MonHocItem.MonHocID",
                    "TemplateBangDiemID": "vueData.MonHocItem.TemplateBangDiemID"
                },
                "OUT": "DSHocSinh_API",
                "CALLBACK": {
                    "EXE": "renderDSHocSinh()"
                }
            },
            "CheckVaiTro_By_GiaoVienID_LopID_MonHocID": {
                "API": "lms/CheckVaiTro_By_GiaoVienID_LopID_MonHocID",
                "IN": {
                    "LopID": "vueData.LopItem.LopID",
                    "MonHocID": "vueData.MonHocItem.MonHocID"
                },
                "OUT": "Respone_VaiTro",
                "CALLBACK": {
                    "VaiTro": "vueData.Respone_VaiTro.VaiTro"
                }
            }
        },
        {
            "EXE": "renderDSKhoi()"
        },
        {
            "EXE": "vueData.onTuChoiDiem = onTuChoiDiem"
        },
        {
            "EXE": "vueData.onDuyetDiem = onDuyetDiem"
        }
    ],
    "watch": {
        "KhoiItem": {
            "IF": "vueData.KhoiItem.value > 0",
            "THEN": [
                {
                    "LopItem": null,
                    "MonHocItem": null,
                    "MaNhomCotDiemItem": null,
                    "DSLop": [],
                    "DSMonHoc": [],
                    "DSNhomDiem": [],
                    "DSHocSinh": []
                },
                {
                    "CALL": "getLop"
                }
            ]
        },
        "LopItem": {
            "IF": "vueData.LopItem?.LopID > 0",
            "THEN": [
                {
                    "DSHocSinh": [],
                    "MonHocItem": null,
                    "MaNhomCotDiemItem": null
                },
                {
                    "CALL": "getMonHoc"
                }
            ]
        },
        "MonHocItem": {
            "IF": "vueData.MonHocItem?.MonHocID > 0",
            "THEN": [
                {
                    "CALL": "CheckVaiTro_By_GiaoVienID_LopID_MonHocID"
                },
                {
                    "CALL": "HocSinhBangDiem_Get_ByMonHocID"
                }
            ]
        }
    },
    "controls": [
        {
            "prop": "fluid grid-list-md",
            "rows": [
                {
                    "prop": "",
                    "cols": [
                        {
                            "el": "v-card",
                            "attr": {},
                            "innerHTML": [
                                {
                                    "el": "v-card-title",
                                    "attr": {
                                        "class": "text-primary"
                                    },
                                    "innerHTML": "Tìm kiếm"
                                },
                                {
                                    "el": "v-card-text",
                                    "innerHTML": [
                                        {
                                            "el": "v-row",
                                            "innerHTML": [
                                                {
                                                    "el": "v-col",
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-select",
                                                            "attr": {
                                                                "v-model": "KhoiItem",
                                                                "label": "Chọn khối",
                                                                ":items": "DSKhoi",
                                                                "item-title": "title",
                                                                "item-value": "value",
                                                                ":return-object": true,
                                                                "hide-details": "auto"
                                                            }
                                                        }
                                                    ]
                                                },
                                                {
                                                    "el": "v-col",
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-select",
                                                            "attr": {
                                                                "v-model": "LopItem",
                                                                "label": "Chọn lớp",
                                                                ":items": "DSLop",
                                                                "item-title": "TenLop",
                                                                "item-value": "LopID",
                                                                ":return-object": true,
                                                                "hide-details": "auto"
                                                            }
                                                        }
                                                    ]
                                                },
                                                {
                                                    "el": "v-col",
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-select",
                                                            "attr": {
                                                                "v-model": "MonHocItem",
                                                                "label": "Chọn môn học",
                                                                ":items": "DSMonHoc",
                                                                "item-title": "TenMonHoc_HienThi",
                                                                "item-value": "MonHocID",
                                                                ":return-object": true,
                                                                "hide-details": "auto"
                                                            }
                                                        }
                                                    ]
                                                },
                                                {
                                                    "el": "v-col",
                                                    "innerHTML": "<f-button label='Làm mới' :action='HocSinhBangDiem_Get_ByMonHocID'  color='primary' />"
                                                }
                                            ]
                                        }
                                    ]
                                }
                            ],
                            "w": 12
                        },
                        {
                            "el": "v-card",
                            "innerHTML": [
                                {
                                    "el": "v-card-title",
                                    "innerHTML": [
                                        {
                                            "el": "div",
                                            "attr": {
                                                "class": "text-primary d-flex ga-2"
                                            },
                                            "innerHTML": [
                                                {
                                                    "el": "p",
                                                    "innerHTML": "Giáo viên gửi điểm"
                                                },
                                                {
                                                    "el": "v-chip",
                                                    "attr": {
                                                        "color": "primary",
                                                        "class": "font-weight-medium"
                                                    },
                                                    "innerHTML": "Tổng số học sinh: {{DSHocSinh.length}}"
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "el": "v-list",
                                    "attr": {},
                                    "innerHTML": [
                                        {
                                            "el": "div",
                                            "attr": {
                                                "v-if": "DSHocSinh.length > 0"
                                            },
                                            "innerHTML": "<uc-item-hoc-sinh v-model='hocSinh' v-for='(hocSinh, index) in DSHocSinh' :key='index'/>"
                                        },
                                        {
                                            "el": "uc-empty",
                                            "attr": {
                                                "v-if": "DSHocSinh.length === 0"
                                            }
                                        }
                                    ]
                                }
                            ]
                        }
                    ]
                }
            ]
        }
    ],
    "set": {}
}