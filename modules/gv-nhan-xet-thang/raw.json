{
	"data": [
		{
			"CapID": "parseInt(capid)",
			"keyTable": 0,
			"DSThang": [],
			"DSLop": [],
			"DSKhoi": [],
			"items": [],
			"ThangObj": null,
			"LopID": null,
			"columnReject": {
				"key": "reject",
				"title": "Từ chối",
				"value": "reject",
				"el": "div",
				"width": 200,
				"align": "center",
				"innerHTML": [
					{
						"el": "v-checkbox",
						"attr": {
							"v-model": "item.Is_Reject",
							"class": "checkbox-center",
							"label": "Từ chối",
							"color": "error",
							"hide-details": "true"
						}
					},
					{
						"el": "v-textarea",
						"attr": {
							"v-if": "item.Is_Reject && item.ReasonReject?.length > 0",
							"v-model": "item.ReasonReject"
						}
					}
				]
			},
			"headers": [],
			"labelTable": ""
		},
		{
			"Lop_Get_By_CapID": {
				"API": "lms/Lop_Get_By_CapID",
				"IN": {
					"CapID": "vueData.CapID"
				},
				"OUT": "DSLop"
			}
		},
		{
			"NhanXetThang_Lop_Get": {
				"API": "lms/NhanXetThang_Lop_Get",
				"IN": {
					"LopID": "vueData.LopID"
				},
				"OUT": "DSThang",
				"CALLBACK": {
					"CALL": [
						{
							"IF": "vueData.ThangObj !== null",
							"THEN": [
								{
									"EXE": "vueData.ThangObj  = vueData.DSThang.find(x=> x.Lop_NhanXetThangID === vueData.ThangObj.Lop_NhanXetThangID)"
								}
							]
						}
					]
				}
			}
		},
		{
			"NhanXetThang_Get": {
				"API": "lms/NhanXetThang_Get",
				"IN": {
					"Lop_NhanXetThangID": "vueData.ThangObj.Lop_NhanXetThangID",
					"LopID": "vueData.LopID"
				},
				"OUT": "items",
				"CALLBACK": [
					{
						"keyTable": "keyTable + 1"
					}
				]
			}
		},
		{
			"NhanXetThang_Copy": {
				"CONFIRM": "Tính năng đang được phát triển",
				"API": "lms/NhanXetThang_Copy",
				"IN": {
					"Lop_NhanXetThangID": 0,
					"Lop_NhanXetThangID_Copy": 0
				}
			}
		},
		{
			"CALL": "Lop_Get_By_CapID"
		},
		{
			"EXE": "vueData.onLuuTamByHocSinhID = onLuuTamByHocSinhID"
		},
		{
			"EXE": "vueData.renderLabelTable = renderLabelTable; vueData.renderTextDSHocSinhDaLuu = renderTextDSHocSinhDaLuu"
		},
		{
			"EXE": "vueData.labelTable = renderLabelTable()"
		}
	],
	"watch": {
		"LopID": {
			"IF": "vueData.LopID !== null",
			"THEN": [
				{
					"ThangObj": null,
					"items": []
				},
				{
					"CALL": "NhanXetThang_Lop_Get"
				},
				{
					"EXE": "localStorage.setItem('LopID_C1_NXT', vueData.LopID)"
				}
			]
		},
		"ThangObj": {
			"IF": "vueData.ThangObj?.Lop_NhanXetThangID > 0",
			"THEN": [
				{
					"CALL": "NhanXetThang_Get"
				},
				{
					"EXE": "localStorage.setItem('Thang_C' + vueData.CapID + '_NXT', JSON.stringify(vueData.ThangObj))"
				},
				{
					"EXE": "const result = fn_IsDisabledTinhTrangDiem({ TinhTrang: vueData.ThangObj.TinhTrang, type: 'GV' }); const { isDisabled } = result || {}; vueData.TinhTrang = isDisabled ?? false;"
				},
				{
					"EXE": "renderHeaderTable()"
				}
			]
		}
	},
	"controls": [
		{
			"prop": "fluid",
			"rows": [
				{
					"prop": "",
					"cols": [
						{
							"el": "v-card",
							"innerHTML": [
								{
									"el": "v-card-title",
									"innerHTML": "Tìm kiếm"
								},
								{
									"el": "v-card-text",
									"attr": {
										"class": "pa-0"
									},
									"innerHTML": [
										{
											"el": "v-row",
											"innerHTML": [
												{
													"el": "v-col",
													"attr": {
														"cols": 3
													},
													"innerHTML": [
														{
															"el": "v-select",
															"attr": {
																"v-model": "LopID",
																"label": "Chọn lớp",
																":items": "DSLop",
																"item-title": "TenLop",
																"item-value": "LopID"
															}
														}
													]
												},
												{
													"el": "v-col",
													"attr": {
														"cols": 3
													},
													"innerHTML": [
														{
															"el": "v-autocomplete",
															"attr": {
																"v-model": "ThangObj",
																"label": "Chọn Tháng",
																":items": "DSThang",
																"item-title": "Thang_HienThi",
																"item-value": "Thang",
																":return-object": true
															},
															"innerHTML": [
																{
																	"el": "template",
																	"attr": {
																		"v-slot:item": "{ props, item }"
																	},
																	"innerHTML": "<uc-item-thang v-bind='props' :item='item' />"
																}
															]
														}
													]
												},
												{
													"el": "v-col",
													"innerHTML": [
														{
															"el": "f-button",
															"attr": {
																"label": "Làm mới",
																"color": "primary",
																"variant": "tonal",
																":action": "NhanXetThang_Get"
															}
														}
													]
												}
											]
										}
									]
								}
							]
						},
						{
							"el": "div",
							"attr": {
								"class": "d-flex justify-space-between"
							},
							"innerHTML": [
								{
									"el": "div",
									"innerHTML": [
										{
											"el": "p",
											"attr": {
												"class": "text-title"
											},
											"innerHTML": "Các học sinh đã lưu: <v-chip color='primary' class='font-weight-medium'>({{renderTextDSHocSinhDaLuu()}} / {{items.length}})</v-chip>"
										}
									]
								},
								{
									"el": "div",
									"attr": {
										"class": "d-flex ga-2"
									},
									"innerHTML": [
										{
											"el": "f-button",
											"attr": {
												"label": "Import dữ liệu từ Excel",
												":disabled": "items.length === 0 ||  TinhTrang",
												"color": "success",
												"variant": "elevated",
												"target": "dialog",
												"title": "Import dữ liệu từ Excel",
												":url": "'/gv-nhan-xet-thang-import?lopid='+ LopID + '&lop_nxtid=' + ThangObj?.Lop_NhanXetThangID",
												"onclose": "CALL('NhanXetThang_Get')"
											}
										},
										{
											"el": "f-button",
											"attr": {
												"label": "Sao chép dữ liệu tháng",
												":disabled": "items.length === 0 || TinhTrang",
												"color": "info",
												"variant": "elevated",
												":action": "NhanXetThang_Copy"
											}
										},
										{
											"el": "f-button",
											"attr": {
												"label": "Gửi tổ trưởng",
												":disabled": "items.length === 0 || TinhTrang",
												"color": "primary",
												"variant": "elevated",
												":action": [
													{
														"CALL": [
															{
																"IF": "renderTextDSHocSinhDaLuu() === items.length",
																"THEN": [
																	{
																		"COFIRM": "Xác nhận gửi tổ trưởng",
																		"CALL": [
																			{
																				"EXE": "processDataBeforePostAPI()"
																			},
																			{
																				"API": "lms/NhanXetThang_Ins",
																				"IN": {
																					"JSON_NhanXetThang": "vueData.JSON_NhanXetThang"
																				},
																				"MESS": "Cập nhật nhận xét tháng thành công",
																				"CALLBACK": [
																					{
																						"API": "lms/NhanXetThang_Upd_TinhTrang",
																						"IN": {
																							"TinhTrang": 2,
																							"Lop_NhanXetThangID": "vueData.ThangObj.Lop_NhanXetThangID"
																						},
																						"MESS": "Gửi tổ trưởng thành công",
																						"CALLBACK": [
																							{
																								"CALL": "NhanXetThang_Lop_Get"
																							},
																							{
																								"CALL": "NhanXetThang_Get"
																							},
																							{
																								"EXE": "renderHeaderTable()"
																							},
																							{
																								"EXE": "const result = fn_IsDisabledTinhTrangDiem({ TinhTrang: vueData.ThangObj.TinhTrang, type: 'GV' }); const { isDisabled } = result || {}; vueData.TinhTrang = isDisabled ?? false;"
																							}
																						]
																					}
																				]
																			}
																		]
																	}
																]
															},
															{
																"IF": "renderTextDSHocSinhDaLuu() !== items.length",
																"THEN": {
																	"MESS": "Vui lòng lưu hết tất cả học sinh trước khi gửi tổ trưởng"
																}
															}
														]
													}
												]
											}
										}
									]
								}
							],
							"w": 12
						},
						{
							"el": "f-table",
							"attr": {
								":key": "keyTable",
								":label": "renderLabelTable()",
								":items": "items",
								":headers": "headers"
							},
							"w": 12
						}
					]
				}
			]
		}
	],
	"set": {}
}