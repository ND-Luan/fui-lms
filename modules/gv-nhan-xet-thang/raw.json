{
    "data": [
        {
            "EXE": "Vue.component('QuillEditor', VueQuill.QuillEditor);"
        },
        {
            "CapID": "parseInt(capid)",
            "keyTable": 0,
            "DSThang": [],
            "DSLop": [],
            "DSKhoi": [],
            "items": [],
            "headers": [
                {
                    "title": "Mã học sinh",
                    "value": "HocSinhID",
                    "width": 100
                },
                {
                    "title": "Số danh bộ",
                    "value": "SoDanhBo",
                    "align": "center",
                    "width": 150
                },
                {
                    "key": "ho_ten",
                    "el": "div",
                    "title": "Họ tên",
                    "width": 350,
                    "innerHTML": [
                        {
                            "el": "span",
                            "attr": {
                                "class": "font-weight-medium"
                            },
                            "innerHTML": "{{item.HoTen}}"
                        },
                        {
                            "el": "uc-gender",
                            "attr": {
                                "v-model": "item.Nu"
                            }
                        },
                        {
                            "el": "p",
                            "attr": {
                                "class": "text-caption"
                            },
                            "innerHTML": "{{item.NgaySinh}}"
                        }
                    ]
                },
                {
                    "key": "NoiDungKienThuc",
                    "el": "div",
                    "align": "center",
                    "innerHTML": [
                        {
                            "el": "quill-editor",
                            "attr": {
                                ":id": "item.HocSinhID+'_NoiDungKienThuc_Delta'",
                                ":key": "item.HocSinhID+'_NoiDungKienThuc_Delta'",
                                ":ref": "item.HocSinhID+'_NoiDungKienThuc_Delta'",
                                "v-model:content": "item.NoiDungKienThuc_Delta",
                                "content-type": "delta",
                                ":spellcheck": "false"
                            }
                        }
                    ],
                    "title": "Nội dung kiến thức",
                    "value": "NoiDungKienThuc",
                    "width": 500
                },
                {
                    "key": "v_btn",
                    "el": "v-btn",
                    "attr": {
                        "color": "primary",
                        "variant": "tonal",
                        "v-on:click": "() => vueData.onLuuTamByHocSinhID(item)"
                    },
                    "innerHTML": "Lưu tạm"
                }
            ],
            "ThangObj": null,
            "LopID": null
        },
        {
            "Lop_Get_By_CapID": {
                "API": "lms/Lop_Get_By_CapID",
                "IN": {
                    "CapID": "vueData.CapID"
                },
                "OUT": "DSLop"
            }
        },
        {
            "NhanXetThang_Lop_Get": {
                "API": "lms/NhanXetThang_Lop_Get",
                "IN": {
                    "LopID": "vueData.LopID"
                },
                "OUT": "DSThang"
            }
        },
        {
            "NhanXetThang_Get": {
                "API": "lms/NhanXetThang_Get",
                "IN": {
                    "Thang": "vueData.ThangObj.Thang",
                    "Nam": "vueData.ThangObj.Nam",
                    "LopID": "vueData.LopID"
                },
                "OUT": "items",
                "CALLBACK": [
                    {
                        "EXE": "convertItems();"
                    },
                    {
                        "keyTable": "keyTable + 1"
                    }
                ]
            }
        },
        {
            "CALL": "Lop_Get_By_CapID"
        },
        {
            "EXE": "vueData.onLuuTamByHocSinhID = onLuuTamByHocSinhID"
        }
    ],
    "watch": {
        "LopID": {
            "IF": "vueData.LopID !== null",
            "THEN": {
                "CALL": "NhanXetThang_Lop_Get"
            }
        },
        "ThangObj": {
            "IF": "vueData.ThangObj !== null",
            "THEN": {
                "CALL": "NhanXetThang_Get"
            }
        }
    },
    "controls": [
        {
            "prop": "fluid",
            "rows": [
                {
                    "prop": "",
                    "cols": [
                        {
                            "el": "v-card",
                            "innerHTML": [
                                {
                                    "el": "v-card-title",
                                    "innerHTML": "Tìm kiếm"
                                },
                                {
                                    "el": "v-card-text",
                                    "innerHTML": [
                                        {
                                            "el": "v-row",
                                            "innerHTML": [
                                                {
                                                    "el": "v-col",
                                                    "attr": {
                                                        "cols": 3
                                                    },
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-select",
                                                            "attr": {
                                                                "v-model": "LopID",
                                                                "label": "Chọn lớp",
                                                                ":items": "DSLop",
                                                                "item-title": "TenLop",
                                                                "item-value": "LopID"
                                                            }
                                                        }
                                                    ]
                                                },
                                                {
                                                    "el": "v-col",
                                                    "attr": {
                                                        "cols": 3
                                                    },
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-autocomplete",
                                                            "attr": {
                                                                "v-model": "ThangObj",
                                                                "label": "Chọn Tháng",
                                                                ":items": "DSThang",
                                                                "item-title": "Thang_HienThi",
                                                                "item-value": "Thang",
                                                                ":return-object": true
                                                            },
                                                            "innerHTML": [
                                                                {
                                                                    "el": "template",
                                                                    "attr": {
                                                                        "v-slot:item": "{ props, item }"
                                                                    },
                                                                    "innerHTML": "<uc-item-thang v-bind='props' :item='item' />"
                                                                }
                                                            ]
                                                        }
                                                    ]
                                                },
                                                {
                                                    "el": "v-col",
                                                    "innerHTML": [
                                                        {
                                                            "el": "f-button",
                                                            "attr": {
                                                                "label": "Làm mới",
                                                                "color": "primary",
                                                                "variant": "tonal",
                                                                ":action": "NhanXetThang_Get"
                                                            }
                                                        }
                                                    ]
                                                }
                                            ]
                                        }
                                    ]
                                }
                            ]
                        },
                        {
                            "el": "div",
                            "innerHTML": "{{items[0]}}"
                        },
                        {
                            "el": "div",
                            "attr": {
                                "class": "d-flex justify-end ga-2"
                            },
                            "innerHTML": [
                                {
                                    "el": "f-button",
                                    "attr": {
                                        "label": "Lưu tạm",
                                        "color": "primary",
                                        "variant": "tonal",
                                        ":action": [
                                            {
                                                "EXE": "processDataBeforePostAPI()"
                                            },
                                            {
                                                "API": "lms/NhanXetThang_Ins",
                                                "IN": {
                                                    "JSON_NhanXetThang": "vueData.JSON_NhanXetThang"
                                                },
                                                "MESS": "Cập nhật nhận xét tháng thành công"
                                            }
                                        ]
                                    }
                                },
                                {
                                    "el": "f-button",
                                    "attr": {
                                        "label": "Gửi tổ trưởng",
                                        "color": "primary",
                                        "variant": "elevated",
                                        ":action": [
                                            {
                                                "EXE": "processDataBeforePostAPI()"
                                            },
                                            {
                                                "API": "lms/NhanXetThang_Ins",
                                                "IN": {
                                                    "JSON_NhanXetThang": "vueData.JSON_NhanXetThang"
                                                },
                                                "MESS": "Cập nhật nhận xét tháng thành công"
                                            }
                                        ]
                                    }
                                }
                            ],
                            "w": 12
                        },
                        {
                            "el": "f-table",
                            "attr": {
                                ":key": "keyTable",
                                ":label": "'Nhận xét tháng cấp ' + CapID",
                                ":items": "items",
                                ":headers": "headers"
                            },
                            "w": 12
                        }
                    ]
                }
            ]
        }
    ],
    "set": {}
}