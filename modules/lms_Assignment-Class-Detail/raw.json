{
    "data": [
        {
            "KhoiID_FromURL": "parseInt(KhoiID)",
            "LopID_FromURL": "LopID",
            "AssignToClassID_FromURL": "parseInt(AssignToClassID)",
            "AssignToStudentID_FromURL": "parseInt(AssignToStudentID)",
            "MonHocID_FromURL": "parseInt(MonHocID)",
            "loading": false,
            "domHeaderLength": 0,
            "AssignType": "AssignType",
            "NienKhoa": "parseInt(localStorage.getItem('NienKhoa'))",
            "keyComp": 0
        }
    ],
    "watch": {
        "NienKhoa": {
            "EXE": "console.log('NienKhoa',vueData.NienKhoa)"
        }
    },
    "controls": [
        {
            "prop": "fluid pa-0",
            "rows": [
                {
                    "prop": ":no-gutters='true'",
                    "cols": [
                        {
                            "el": "uc-assignment-grading-list",
                            "attr": {
                                "v-if": "AssignType =='CLASS'",
                                ":khoiid": "parseInt(KhoiID_FromURL)",
                                ":lopid": "LopID_FromURL",
                                ":assigntoclassid": "AssignToClassID_FromURL",
                                ":monhocid": "parseInt(MonHocID_FromURL)",
                                "ref": "test",
                                ":key": "keyComp"
                            },
                            "w": 12
                        },
                        {
                            "el": "uc-assignment-grading-list-student",
                            "attr": {
                                "v-if": "AssignType  =='STUDENT'",
                                ":khoiid": "parseInt(KhoiID_FromURL)",
                                ":lopid": "LopID_FromURL",
                                ":assigntoclassid": "AssignToClassID_FromURL",
                                ":monhocid": "parseInt(MonHocID_FromURL)",
                                "ref": "test",
                                ":key": "keyComp"
                            },
                            "w": 12
                        }
                    ]
                }
            ]
        }
    ],
    "set": {
        "menu": false,
        "menuLeft": false
    }
}