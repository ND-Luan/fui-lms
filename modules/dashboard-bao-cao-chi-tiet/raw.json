{
    "data": [
        {
            "options": {
                "scales": {
                    "y": {
                        "beginAtZero": true,
                        "grace": "5%"
                    }
                },
                "responsive": true,
                "maintainAspectRatio": false
            },
            "headers": [
                {
                    "title": "HocSinhID",
                    "value": "HocSinhID"
                },
                {
                    "title": "SoDanhBo",
                    "value": "SoDanhBo"
                },
                {
                    "title": "HoTen",
                    "value": "HoTen"
                }
            ],
            "items": []
        },
        {
            "CALL": {
                "EXE": "convertDataChart()"
            }
        }
    ],
    "watch": {},
    "controls": [
        {
            "prop": "fluid",
            "rows": [
                {
                    "prop": "",
                    "cols": [
                        {
                            "el": "v-card",
                            "innerHTML": [
                                {
                                    "el": "v-card-title",
                                    "attr": {
                                        "class": "text-primary"
                                    },
                                    "innerHTML": "Chi tiết điểm số của từng học sinh"
                                },
                                {
                                    "el": "v-card-text",
                                    "attr": {
                                        "style": "height: calc(600px)"
                                    },
                                    "innerHTML": [
                                        {
                                            "el": "uc-box-plot",
                                            "attr": {
                                                ":data": "DataChart",
                                                ":options": "options"
                                            }
                                        }
                                    ]
                                }
                            ]
                        },
                        {
                            "el": "f-table",
                            "attr": {
                                "label": "Chi tiết điểm số của từng học sinh",
                                ":headers": "headers",
                                ":items": "items"
                            },
                            "w": 12
                        },
                        {
                            "el": "v-textarea",
                            "attr": {
                                "label": "Tổng kết và nhận xét chung"
                            }
                        }
                    ]
                }
            ]
        }
    ],
    "set": {}
}