{
    "data": [
        {
            "dataReady": false,
            "lesson": null,
            "assignToClassId": "AssignToClassID",
            "dataVersion": 0
        },
        {
            "getLessonData": {
                "API": "lms/EL_Student_GetAssignedLessonContent",
                "IN": {
                    "AssignToClassID": "vueData.assignToClassId"
                },
                "OUT": "lessonApiResponse",
                "CALLBACK": [
                    {
                        "EXE": "console.log('[LOG A - ALLDRAW] API Callback được kích hoạt. Chuẩn bị gọi processInitialData.')"
                    },
                    {
                        "EXE": "processInitialData(vueData.lessonApiResponse)"
                    }
                ]
            }
        },
        {
            "EXE": "initPage()"
        }
    ],
    "watch": {},
    "controls": [
        {
            "prop": "fluid pa-0",
            "rows": [
                {
                    "prop": ":no-gutters='true'",
                    "cols": [
                        {
                            "el": "uc-lesson-viewer",
                            "attr": {
                                "v-if": "dataReady",
                                ":initial-lesson": "lesson",
                                ":on-update-progress": "updateProgress",
                                ":key": "dataVersion"
                            }
                        }
                    ]
                }
            ]
        }
    ],
    "set": {
        "menu": false,
        "menuLeft": false
    }
}