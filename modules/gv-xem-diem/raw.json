{
    "data": [
        {
            "EXE": "IsCheck_NotRoleParent(vueData.user)"
        },
        {
            "CapID": "parseInt(capid)",
            "instance": null,
            "DSKhoi": [],
            "DSLop": [],
            "DSMonHoc": [],
            "DSNhomDiem": [],
            "LopItem": null,
            "KhoiItem": null,
            "MonHocItem": null,
            "MaNhomCotDiemItem": null,
            "keyComp": 0,
            "columnHeader": [],
            "DSHocSinh": [],
            "DSCotDiem": [],
            "DSCotDiem_ByMaNhomCotDiem": [],
            "DSCotDiem_TatCa": [],
            "dataBeforeInsertToDB": [],
            "TinhTrang": null,
            "styleSheet": null,
            "comments": {},
            "StatusButton": null,
            "freezeColumns": 3,
            "Semester": {
                "title": "Học kì 2",
                "value": "HK2",
                "HocKi": 2
            },
            "TitlePage": "getTitlePageByURL(window.location.pathname + window.location.search)",
            "DSSemester": [
                {
                    "title": "Học kì 1",
                    "value": "HK1",
                    "HocKi": 1
                },
                {
                    "title": "Học kì 2",
                    "value": "HK2",
                    "HocKi": 2
                },
                {
                    "title": "Cả năm",
                    "value": "CaNam",
                    "HocKi": 0
                }
            ],
            "IsShowDialogReject": false,
            "IsShowDialogTinhTrangDiem": false,
            "DSHocSinh_API_QLD": [],
            "MonHoc_QLD": [],
            "DSHocSinhQLD": []
        },
        {
            "getKhoi": {
                "API": "lms/KhoiHocByCapHoc_Get",
                "IN": {
                    "CapID": "vueData.CapID"
                },
                "OUT": "DSKhoi"
            }
        },
        {
            "getLop": {
                "API": "lms/Lop_Get_ByKhoiID",
                "IN": {
                    "NienKhoa": "vueData.NienKhoa",
                    "KhoiID": "vueData.KhoiItem.KhoiID"
                },
                "OUT": "DSLop",
                "CALLBACK": {
                    "EXE": "vueData.DSLop = vueData.DSLop.filter(x=> !x.TenLop.includes('AV'))"
                }
            }
        },
        {
            "MonHoc_QLD_GetByKhoi": {
                "API": "lms/MonHoc_QLD_GetByKhoi",
                "IN": {
                    "NienKhoa": "vueData.NienKhoa",
                    "KhoiID": "vueData.KhoiItem.KhoiID"
                },
                "OUT": "MonHoc_QLD"
            }
        },
        {
            "CALL": "getKhoi"
        }
    ],
    "watch": {
        "Semester": {
            "IF": "vueData.Semester?.value?.length > 0",
            "THEN": [
                {
                    "LopItem": null,
                    "MonHocItem": null,
                    "KhoiItem": null,
                    "MaNhomCotDiemItem": null,
                    "DSLop": [],
                    "DSMonHoc": [],
                    "DSNhomDiem": [],
                    "DSHocSinh": []
                },
                {
                    "CALL": "getLop"
                }
            ]
        },
        "KhoiItem": {
            "IF": "vueData.KhoiItem?.KhoiID > 0",
            "THEN": [
                {
                    "LopItem": null,
                    "MonHocItem": null,
                    "MaNhomCotDiemItem": null,
                    "DSLop": [],
                    "DSMonHoc": [],
                    "DSNhomDiem": [],
                    "DSHocSinh": []
                },
                {
                    "CALL": "getLop"
                }
            ]
        },
        "LopItem": {
            "IF": "vueData.LopItem?.LopID > 0",
            "THEN": [
                {
                    "DSHocSinh": [],
                    "MonHocItem": null,
                    "MaNhomCotDiemItem": null
                },
                {
                    "EXE": "getDiemTheoLop_Mon_QLD()"
                }
            ]
        }
    },
    "controls": [
        {
            "prop": "fluid grid-list-md",
            "rows": [
                {
                    "prop": "class='pt-0'",
                    "cols": [
                        {
                            "el": "v-card",
                            "attr": {
                                "class": "sticky-filter"
                            },
                            "innerHTML": [
                                {
                                    "el": "v-card-title",
                                    "attr": {
                                        "class": "text-primary px-0 pt-0"
                                    },
                                    "innerHTML": "{{TitlePage}}"
                                },
                                {
                                    "el": "v-card-text",
                                    "innerHTML": [
                                        {
                                            "el": "v-row",
                                            "innerHTML": [
                                                {
                                                    "el": "v-col",
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-select",
                                                            "attr": {
                                                                "v-model": "Semester",
                                                                "label": "Chọn học kì",
                                                                ":items": "DSSemester",
                                                                "hide-details": "auto",
                                                                "item-title": "title",
                                                                "item-value": "value",
                                                                ":return-object": true
                                                            }
                                                        }
                                                    ]
                                                },
                                                {
                                                    "el": "v-col",
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-select",
                                                            "attr": {
                                                                "v-model": "KhoiItem",
                                                                "label": "Chọn khối",
                                                                ":items": "DSKhoi",
                                                                "item-title": "TenKhoiHoc",
                                                                "item-value": "KhoiID",
                                                                ":return-object": true,
                                                                "hide-details": "auto"
                                                            }
                                                        }
                                                    ]
                                                },
                                                {
                                                    "el": "v-col",
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-select",
                                                            "attr": {
                                                                "v-model": "LopItem",
                                                                "label": "Chọn lớp",
                                                                ":items": "DSLop",
                                                                "item-title": "TenLop",
                                                                "item-value": "LopID",
                                                                ":return-object": true,
                                                                "hide-details": "auto"
                                                            }
                                                        }
                                                    ]
                                                },
                                                {
                                                    "el": "v-col",
                                                    "innerHTML": [
                                                        {
                                                            "el": "f-button",
                                                            "attr": {
                                                                "label": "Làm mới",
                                                                "color": "primary",
                                                                "variant": "tonal",
                                                                ":action": [
                                                                    {
                                                                        "EXE": "getDiemTheoLop_Mon_QLD()"
                                                                    }
                                                                ]
                                                            }
                                                        }
                                                    ]
                                                }
                                            ]
                                        }
                                    ]
                                }
                            ],
                            "w": 12
                        },
                        {
                            "el": "v-card",
                            "innerHTML": [
                                {
                                    "el": "v-card-title",
                                    "attr": {
                                        "class": "text-primary d-flex justify-space-between ga-2"
                                    },
                                    "innerHTML": [
                                        {
                                            "el": "div",
                                            "attr": {
                                                "class": "d-flex ga-2"
                                            },
                                            "innerHTML": [
                                                {
                                                    "el": "v-chip",
                                                    "attr": {
                                                        "color": "primary",
                                                        "class": "font-weight-medium"
                                                    },
                                                    "innerHTML": "Tổng số học sinh: {{DSHocSinhQLD.length}}"
                                                }
                                            ]
                                        },
                                        {
                                            "el": "f-button",
                                            "attr": {
                                                "label": "Kéo điểm",
                                                "color": "primary",
                                                ":action": [
                                                    {
                                                        "CONFIRM": "Xác nhận kéo điểm",
                                                        "EXE": "fn_KeoDiem()",
                                                        "MESS": "Kéo điểm thành công"
                                                    }
                                                ]
                                            }
                                        }
                                    ]
                                },
                                {
                                    "el": "uc-table",
                                    "attr": {}
                                }
                            ]
                        }
                    ]
                }
            ]
        }
    ],
    "set": {}
}