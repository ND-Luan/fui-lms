{
    "data": [
        {
            "HocLieuID": "parseInt(hoclieuid)",
            "NoiDungID": "parseInt(noidungid)",
            "lessonId": null,
            "lessonTitle": "Đang tải bài giảng...",
            "slides": [],
            "currentSlideIndex": -1,
            "isLoading": true,
            "getLessonResult": null,
            "DetailHocLieu": {},
            "DetailNoiDung": [],
            "lenDetailNoiDung": 0,
            "lenCurrentNoiDung": 0,
            "currentBaiGiang": null,
            "IsLoading": true,
            "showCelebration": false,
            "userProgress": {
                "completedSlides": 0,
                "totalSlides": 0,
                "currentStreak": 0,
                "stars": 0
            }
        },
        {
            "getTree": {
                "EXE": "vueData.IsLoading = true",
                "API": "lms/FP_NoiDung_GetTreeByHocLieu",
                "IN": {
                    "HocLieuID": "vueData.HocLieuID"
                },
                "OUT": "TreeResult",
                "CALLBACK": [
                    {
                        "DetailHocLieu": "TreeResult[0][0]",
                        "DetailNoiDung": "TreeResult[1]"
                    },
                    {
                        "EXE": "fn_renderDataPage()"
                    }
                ]
            },
            "getLessonDetail": {
                "API": "lms/FP_NoiDung_GetDetail",
                "IN": {
                    "NoiDungID": "vueData.lessonId"
                },
                "OUT": "getLessonResult"
            }
        },
        {
            "EXE": "vueData.initPage = initPage; vueData.handleApiResponse = handleApiResponse; vueData.goToNextSlide = goToNextSlide; vueData.goToPrevSlide = goToPrevSlide; vueData.goBack = goBack; vueData.increasePage = increasePage; vueData.decreasePage = decreasePage; vueData.showSuccessAnimation = showSuccessAnimation;"
        },
        {
            "CALL": "getTree"
        },
        {
            "EXE": "initPage()"
        }
    ],
    "watch": {
        "getLessonResult": {
            "IF": "vueData.getLessonResult.length > 0",
            "THEN": [
                {
                    "EXE": "handleApiResponse(vueData.getLessonResult)"
                }
            ]
        }
    },
    "controls": [
        {
            "prop": "fluid class='lh-app-container'",
            "rows": [
                {
                    "prop": "no-gutters class='lh-main-layout'",
                    "cols": [
                        {
                            "el": "div",
                            "attr": {
                                "class": "lh-lesson-layout"
                            },
                            "innerHTML": [
                                {
                                    "el": "header",
                                    "attr": {
                                        "class": "lh-header-premium"
                                    },
                                    "innerHTML": [
                                        {
                                            "el": "div",
                                            "attr": {
                                                "class": "lh-header-content"
                                            },
                                            "innerHTML": [
                                                {
                                                    "el": "div",
                                                    "attr": {
                                                        "class": "lh-brand-section"
                                                    },
                                                    "innerHTML": [
                                                        {
                                                            "el": "div",
                                                            "attr": {
                                                                "class": "lh-logo-container cursor-pointer",
                                                                "v-on:click": "redirect('/soan-hoc-lieu-v2')"
                                                            },
                                                            "innerHTML": [
                                                                {
                                                                    "el": "div",
                                                                    "attr": {
                                                                        "class": "lh-logo-icon"
                                                                    },
                                                                    "innerHTML": [
                                                                        {
                                                                            "el": "img",
                                                                            "attr": {
                                                                                "src": "/_cdn/lhbs-lms/logo_lhbs_2.jpg",
                                                                                "alt": "LHBS Logo",
                                                                                "class": "lh-logo-image"
                                                                            }
                                                                        }
                                                                    ]
                                                                },
                                                                {
                                                                    "el": "div",
                                                                    "attr": {
                                                                        "class": "lh-logo-text"
                                                                    },
                                                                    "innerHTML": [
                                                                        {
                                                                            "el": "div",
                                                                            "attr": {
                                                                                "class": "lh-logo-main"
                                                                            },
                                                                            "innerHTML": "LHBS"
                                                                        },
                                                                        {
                                                                            "el": "div",
                                                                            "attr": {
                                                                                "class": "lh-logo-sub"
                                                                            },
                                                                            "innerHTML": "Learning Hub"
                                                                        }
                                                                    ]
                                                                }
                                                            ]
                                                        },
                                                        {
                                                            "el": "v-btn",
                                                            "attr": {
                                                                "icon": true,
                                                                "variant": "text",
                                                                "class": "lh-back-btn",
                                                                "v-on:click": "goBack()"
                                                            },
                                                            "innerHTML": [
                                                                {
                                                                    "el": "v-icon",
                                                                    "attr": {
                                                                        "class": "lh-back-icon"
                                                                    },
                                                                    "innerHTML": "mdi-arrow-left"
                                                                }
                                                            ]
                                                        }
                                                    ]
                                                },
                                                {
                                                    "el": "div",
                                                    "attr": {
                                                        "class": "lh-breadcrumb-section"
                                                    },
                                                    "innerHTML": [
                                                        {
                                                            "el": "nav",
                                                            "attr": {
                                                                "class": "lh-breadcrumb-container"
                                                            },
                                                            "innerHTML": [
                                                                {
                                                                    "el": "div",
                                                                    "attr": {
                                                                        "class": "lh-breadcrumb-item lh-breadcrumb-subject"
                                                                    },
                                                                    "innerHTML": [
                                                                        {
                                                                            "el": "span",
                                                                            "attr": {
                                                                                "class": "lh-breadcrumb-icon"
                                                                            },
                                                                            "innerHTML": "📚"
                                                                        },
                                                                        {
                                                                            "el": "span",
                                                                            "attr": {
                                                                                "class": "lh-breadcrumb-text"
                                                                            },
                                                                            "innerHTML": "{{ DetailHocLieu?.TenHocLieu || 'Học liệu' }}"
                                                                        }
                                                                    ]
                                                                },
                                                                {
                                                                    "el": "div",
                                                                    "attr": {
                                                                        "class": "lh-breadcrumb-separator"
                                                                    },
                                                                    "innerHTML": "›"
                                                                },
                                                                {
                                                                    "el": "div",
                                                                    "attr": {
                                                                        "class": "lh-breadcrumb-item lh-breadcrumb-lesson",
                                                                        "v-if": "currentBaiGiang?.currentBai"
                                                                    },
                                                                    "innerHTML": [
                                                                        {
                                                                            "el": "span",
                                                                            "attr": {
                                                                                "class": "lh-breadcrumb-icon"
                                                                            },
                                                                            "innerHTML": "📖"
                                                                        },
                                                                        {
                                                                            "el": "span",
                                                                            "attr": {
                                                                                "class": "lh-breadcrumb-text"
                                                                            },
                                                                            "innerHTML": "{{ currentBaiGiang?.currentBai.TenNoiDung }}"
                                                                        }
                                                                    ]
                                                                },
                                                                {
                                                                    "el": "div",
                                                                    "attr": {
                                                                        "class": "lh-breadcrumb-separator",
                                                                        "v-if": "currentBaiGiang?.currentNhomKyNang"
                                                                    },
                                                                    "innerHTML": "›"
                                                                },
                                                                {
                                                                    "el": "div",
                                                                    "attr": {
                                                                        "class": "lh-breadcrumb-item lh-breadcrumb-skill",
                                                                        "v-if": "currentBaiGiang?.currentNhomKyNang"
                                                                    },
                                                                    "innerHTML": [
                                                                        {
                                                                            "el": "span",
                                                                            "attr": {
                                                                                "class": "lh-breadcrumb-icon"
                                                                            },
                                                                            "innerHTML": "🎯"
                                                                        },
                                                                        {
                                                                            "el": "span",
                                                                            "attr": {
                                                                                "class": "lh-breadcrumb-text"
                                                                            },
                                                                            "innerHTML": "{{ currentBaiGiang?.currentNhomKyNang.TenNoiDung }}"
                                                                        }
                                                                    ]
                                                                },
                                                                {
                                                                    "el": "div",
                                                                    "attr": {
                                                                        "class": "lh-breadcrumb-separator"
                                                                    },
                                                                    "innerHTML": "›"
                                                                },
                                                                {
                                                                    "el": "div",
                                                                    "attr": {
                                                                        "class": "lh-breadcrumb-item lh-breadcrumb-current"
                                                                    },
                                                                    "innerHTML": [
                                                                        {
                                                                            "el": "span",
                                                                            "attr": {
                                                                                "class": "lh-breadcrumb-icon"
                                                                            },
                                                                            "innerHTML": "✨"
                                                                        },
                                                                        {
                                                                            "el": "span",
                                                                            "attr": {
                                                                                "class": "lh-breadcrumb-text"
                                                                            },
                                                                            "innerHTML": "{{ lessonTitle }}"
                                                                        }
                                                                    ]
                                                                }
                                                            ]
                                                        }
                                                    ]
                                                },
                                                {
                                                    "el": "div",
                                                    "attr": {
                                                        "class": "lh-progress-section"
                                                    },
                                                    "innerHTML": [
                                                        {
                                                            "el": "div",
                                                            "attr": {
                                                                "class": "lh-progress-container"
                                                            },
                                                            "innerHTML": [
                                                                {
                                                                    "el": "div",
                                                                    "attr": {
                                                                        "class": "lh-progress-stars"
                                                                    },
                                                                    "innerHTML": [
                                                                        {
                                                                            "el": "span",
                                                                            "attr": {
                                                                                "v-for": "star in 5",
                                                                                ":key": "star",
                                                                                "class": "lh-star",
                                                                                ":class": "{ 'lh-star-filled': star <= Math.ceil(((lenCurrentNoiDung + 1) / lenDetailNoiDung) * 5) }"
                                                                            },
                                                                            "innerHTML": "⭐"
                                                                        }
                                                                    ]
                                                                },
                                                                {
                                                                    "el": "div",
                                                                    "attr": {
                                                                        "class": "lh-progress-text"
                                                                    },
                                                                    "innerHTML": "{{ lenCurrentNoiDung + 1 }}/{{ lenDetailNoiDung }}"
                                                                }
                                                            ]
                                                        }
                                                    ]
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "el": "main",
                                    "attr": {
                                        "class": "lh-content-main"
                                    },
                                    "innerHTML": [
                                        {
                                            "el": "div",
                                            "attr": {
                                                "class": "lh-content-container"
                                            },
                                            "innerHTML": [
                                                {
                                                    "el": "div",
                                                    "attr": {
                                                        "class": "lh-slide-container"
                                                    },
                                                    "innerHTML": [
                                                        {
                                                            "el": "div",
                                                            "attr": {
                                                                "v-if": "slides && slides.length > 0 && currentSlideIndex >= 0",
                                                                "class": "lh-slide-wrapper"
                                                            },
                                                            "innerHTML": [
                                                                {
                                                                    "el": "uc-slide-viewer-v3",
                                                                    "attr": {
                                                                        "id": "slide_viewer_premium",
                                                                        ":slide-data": "slides[currentSlideIndex]",
                                                                        "v-on:next": "() => increasePage()",
                                                                        "class": "lh-slide-viewer-premium"
                                                                    }
                                                                }
                                                            ]
                                                        },
                                                        {
                                                            "el": "div",
                                                            "attr": {
                                                                "v-else": true,
                                                                "class": "lh-loading-container"
                                                            },
                                                            "innerHTML": [
                                                                {
                                                                    "el": "div",
                                                                    "attr": {
                                                                        "class": "lh-loading-content"
                                                                    },
                                                                    "innerHTML": [
                                                                        {
                                                                            "el": "div",
                                                                            "attr": {
                                                                                "class": "lh-loading-spinner"
                                                                            }
                                                                        },
                                                                        {
                                                                            "el": "div",
                                                                            "attr": {
                                                                                "class": "lh-loading-text"
                                                                            },
                                                                            "innerHTML": "{{ lessonTitle }}"
                                                                        }
                                                                    ]
                                                                }
                                                            ]
                                                        }
                                                    ]
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "el": "footer",
                                    "attr": {
                                        "class": "lh-navigation-footer"
                                    },
                                    "innerHTML": [
                                        {
                                            "el": "div",
                                            "attr": {
                                                "class": "lh-nav-container"
                                            },
                                            "innerHTML": [
                                                {
                                                    "el": "v-btn",
                                                    "attr": {
                                                        "class": "lh-nav-btn lh-nav-prev",
                                                        "variant": "elevated",
                                                        ":disabled": "(lenCurrentNoiDung + 1) <= 1",
                                                        "v-on:click": "decreasePage"
                                                    },
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-icon",
                                                            "attr": {
                                                                ":start": true
                                                            },
                                                            "innerHTML": "mdi-chevron-left"
                                                        },
                                                        "Trước"
                                                    ]
                                                },
                                                {
                                                    "el": "div",
                                                    "attr": {
                                                        "class": "lh-nav-progress"
                                                    },
                                                    "innerHTML": [
                                                        {
                                                            "el": "div",
                                                            "attr": {
                                                                "class": "lh-progress-circle"
                                                            },
                                                            "innerHTML": [
                                                                {
                                                                    "el": "div",
                                                                    "attr": {
                                                                        "class": "lh-progress-number"
                                                                    },
                                                                    "innerHTML": "{{ lenCurrentNoiDung + 1 }}"
                                                                },
                                                                {
                                                                    "el": "div",
                                                                    "attr": {
                                                                        "class": "lh-progress-total"
                                                                    },
                                                                    "innerHTML": "/{{ lenDetailNoiDung }}"
                                                                }
                                                            ]
                                                        },
                                                        {
                                                            "el": "div",
                                                            "attr": {
                                                                "class": "lh-progress-bar-container"
                                                            },
                                                            "innerHTML": [
                                                                {
                                                                    "el": "div",
                                                                    "attr": {
                                                                        "class": "lh-progress-bar",
                                                                        ":style": "{ width: ((lenCurrentNoiDung + 1) / lenDetailNoiDung * 100) + '%' }"
                                                                    }
                                                                }
                                                            ]
                                                        }
                                                    ]
                                                },
                                                {
                                                    "el": "v-btn",
                                                    "attr": {
                                                        "class": "lh-nav-btn lh-nav-next",
                                                        "variant": "elevated",
                                                        ":disabled": "(lenCurrentNoiDung + 1) === lenDetailNoiDung",
                                                        "v-on:click": "increasePage"
                                                    },
                                                    "innerHTML": [
                                                        "Tiếp",
                                                        {
                                                            "el": "v-icon",
                                                            "attr": {
                                                                ":end": true
                                                            },
                                                            "innerHTML": "mdi-chevron-right"
                                                        }
                                                    ]
                                                }
                                            ]
                                        }
                                    ]
                                }
                            ]
                        }
                    ]
                }
            ]
        }
    ],
    "set": {
        "menu": false,
        "menuLeft": false
    }
}