{
    "data": [
        {
            "DSKhoi_Init": [],
            "DSKhoi": [],
            "DSCap": [],
            "DSLop": [],
            "headers": [
                {
                    "title": "STT",
                    "value": "STT",
                    "align": "center",
                    "width": 50
                },
                {
                    "title": "Mã học sinh",
                    "value": "HocSinhID"
                },
                {
                    "title": "Họ tên",
                    "value": "HoTen"
                },
                {
                    "el": "v-btn",
                    "title": "Xem chi tiết",
                    "align": "center",
                    "key": "Thang",
                    "value": "",
                    "attr": {
                        "title": "Xem chi tiết",
                        "color": "primary",
                        "v-on:click": "vueData.localStorageSetItem(item)"
                    },
                    "innerHTML": "Xem chi tiết"
                },
                {
                    "el": "v-chip",
                    "title": "Tình trạng HS của phần mềm KQHT",
                    "value": "TinhTrangKQHT",
                    "key": "TinhTrangKQHT",
                    "align": "center",
                    "attr": {
                        ":color": "item.TinhTrangKQHT === 0 ? 'green' : 'red' "
                    },
                    "innerHTML": "{{item.TenTinhTrangKQHT ? item.TenTinhTrangKQHT : 'Không có'}}"
                },
                {
                    "el": "v-chip",
                    "title": "Tình trạng HS của phần mềm QLHS",
                    "value": "TinhTrangQLHS",
                    "key": "TinhTrangQLHS",
                    "align": "center",
                    "attr": {
                        ":color": "item.TinhTrangQLHS === 0 ? 'green' : 'red' "
                    },
                    "innerHTML": "{{item.TenTinhTrangQLHS  ? item.TenTinhTrangQLHS : 'Không có'}}"
                }
            ],
            "items": [],
            "DSHocSinhSelected": [],
            "DSHocSinhLop": [],
            "DSHocSinh_LMS": [],
            "DSHocSinhLop_LMS": [],
            "CapItem": null,
            "KhoiItem": null,
            "LopItem": null,
            "keyTable": 1
        },
        {
            "getLop": {
                "API": "lms/Lop_Get_ByKhoiID",
                "IN": {
                    "KhoiID": "vueData.KhoiItem.KhoiID"
                },
                "OUT": "DSLop"
            },
            "getHocSinhLop": {
                "API": "lms/HocSinhLop_Get",
                "IN": {
                    "LopID": "vueData.LopItem?.LopID"
                },
                "OUT": "DSHocSinhLop"
            },
            "getEdubot_GetHocSinh": {
                "API": "student/LMS_GetHocSinh",
                "OUT": "DSHocSinh_LMS"
            },
            "getEdubot_GetHocSinhLop": {
                "API": "student/LMS_GetHocSinhLop",
                "OUT": "DSHocSinhLop_LMS",
                "CALLBACK": [
                    {
                        "DSHocSinhSelected": []
                    }
                ]
            },
            "insDSHocSinh": {
                "API": "lms/IO_IN_HocSinh_Ins",
                "IN": {
                    "HocSinhObjArr": "vueData.DSHocSinhSelected.map(x=> ({...x, TinhTrang: x.TinhTrangQLHS, TenTinhTrang: x.TenTinhTrangQLHS}))"
                }
            },
            "insDSHocSinhLop": {
                "API": "lms/IO_IN_HocSinhLop_Ins",
                "IN": {
                    "HocSinhLopObjArr": "vueData.DSHocSinhSelected.map(x=> ({...x, TinhTrang: x.TinhTrangQLHS, TenTinhTrang: x.TenTinhTrangQLHS}))"
                }
            },
            "udpDSHocSinh": [
                {
                    "CALL": "insDSHocSinh"
                },
                {
                    "CALL": "insDSHocSinhLop"
                },
                {
                    "CALL": "onRefresh"
                }
            ]
        },
        {
            "onRefresh": [
                {
                    "items": []
                },
                {
                    "CALL": "getHocSinhLop"
                },
                {
                    "CALL": "getEdubot_GetHocSinh"
                },
                {
                    "CALL": "getEdubot_GetHocSinhLop"
                }
            ]
        },
        {
            "EXE": "renderDSCap(); renderDSKhoi(); vueData.localStorageSetItem = localStorageSetItem"
        }
    ],
    "watch": {
        "keyTable": {
            "EXE": "console.log(vueData.keyTable)"
        },
        "CapItem": {
            "IF": "vueData.CapItem?.CapID > 0",
            "THEN": [
                {
                    "EXE": "vueData.DSKhoi = vueData.DSKhoi_Init.filter(x => x.CapID === vueData.CapItem?.CapID)"
                },
                {
                    "KhoiItem": null,
                    "LopItem": null,
                    "items": []
                }
            ]
        },
        "KhoiItem": {
            "IF": "vueData.KhoiItem?.KhoiID > 0",
            "THEN": [
                {
                    "LopItem": null,
                    "items": []
                },
                {
                    "CALL": "getLop"
                }
            ]
        },
        "LopItem": {
            "IF": "vueData.LopItem?.LopID > 0",
            "THEN": [
                {
                    "CALL": "onRefresh"
                }
            ]
        },
        "DSHocSinhLop_LMS": {
            "CALL": [
                {
                    "EXE": "renderDSHocSinh()"
                }
            ]
        }
    },
    "controls": [
        {
            "prop": "fluid ",
            "rows": [
                {
                    "prop": "",
                    "cols": [
                        {
                            "attr": {},
                            "el": "v-card",
                            "w": 12,
                            "innerHTML": [
                                {
                                    "el": "v-card-title",
                                    "attr": {
                                        "class": "text-primary"
                                    },
                                    "innerHTML": "Tìm kiếm"
                                },
                                {
                                    "el": "v-card-text",
                                    "attr": {},
                                    "innerHTML": [
                                        {
                                            "el": "v-row",
                                            "attr": {},
                                            "innerHTML": [
                                                {
                                                    "el": "v-col",
                                                    "attr": {},
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-select",
                                                            "attr": {
                                                                "label": "Chọn cấp",
                                                                "v-model": "CapItem",
                                                                ":items": "DSCap",
                                                                "item-title": "TenCap",
                                                                "item-value": "CapID",
                                                                ":return-object": true
                                                            }
                                                        }
                                                    ]
                                                },
                                                {
                                                    "el": "v-col",
                                                    "attr": {},
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-select",
                                                            "attr": {
                                                                "label": "Chọn khối",
                                                                "v-model": "KhoiItem",
                                                                ":items": "DSKhoi",
                                                                "item-title": "TenKhoi",
                                                                "item-value": "KhoiID",
                                                                ":return-object": true
                                                            }
                                                        }
                                                    ]
                                                },
                                                {
                                                    "el": "v-col",
                                                    "attr": {},
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-select",
                                                            "attr": {
                                                                "label": "Chọn lớp",
                                                                "v-model": "LopItem",
                                                                ":items": "DSLop",
                                                                "item-title": "TenLop",
                                                                "item-value": "LopID",
                                                                ":return-object": true
                                                            }
                                                        }
                                                    ]
                                                },
                                                {
                                                    "el": "v-col",
                                                    "attr": {},
                                                    "innerHTML": [
                                                        {
                                                            "el": "f-button",
                                                            "attr": {
                                                                "label": "Làm mới",
                                                                "color": "primary",
                                                                ":action": "onRefresh"
                                                            }
                                                        }
                                                    ]
                                                }
                                            ]
                                        }
                                    ]
                                }
                            ]
                        },
                        {
                            "el": "v-card",
                            "innerHTML": [
                                {
                                    "el": "v-card-text",
                                    "innerHTML": [
                                        {
                                            "el": "f-table",
                                            "attr": {
                                                ":key": "keyTable",
                                                "label": "Danh sách học sinh lớp",
                                                "v-model": "DSHocSinhSelected",
                                                ":show-select": true,
                                                ":headers": "headers",
                                                ":item-value": "(item) => item",
                                                ":items": "items",
                                                ":slots": [
                                                    {
                                                        "name": "top",
                                                        "html": "<div class='d-flex justify-end pa-2'> <f-button label='Cập nhật DS học sinh' :action='vueData.udpDSHocSinh' color='primary'></f-button> </div>"
                                                    }
                                                ]
                                            }
                                        }
                                    ]
                                }
                            ]
                        }
                    ]
                }
            ]
        }
    ],
    "set": {}
}