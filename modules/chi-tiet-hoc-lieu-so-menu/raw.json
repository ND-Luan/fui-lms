{
    "data": [
        {
            "HocLieuID": "parseInt(hoclieuid)",
            "NoiDungID": "parseInt(noidungid)",
            "DetailHocLieu": {},
            "DetailNoiDung": [],
            "lenDetailNoiDung": 0,
            "lenCurrentNoiDung": 0,
            "currentBaiGiang": null,
            "IsLoading": true
        },
        {
            "getTree": {
                "EXE": "vueData.IsLoading = true",
                "API": "lms/FP_NoiDung_GetTreeByHocLieu",
                "IN": {
                    "HocLieuID": "vueData.HocLieuID"
                },
                "OUT": "TreeResult",
                "CALLBACK": [
                    {
                        "DetailHocLieu": "TreeResult[0][0]",
                        "DetailNoiDung": "TreeResult[1]"
                    },
                    {
                        "EXE": "fn_renderDataPage()"
                    }
                ]
            }
        },
        {
            "CALL": "getTree"
        }
    ],
    "watch": {
        "IsLoading": {
            "EXE": "console.log('IsLoading', vueData.IsLoading)"
        }
    },
    "controls": [
        {
            "prop": "fluid pa-0",
            "rows": [
                {
                    "prop": ":no-gutters='true'",
                    "cols": [
                        {
                            "el": "iframe",
                            "attr": {
                                "class": "w-100",
                                "style": "height: calc(100dvh - 63px); border:none;",
                                ":src": "'/bai-giang-view?id='+NoiDungID"
                            },
                            "w": 12
                        },
                        {
                            "el": "v-sheet",
                            "attr": {
                                "class": "d-flex align-center bg-primary pa-2"
                            },
                            "innerHTML": [
                                {
                                    "el": "p",
                                    "innerHTML": "{{DetailHocLieu?.TenHocLieu}} / {{currentBaiGiang?.TenNoiDung}}"
                                },
                                {
                                    "el": "v-spacer"
                                },
                                {
                                    "el": "div",
                                    "attr": {
                                        "class": "d-flex align-center ga-2"
                                    },
                                    "innerHTML": [
                                        {
                                            "el": "v-btn",
                                            "attr": {
                                                "color": "white",
                                                "variant": "outlined",
                                                "icon": "mdi-chevron-left",
                                                "size": "small",
                                                "v-on:click": "decreasePage",
                                                ":disabled": "(lenCurrentNoiDung + 1) <= 1"
                                            }
                                        },
                                        {
                                            "el": "p",
                                            "innerHTML": "{{lenCurrentNoiDung + 1}} / {{lenDetailNoiDung}}"
                                        },
                                        {
                                            "el": "v-btn",
                                            "attr": {
                                                "color": "white",
                                                "variant": "outlined",
                                                "icon": "mdi-chevron-right",
                                                "size": "small",
                                                "v-on:click": "increasePage",
                                                ":disabled": "(lenCurrentNoiDung + 1) === lenDetailNoiDung"
                                            }
                                        }
                                    ]
                                }
                            ],
                            "w": 12
                        }
                    ]
                }
            ]
        }
    ],
    "set": {
        "menu": false,
        "menuLeft": false
    }
}