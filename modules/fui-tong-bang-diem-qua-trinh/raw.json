{
    "data": [
        {
            "instance": null,
            "DSKhoi": [],
            "DSLop": [],
            "DSMonHoc": [],
            "DSNhomDiem": [],
            "LopItem": null,
            "KhoiItem": null,
            "MonHocItem": null,
            "MaNhomCotDiem": null,
            "keyComp": 0,
            "columnHeader": [],
            "DSHocSinh": [],
            "DSCotDiem": [],
            "DSCotDiem_ByMaNhomCotDiem": [],
            "DSCotDiem_TatCa": [],
            "dataBeforeInsertToDB": [],
            "TinhTrang": null,
            "step": null,
            "headers": [],
            "items": []
        },
        {
            "getLop": {
                "API": "lms/Lop_Get_ByKhoiID",
                "IN": {
                    "KhoiID": "vueData.KhoiItem.value"
                },
                "OUT": "DSLop"
            }
        },
        {
            "getMonHoc": {
                "API": "lms/MonHoc_Get_ByLopID",
                "IN": {
                    "LopID": "vueData.LopItem.LopID"
                },
                "OUT": "DSMonHoc",
                "CALLBACK": {
                    "step": "DSMonHoc[0].MaNhomCotDiem"
                }
            }
        },
        {
            "getNhomDiem": {
                "API": "lms/NhomCauTrucDiem_Get_ByTemplateBangDiemID",
                "IN": {
                    "TemplateBangDiemID": "vueData.MonHocItem.TemplateBangDiemID"
                },
                "OUT": "DSNhomDiem"
            }
        },
        {
            "getHocSinhBangDiem": {
                "API": "lms/HocSinhBangDiem_Get_ByMonHocID_MaNhom",
                "IN": {
                    "LopID": "vueData.LopItem.LopID",
                    "MonHocID": "vueData.MonHocItem.MonHocID",
                    "TemplateBangDiemID": "vueData.MonHocItem.TemplateBangDiemID",
                    "MaNhomCotDiem": "vueData.MaNhomCotDiem"
                },
                "OUT": "DSCotDiem",
                "CALLBACK": [
                    {
                        "EXE": "convertDSHocSinh()"
                    },
                    {
                        "FUN": "fn_IsDisabledTinhTrangDiem",
                        "IN": {
                            "type": "`TT"
                        },
                        "OUT": "TinhTrang"
                    }
                ]
            }
        },
        {
            "EXE": "renderDSKhoi()"
        }
    ],
    "watch": {
        "KhoiItem": {
            "IF": "vueData.KhoiItem.value > 0",
            "THEN": [
                {
                    "LopItem": null,
                    "MonHocItem": null,
                    "MaNhomCotDiem": null,
                    "DSLop": [],
                    "DSMonHoc": [],
                    "DSNhomDiem": [],
                    "DSHocSinh": []
                },
                {
                    "CALL": "getLop"
                }
            ]
        },
        "LopItem": {
            "IF": "vueData.LopItem?.LopID > 0",
            "THEN": [
                {
                    "DSHocSinh": [],
                    "MonHocItem": null,
                    "MaNhomCotDiem": null
                },
                {
                    "CALL": "getMonHoc"
                }
            ]
        },
        "MonHocItem": {
            "IF": "vueData.MonHocItem?.MonHocID > 0",
            "THEN": [
                {
                    "MaNhomCotDiem": null,
                    "DSHocSinh": [],
                    "step": null
                },
                {
                    "CALL": "getNhomDiem"
                }
            ]
        },
        "MaNhomCotDiem": {
            "IF": "vueData.MaNhomCotDiem?.length > 0",
            "THEN": {
                "CALL": "getHocSinhBangDiem"
            }
        },
        "step": {
            "EXE": "vueData.MaNhomCotDiem = vueData.DSNhomDiem.find(x => x.ThuTuNhom === step)?.MaNhomCotDiem ?? ''"
        }
    },
    "controls": [
        {
            "prop": "fluid grid-list-md",
            "rows": [
                {
                    "prop": "",
                    "cols": [
                        {
                            "el": "v-card",
                            "innerHTML": [
                                {
                                    "el": "v-card-title",
                                    "attr": {
                                        "class": "text-primary"
                                    },
                                    "innerHTML": "Tìm kiếm"
                                },
                                {
                                    "el": "v-card-text",
                                    "innerHTML": [
                                        {
                                            "el": "v-row",
                                            "innerHTML": [
                                                {
                                                    "el": "v-col",
                                                    "attr": {
                                                        "cols": 12
                                                    },
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-select",
                                                            "attr": {
                                                                "v-model": "KhoiItem",
                                                                "label": "Chọn khối",
                                                                ":items": "DSKhoi",
                                                                "item-title": "title",
                                                                "item-value": "value",
                                                                ":return-object": true,
                                                                "hide-details": "auto"
                                                            }
                                                        }
                                                    ]
                                                },
                                                {
                                                    "el": "v-col",
                                                    "attr": {
                                                        "cols": 12
                                                    },
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-select",
                                                            "attr": {
                                                                "v-model": "LopItem",
                                                                "label": "Chọn lớp",
                                                                ":items": "DSLop",
                                                                "item-title": "TenLop",
                                                                "item-value": "LopID",
                                                                ":return-object": true,
                                                                "hide-details": "auto"
                                                            }
                                                        }
                                                    ]
                                                },
                                                {
                                                    "el": "v-col",
                                                    "attr": {
                                                        "cols": 12
                                                    },
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-select",
                                                            "attr": {
                                                                "v-model": "MonHocItem",
                                                                "label": "Chọn môn học",
                                                                ":items": "DSMonHoc",
                                                                "item-title": "MonHocName",
                                                                "item-value": "MonHocID",
                                                                ":return-object": true,
                                                                "hide-details": "auto"
                                                            }
                                                        }
                                                    ]
                                                },
                                                {
                                                    "el": "v-col",
                                                    "attr": {
                                                        "cols": 12
                                                    },
                                                    "innerHTML": "<f-button label='Làm mới' :action='getHocSinhBangDiem' color='primary' />"
                                                }
                                            ]
                                        }
                                    ]
                                }
                            ],
                            "w": 3
                        },
                        {
                            "el": "uc-stepper",
                            "w": 9
                        }
                    ]
                }
            ]
        }
    ],
    "set": {}
}