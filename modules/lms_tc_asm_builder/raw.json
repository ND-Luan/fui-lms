{
    "data": [
        {
            "dataReady": false,
            "isEditMode": false,
            "assignment": null,
            "AssignToClassID": "parseInt(AssignToClassID)",
            "AssignmentID": "parseInt(AssignmentID)",
            "AssignmentDataLog": {},
            "JSONINPUT": ""
        },
        {
            "EXE": "initPage()"
        }
    ],
    "watch": {},
    "controls": [
        {
            "prop": "fluid pa-0",
            "rows": [
                {
                    "prop": ":no-gutters='true'",
                    "cols": [
                        {
                            "w": 12,
                            "el": "uc-assignment-builder",
                            "attr": {
                                "v-if": "dataReady",
                                ":initial-assignment": "assignment",
                                ":is-edit-mode": "isEditMode",
                                ":on-save": "saveAssignment"
                            }
                        }
                    ]
                }
            ]
        }
    ],
    "set": {
        "menu": false,
        "menuLeft": false
    }
}