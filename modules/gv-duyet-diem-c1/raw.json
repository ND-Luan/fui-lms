{
    "data": [
        {
            "CapID": 1,
            "instance": null,
            "DSKhoi": [],
            "DSLop": [],
            "DSMonHoc": [],
            "DSNhomDiem": [],
            "LopItem": null,
            "KhoiItem": null,
            "MonHocItem": null,
            "MaNhomCotDiemItem": null,
            "keyComp": 0,
            "columnHeader": [],
            "DSHocSinh": [],
            "DSCotDiem": [],
            "DSCotDiem_ByMaNhomCotDiem": [],
            "DSCotDiem_TatCa": [],
            "dataBeforeInsertToDB": [],
            "TinhTrang": null,
            "styleSheet": null,
            "comments": {},
            "StatusButton": null,
            "freezeColumns": 3,
            "Semester": "HK1",
            "DSSemester": [
                {
                    "title": "Giữa kì 1",
                    "value": "GK_HK1"
                },
                {
                    "title": "Cuối kì 1",
                    "value": "CK_HK1"
                },
                {
                    "title": "Giữa kì 2",
                    "value": "GK_HK2"
                },
                {
                    "title": "Cuối kì 2",
                    "value": "CK_HK2"
                }
            ],
            "DSMonHoc_Selected": [],
            "IsShowDialogReject": false,
            "IsShowDialogTinhTrangDiem": false
        },
        {
            "getLop": {
                "API": "lms/Lop_Get_ByKhoiID",
                "IN": {
                    "KhoiID": "vueData.KhoiItem.value"
                },
                "OUT": "DSLop"
            }
        },
        {
            "getMonHoc": {
                "API": "lms/MonHoc_Get_ByLopID",
                "IN": {
                    "LopID": "vueData.LopItem.LopID"
                },
                "OUT": "DSMonHoc",
                "CALLBACK": {
                    "EXE": "vueData.DSMonHoc_Selected = vueData.DSMonHoc.map(x => x.MonHocID)"
                }
            }
        },
        {
            "HocSinhBangDiem_TT_BGH_Get": {
                "API": "lms/HocSinhBangDiem_TT_BGH_Get",
                "IN": {
                    "LopID": "vueData.LopItem.LopID",
                    "Semester": "vueData.Semester.value.split('_')[1]"
                },
                "OUT": "DSHocSinh_API",
                "CALLBACK": {
                    "EXE": "renderDSHocSinh()"
                }
            }
        },
        {
            "EXE": "renderDSKhoi()"
        },
        {
            "EXE": "vueData.isDisabledButton_TuChoi = isDisabledButton_TuChoi; vueData.isDisabledButton_GuiDiem = isDisabledButton_GuiDiem;"
        }
    ],
    "watch": {
        "KhoiItem": {
            "IF": "vueData.KhoiItem.value > 0",
            "THEN": [
                {
                    "LopItem": null,
                    "MonHocItem": null,
                    "MaNhomCotDiemItem": null,
                    "DSLop": [],
                    "DSMonHoc": [],
                    "DSNhomDiem": [],
                    "DSHocSinh": []
                },
                {
                    "CALL": "getLop"
                }
            ]
        },
        "LopItem": {
            "IF": "vueData.LopItem?.LopID > 0",
            "THEN": [
                {
                    "DSHocSinh": [],
                    "MonHocItem": null,
                    "MaNhomCotDiemItem": null
                },
                {
                    "CALL": "HocSinhBangDiem_TT_BGH_Get"
                },
                {
                    "CALL": "getMonHoc"
                }
            ]
        }
    },
    "controls": [
        {
            "prop": "fluid grid-list-md",
            "rows": [
                {
                    "prop": "",
                    "cols": [
                        {
                            "el": "v-card",
                            "attr": {},
                            "innerHTML": [
                                {
                                    "el": "v-card-title",
                                    "attr": {
                                        "class": "text-primary"
                                    },
                                    "innerHTML": "Tìm kiếm"
                                },
                                {
                                    "el": "v-card-text",
                                    "innerHTML": [
                                        {
                                            "el": "v-row",
                                            "innerHTML": [
                                                {
                                                    "el": "v-col",
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-select",
                                                            "attr": {
                                                                "v-model": "Semester",
                                                                "label": "Chọn học kỳ",
                                                                ":items": "DSSemester",
                                                                "hide-details": "auto",
                                                                "item-title": "title",
                                                                "item-value": "value",
                                                                ":return-object": true
                                                            }
                                                        }
                                                    ]
                                                },
                                                {
                                                    "el": "v-col",
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-select",
                                                            "attr": {
                                                                "v-model": "KhoiItem",
                                                                "label": "Chọn khối",
                                                                ":items": "DSKhoi",
                                                                "item-title": "title",
                                                                "item-value": "value",
                                                                ":return-object": true,
                                                                "hide-details": "auto"
                                                            }
                                                        }
                                                    ]
                                                },
                                                {
                                                    "el": "v-col",
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-select",
                                                            "attr": {
                                                                "v-model": "LopItem",
                                                                "label": "Chọn lớp",
                                                                ":items": "DSLop",
                                                                "item-title": "TenLop",
                                                                "item-value": "LopID",
                                                                ":return-object": true,
                                                                "hide-details": "auto"
                                                            }
                                                        }
                                                    ]
                                                },
                                                {
                                                    "el": "v-col",
                                                    "innerHTML": "<f-button label='Làm mới' :action='HocSinhBangDiem_TT_BGH_Get'  color='primary' />"
                                                }
                                            ]
                                        }
                                    ]
                                }
                            ],
                            "w": 12
                        },
                        {
                            "el": "v-card",
                            "innerHTML": [
                                {
                                    "el": "v-card-title",
                                    "attr": {
                                        "class": "text-primary d-flex justify-space-between ga-2"
                                    },
                                    "innerHTML": [
                                        {
                                            "el": "div",
                                            "attr": {
                                                "class": "d-flex ga-2"
                                            },
                                            "innerHTML": [
                                                {
                                                    "el": "div",
                                                    "innerHTML": [
                                                        {
                                                            "el": "p",
                                                            "innerHTML": "Giáo viên duyệt điểm"
                                                        },
                                                        {
                                                            "el": "p",
                                                            "attr": {
                                                                "v-if": "DSHocSinh.length > 0 && DSHocSinh[0]?.TT_LyDo_TuChoi_ID > 0",
                                                                "class": "text-black text-body-2"
                                                            },
                                                            "innerHTML": "Lý do từ chối: <span class='text-red'>{{DSHocSinh[0].TT_LyDoTuChoi}}</span>"
                                                        }
                                                    ]
                                                },
                                                {
                                                    "el": "v-chip",
                                                    "attr": {
                                                        "v-if": "1 === 2",
                                                        "color": "amber",
                                                        "class": "font-weight-medium",
                                                        "v-on:click": "IsShowDialogTinhTrangDiem = true"
                                                    },
                                                    "innerHTML": "Xem tình trạng duyệt điểm"
                                                },
                                                {
                                                    "el": "v-chip",
                                                    "attr": {
                                                        "color": "primary",
                                                        "class": "font-weight-medium"
                                                    },
                                                    "innerHTML": "Tổng số học sinh: {{DSHocSinh.length}}"
                                                }
                                            ]
                                        },
                                        {
                                            "el": "div",
                                            "attr": {
                                                "class": "d-flex ga-2"
                                            },
                                            "innerHTML": [
                                                {
                                                    "el": "v-btn",
                                                    "attr": {
                                                        "color": "error",
                                                        "v-on:click": "IsShowDialogReject = true",
                                                        ":disabled": "isDisabledButton_TuChoi()"
                                                    },
                                                    "innerHTML": "Từ chối"
                                                },
                                                {
                                                    "el": "f-button",
                                                    "attr": {
                                                        "label": "Gửi BGH",
                                                        "color": "primary",
                                                        ":disabled": "isDisabledButton_GuiDiem()",
                                                        "action": [
                                                            {
                                                                "CONFIRM": "Xác nhận gửi điểm Ban Giám Hiệu?",
                                                                "API": "lms/KQHT_MonHocLop_TinhTrang_Udp",
                                                                "IN": {
                                                                    "LopID": "vueData.LopItem.LopID",
                                                                    "TinhTrang": 6,
                                                                    "ReasonReject": "ReasonReject"
                                                                },
                                                                "MESS": "Gửi BGH thành công",
                                                                "CALLBACK": [
                                                                    {
                                                                        "CALL": "HocSinhBangDiem_TT_BGH_Get"
                                                                    }
                                                                ]
                                                            }
                                                        ]
                                                    }
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "el": "uc-table",
                                    "attr": {
                                        "v-model": "DSHocSinh",
                                        "v-memo": "[DSHocSinh]"
                                    }
                                },
                                {
                                    "el": "f-dialog",
                                    "attr": {
                                        "v-model": "IsShowDialogReject",
                                        "title": "Lý do từ chối",
                                        ":controls": [
                                            {
                                                "el": "v-textarea",
                                                "attr": {
                                                    "v-model": "ReasonReject",
                                                    "placeholder": "Nhập lý do từ chối..."
                                                }
                                            }
                                        ],
                                        ":button": [
                                            {
                                                "label": "Đóng",
                                                "action": [
                                                    {
                                                        "IsShowDialogReject": false
                                                    }
                                                ]
                                            },
                                            {
                                                "label": "Xác nhận",
                                                "action": [
                                                    {
                                                        "CONFIRM": "Xác nhận lý do từ chối",
                                                        "API": "lms/KQHT_MonHocLop_TinhTrang_Udp",
                                                        "IN": {
                                                            "LopID": "vueData.LopItem.LopID",
                                                            "TinhTrang": 5,
                                                            "ReasonReject": "ReasonReject"
                                                        },
                                                        "MESS": "Từ chối thành công",
                                                        "CALLBACK": [
                                                            {
                                                                "IsShowDialogReject": false
                                                            },
                                                            {
                                                                "CALL": "HocSinhBangDiem_TT_BGH_Get"
                                                            }
                                                        ]
                                                    }
                                                ]
                                            }
                                        ]
                                    },
                                    "w": 12
                                },
                                {
                                    "el": "f-dialog",
                                    "attr": {
                                        "v-model": "IsShowDialogTinhTrangDiem",
                                        "title": "Xem tình trạng điểm",
                                        ":width": 1300,
                                        ":controls": [
                                            {
                                                "el": "uc-tinh-trang-hsl",
                                                "attr": {
                                                    "v-model": "vueData.DSHocSinh",
                                                    ":is-mon-hoc": true
                                                }
                                            }
                                        ],
                                        ":button": [
                                            {
                                                "label": "Đóng",
                                                "action": [
                                                    {
                                                        "IsShowDialogTinhTrangDiem": false
                                                    }
                                                ]
                                            }
                                        ]
                                    },
                                    "w": 12
                                }
                            ]
                        }
                    ]
                }
            ]
        }
    ],
    "set": {}
}