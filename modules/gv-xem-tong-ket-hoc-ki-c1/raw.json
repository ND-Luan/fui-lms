{
    "data": [
        {
            "EXE": "IsCheck_NotRoleParent(vueData.user)"
        },
        {
            "CapID": "parseInt(capid)",
            "Is_InCaKhoi": false,
            "instance": null,
            "DSKhoi": [],
            "DSLop": [],
            "DSMonHoc": [],
            "DSNhomDiem": [],
            "LopItem": null,
            "KhoiItem": null,
            "MonHocItem": null,
            "MaNhomCotDiemItem": null,
            "keyComp": 0,
            "columnHeader": [],
            "DSHocSinh": [],
            "DSCotDiem": [],
            "DSCotDiem_ByMaNhomCotDiem": [],
            "DSCotDiem_TatCa": [],
            "dataBeforeInsertToDB": [],
            "TinhTrang": null,
            "styleSheet": null,
            "comments": {},
            "StatusButton": null,
            "freezeColumns": 4,
            "Semester": {
                "title": "Cuối kì 2",
                "value": 4
            },
            "DSSemester": [
                {
                    "title": "Cuối kì 2",
                    "value": 4
                }
            ],
            "DSHocSinh_API_QLD": [],
            "MonHoc_QLD": [],
            "DSHocSinhQLD": [],
            "DSHocSinh_API_TongKet": [],
            "dataDiem": [],
            "IsShowDialogConfirm": false
        },
        {
            "EXE": "initColumn()"
        },
        {
            "getKhoi": {
                "API": "lms/KhoiHocByCapHoc_Get",
                "IN": {
                    "CapID": "vueData.CapID"
                },
                "OUT": "DSKhoi"
            }
        },
        {
            "getLop": {
                "API": "lms/Lop_Get_ByKhoiID",
                "IN": {
                    "NienKhoa": "vueData.NienKhoa",
                    "KhoiID": "vueData.KhoiItem.KhoiID"
                },
                "OUT": "DSLop",
                "CALLBACK": [
                    {
                        "EXE": "initAllClass()"
                    }
                ]
            }
        },
        {
            "MonHoc_QLD_GetByKhoi": {
                "API": "lms/MonHoc_QLD_GetByKhoi",
                "IN": {
                    "NienKhoa": "vueData.NienKhoa",
                    "KhoiID": "vueData.KhoiItem.KhoiID"
                },
                "OUT": "MonHoc_QLD"
            }
        },
        {
            "CALL": "getKhoi"
        }
    ],
    "watch": {
        "KhoiItem": {
            "IF": "vueData.KhoiItem.KhoiID > 0",
            "THEN": [
                {
                    "LopItem": null,
                    "MonHocItem": null,
                    "MaNhomCotDiemItem": null,
                    "DSLop": [],
                    "DSMonHoc": [],
                    "DSNhomDiem": [],
                    "DSHocSinh": []
                },
                {
                    "CALL": "getLop"
                },
                {
                    "CALL": "MonHoc_QLD_GetByKhoi"
                }
            ]
        },
        "LopItem": {
            "CALL": [
                {
                    "IF": "vueData.LopItem?.LopID > 0",
                    "THEN": [
                        {
                            "DSHocSinh": [],
                            "MonHocItem": null,
                            "MaNhomCotDiemItem": null
                        },
                        {
                            "EXE": "TongKet_GetDTBMonHocByKhoiLop()"
                        }
                    ]
                },
                {
                    "IF": "vueData.LopItem?.LopID == '-1'",
                    "THEN": [
                        {
                            "DSHocSinh": [],
                            "MonHocItem": null,
                            "MaNhomCotDiemItem": null
                        },
                        {
                            "EXE": "getDSLop()"
                        }
                    ]
                }
            ]
        },
        "Is_InCaKhoi": {
            "IF": "Is_InCaKhoi",
            "THEN": [
                {
                    "EXE": "getDSLop()"
                }
            ]
        }
    },
    "controls": [
        {
            "prop": "fluid grid-list-md",
            "rows": [
                {
                    "prop": "",
                    "cols": [
                        {
                            "el": "v-card",
                            "attr": {},
                            "innerHTML": [
                                {
                                    "el": "v-card-title",
                                    "attr": {
                                        "class": "text-primary"
                                    },
                                    "innerHTML": [
                                        {
                                            "el": "div",
                                            "innerHTML": "Xem tổng kết học kì - Cấp 1"
                                        },
                                        {
                                            "el": "v-chip",
                                            "attr": {
                                                "color": "primary",
                                                "class": "font-weight-medium ml-2"
                                            },
                                            "innerHTML": "Tổng số học sinh: {{DSHocSinh.length}}"
                                        }
                                    ]
                                },
                                {
                                    "el": "v-card-text",
                                    "attr": {
                                        "class": "pb-0"
                                    },
                                    "innerHTML": [
                                        {
                                            "el": "v-row",
                                            "innerHTML": [
                                                {
                                                    "el": "v-col",
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-select",
                                                            "attr": {
                                                                "v-model": "Semester",
                                                                "label": "Chọn học kì",
                                                                ":items": "DSSemester",
                                                                "hide-details": "auto",
                                                                "item-title": "title",
                                                                "item-value": "value",
                                                                ":return-object": true
                                                            }
                                                        }
                                                    ]
                                                },
                                                {
                                                    "el": "v-col",
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-select",
                                                            "attr": {
                                                                "v-model": "KhoiItem",
                                                                "label": "Chọn khối",
                                                                ":items": "DSKhoi",
                                                                "item-title": "TenKhoiHoc",
                                                                "item-value": "KhoiID",
                                                                ":return-object": true,
                                                                "hide-details": "auto"
                                                            }
                                                        }
                                                    ]
                                                },
                                                {
                                                    "el": "v-col",
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-select",
                                                            "attr": {
                                                                "v-model": "LopItem",
                                                                "label": "Chọn lớp",
                                                                ":items": "DSLop.filter(item => !item.LopID.includes('N'))",
                                                                "item-title": "TenLop",
                                                                "item-value": "LopID",
                                                                ":return-object": true,
                                                                "hide-details": "auto"
                                                            }
                                                        }
                                                    ]
                                                },
                                                {
                                                    "el": "v-col",
                                                    "innerHTML": "<v-btn label='Làm mới' color='primary' variant='outlined' @click='TongKet_GetDTBMonHocByKhoiLop'>Làm mới</>"
                                                },
                                                {
                                                    "el": "v-btn",
                                                    "attr": {
                                                        "class": "float-right",
                                                        "color": "primary",
                                                        ":disabled": "DSHocSinh.length === 0",
                                                        "v-on:click": "exportExcel()"
                                                    },
                                                    "innerHTML": "Export excel"
                                                }
                                            ]
                                        }
                                    ]
                                }
                            ],
                            "w": 12
                        },
                        {
                            "el": "v-card",
                            "innerHTML": [
                                {
                                    "el": "uc-xem-tong-ket-hk"
                                }
                            ]
                        }
                    ]
                }
            ]
        }
    ],
    "set": {}
}