{
    "data": [
        {
            "EXE": "IsCheck_NotRoleParent(vueData.user)"
        },
        {
            "CapID": "parseInt(capid)",
            "Is_InCaKhoi": false,
            "instance": null,
            "DSKhoi": [],
            "DSLop": [],
            "DSMonHoc": [],
            "DSNhomDiem": [],
            "LopItem": null,
            "KhoiItem": null,
            "MonHocItem": null,
            "MaNhomCotDiemItem": null,
            "keyComp": 0,
            "columnHeader": [],
            "DSHocSinh": [],
            "DSCotDiem": [],
            "DSCotDiem_ByMaNhomCotDiem": [],
            "DSCotDiem_TatCa": [],
            "dataBeforeInsertToDB": [],
            "TinhTrang": null,
            "styleSheet": {},
            "comments": {},
            "StatusButton": null,
            "freezeColumns": 3,
            "Semester": {
                "title": "Cuối kì 2",
                "value": 2
            },
            "DSSemester": [
                {
                    "title": "Cuối kì 2",
                    "value": 2
                },
                {
                    "title": "Cả năm",
                    "value": 0
                }
            ],
            "IsShowDialogReject": false,
            "IsShowDialogTinhTrangDiem": false,
            "DSHocSinh_API_QLD": [],
            "MonHoc_QLD": [],
            "DSHocSinhQLD": [],
            "DSHocSinh_API_TongKet": [],
            "dataDiem": [],
            "DSHocSinhChange": [],
            "IsShowDialogConfirm": false
        },
        {
            "getKhoi": {
                "API": "lms/KhoiHocByCapHoc_Get",
                "IN": {
                    "CapID": "vueData.CapID"
                },
                "OUT": "DSKhoi"
            }
        },
        {
            "getLop": {
                "API": "lms/Lop_Get_ByKhoiID",
                "IN": {
                    "NienKhoa": "vueData.NienKhoa",
                    "KhoiID": "vueData.KhoiItem.KhoiID"
                },
                "OUT": "DSLop"
            }
        },
        {
            "MonHoc_QLD_GetByKhoi": {
                "API": "lms/MonHoc_QLD_GetByKhoi",
                "IN": {
                    "NienKhoa": "vueData.NienKhoa",
                    "KhoiID": "vueData.KhoiItem.KhoiID"
                },
                "OUT": "MonHoc_QLD"
            }
        },
        {
            "getKhenThuong": {
                "API": "lms/KhenThuong_Get_By_KhoiID",
                "IN": {
                    "KhoiID": "vueData.KhoiItem.KhoiID",
                    "NienKhoa": "vueData.NienKhoa"
                },
                "OUT": "DSKhenThuong"
            }
        },
        {
            "CALL": "getKhoi"
        }
    ],
    "watch": {
        "KhoiItem": {
            "IF": "vueData.KhoiItem.KhoiID > 0",
            "THEN": [
                {
                    "LopItem": null,
                    "MonHocItem": null,
                    "MaNhomCotDiemItem": null,
                    "DSLop": [],
                    "DSMonHoc": [],
                    "DSNhomDiem": [],
                    "DSHocSinh": []
                },
                {
                    "CALL": "getLop"
                },
                {
                    "CALL": "MonHoc_QLD_GetByKhoi"
                },
                {
                    "EXE": "vueData.getDiemTheoLop_QLD()"
                },
                {
                    "CALL": "getKhenThuong"
                }
            ]
        },
        "Semester": {
            "IF": "vueData.Semester?.value?.length > 0",
            "THEN": []
        }
    },
    "controls": [
        {
            "prop": "fluid grid-list-md",
            "rows": [
                {
                    "prop": "",
                    "cols": [
                        {
                            "el": "v-card",
                            "attr": {},
                            "innerHTML": [
                                {
                                    "el": "v-card-title",
                                    "attr": {
                                        "class": "text-primary px-0"
                                    },
                                    "innerHTML": "Xem tổng kết Tỉ lệ khen thưởng"
                                },
                                {
                                    "el": "v-card-text",
                                    "attr": {
                                        "class": "pb-0 px-0"
                                    },
                                    "innerHTML": [
                                        {
                                            "el": "v-row",
                                            "innerHTML": [
                                                {
                                                    "el": "v-col",
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-select",
                                                            "attr": {
                                                                "v-model": "Semester",
                                                                "label": "Chọn học kì",
                                                                ":items": "DSSemester",
                                                                "hide-details": "auto",
                                                                "item-title": "title",
                                                                "item-value": "value",
                                                                ":return-object": true
                                                            }
                                                        }
                                                    ],
                                                    "w": 2
                                                },
                                                {
                                                    "el": "v-col",
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-select",
                                                            "attr": {
                                                                "v-model": "KhoiItem",
                                                                "label": "Chọn khối",
                                                                ":items": "DSKhoi",
                                                                "item-title": "TenKhoiHoc",
                                                                "item-value": "KhoiID",
                                                                ":return-object": true,
                                                                "hide-details": "auto"
                                                            }
                                                        }
                                                    ],
                                                    "w": 2
                                                },
                                                {
                                                    "el": "v-col",
                                                    "innerHTML": "<v-btn label='Làm mới' color='primary' variant='tonal' @click='getDiemTheoLop_QLD' :disabled='!KhoiItem'>Làm mới</>"
                                                },
                                                {
                                                    "el": "v-col",
                                                    "attr": {
                                                        "v-if": "Semester.value !== 0",
                                                        "class": "d-flex align-center"
                                                    },
                                                    "w": 2
                                                }
                                            ]
                                        }
                                    ]
                                }
                            ],
                            "w": 12
                        },
                        {
                            "el": "div",
                            "attr": {
                                "class": "float-right"
                            },
                            "innerHTML": [
                                {
                                    "el": "v-btn",
                                    "attr": {
                                        "color": "primary",
                                        ":disabled": "DSHocSinhQLD.length === 0",
                                        "v-on:click": "exportExcel()"
                                    },
                                    "innerHTML": "Export excel"
                                }
                            ],
                            "w": 12
                        },
                        {
                            "el": "v-card",
                            "innerHTML": [
                                {
                                    "el": "uc-xem-tong-ket-khen-thuong",
                                    "attr": {}
                                }
                            ]
                        },
                        {
                            "el": "f-dialog",
                            "attr": {
                                "v-model": "IsShowDialogConfirm",
                                "title": "Xác nhận trước khi lưu",
                                ":width": 600,
                                ":controls": [
                                    {
                                        "el": "v-list-item",
                                        "attr": {
                                            "v-for": "hocSinh in vueData.renderDSHocSinhChange()",
                                            ":title": "hocSinh.HoTen + ' - ' + hocSinh.KQRenLuyen"
                                        }
                                    }
                                ],
                                ":button": [
                                    {
                                        "label": "Đóng",
                                        "action": {
                                            "IsShowDialogConfirm": false
                                        }
                                    },
                                    {
                                        "label": "Xác nhận",
                                        "action": {
                                            "EXE": "onSave()"
                                        }
                                    }
                                ]
                            },
                            "w": 12
                        }
                    ]
                }
            ]
        }
    ],
    "set": {}
}