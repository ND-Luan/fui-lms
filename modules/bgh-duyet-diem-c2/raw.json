{
    "data": [
        {
            "EXE": "IsCheck_NotRoleParent(vueData.user)"
        },
        {
            "CapID": 2,
            "instance": null,
            "DSKhoi": [],
            "DSLop": [],
            "DSMonHoc": [],
            "DSNhomDiem": [],
            "LopItem": null,
            "KhoiItem": null,
            "MonHocItem": null,
            "MaNhomCotDiemItem": null,
            "keyComp": 0,
            "columnHeader": [],
            "DSHocSinh": [],
            "DSCotDiem": [],
            "DSCotDiem_ByMaNhomCotDiem": [],
            "DSCotDiem_TatCa": [],
            "dataBeforeInsertToDB": [],
            "TinhTrang": null,
            "styleSheet": null,
            "comments": {},
            "StatusButton": null,
            "freezeColumns": 3,
            "IsShowDialogReject": false,
            "TitlePage": "getTitlePageByURL(window.location.pathname + window.location.search)"
        },
        {
            "getKhoi": {
                "API": "lms/KhoiHocByCapHoc_Get",
                "IN": {
                    "CapID": "vueData.CapID"
                },
                "OUT": "DSKhoi"
            }
        },
        {
            "getLop": {
                "API": "lms/Lop_Get_ByKhoiID",
                "IN": {
                    "NienKhoa": "vueData.NienKhoa",
                    "KhoiID": "vueData.KhoiItem.KhoiID"
                },
                "OUT": "DSLop"
            }
        },
        {
            "getMonHoc": {
                "API": "lms/MonHoc_Get_ByLopID",
                "IN": {
                    "NienKhoa": "vueData.NienKhoa",
                    "LopID": "vueData.LopItem.LopID"
                },
                "OUT": "DSMonHoc"
            }
        },
        {
            "getNhomDiem": {
                "API": "lms/NhomCauTrucDiem_Get_ByTemplateBangDiemID",
                "IN": {
                    "TemplateBangDiemID": "vueData.MonHocItem.TemplateBangDiemID"
                },
                "OUT": "DSNhomDiem"
            }
        },
        {
            "getHocSinhBangDiem": {
                "API": "lms/HocSinhBangDiem_Get_ByMonHocID_MaNhom",
                "IN": {
                    "LopID": "vueData.LopItem.LopID",
                    "MonHocID": "vueData.MonHocItem.MonHocID",
                    "TemplateBangDiemID": "vueData.MonHocItem.TemplateBangDiemID",
                    "MaNhomCotDiem": "vueData.MaNhomCotDiemItem.MaNhomCotDiem"
                },
                "OUT": "DSCotDiem",
                "CALLBACK": [
                    {
                        "FUN": "fn_IsDisabledTinhTrangDiem",
                        "IN": {
                            "TinhTrang": "fn_ProrityTinhTrang(vueData.DSCotDiem).TinhTrang",
                            "type": "`GV"
                        },
                        "OUT": "TinhTrang"
                    },
                    {
                        "EXE": "convertDSHocSinh()"
                    }
                ]
            }
        },
        {
            "insKQHT_MonHocLop": {
                "API": "lms/KQHT_MonHocLop_Ins",
                "IN": {
                    "NienKhoa": "vueData.NienKhoa",
                    "MonHocLopID": "vueData.MonHocItem.MonHocLopID",
                    "LopID": "vueData.LopItem.LopID",
                    "MonHocID": "vueData.MonHocItem.MonHocID",
                    "TemplateBangDiemID": "vueData.MonHocItem.TemplateBangDiemID",
                    "KetQuaObjArr": "vueData.dataBeforeInsertToDB"
                },
                "CALLBACK": [
                    {
                        "IF": "vueData.StatusButton === 'luu'",
                        "THEN": {
                            "CALL": [
                                {
                                    "IF": "vueData.CapID === 1",
                                    "THEN": {
                                        "CALL": "udpKQHT_MonHocLop_TinhTrang_LuuTam"
                                    }
                                },
                                {
                                    "IF": "vueData.CapID === 2 || vueData.CapID === 3",
                                    "THEN": {
                                        "CALL": "udpKQHT_MonHocLop_TinhTrang_LuuTam_C2_C3"
                                    }
                                }
                            ]
                        },
                        "ELSE": {
                            "CALL": "udpKQHT_MonHocLop_TinhTrang_GuiDiem"
                        }
                    },
                    {
                        "EXE": "vueData.keyComp++"
                    }
                ]
            }
        },
        {
            "udpKQHT_MonHocLop_TinhTrang_LuuTam": {
                "API": "lms/KQHT_MonHocLop_TinhTrang_Udp",
                "IN": {
                    "NienKhoa": "vueData.NienKhoa",
                    "MonHocLopID": "vueData.MonHocItem.MonHocLopID",
                    "LopID": "vueData.LopItem.LopID",
                    "TinhTrang": 1,
                    "MaNhomCotDiem": "vueData.MaNhomCotDiemItem.MaNhomCotDiem",
                    "IsSendToManager": false
                },
                "MESS": "Lưu tạm điểm thành công",
                "CALLBACK": [
                    {
                        "CALL": "getHocSinhBangDiem"
                    },
                    {
                        "dataBeforeInsertToDB": []
                    }
                ]
            },
            "udpKQHT_MonHocLop_TinhTrang_LuuTam_C2_C3": {
                "API": "lms/KQHT_MonHocLop_TinhTrang_Udp_C2_C3",
                "IN": {
                    "NienKhoa": "vueData.NienKhoa",
                    "MonHocLopID": "vueData.MonHocItem.MonHocLopID",
                    "LopID": "vueData.LopItem.LopID",
                    "TinhTrang": 1,
                    "MaNhomCotDiem": "vueData.MaNhomCotDiemItem.MaNhomCotDiem",
                    "IsSendToManager": false
                },
                "MESS": "Lưu tạm điểm thành công",
                "CALLBACK": [
                    {
                        "CALL": "getHocSinhBangDiem"
                    },
                    {
                        "dataBeforeInsertToDB": []
                    }
                ]
            }
        },
        {
            "udpKQHT_MonHocLop_TinhTrang_GuiDiem": {
                "CONFIRM": "Xác nhận gửi điểm tới tổ tưởng",
                "CALL": {
                    "API": "lms/KQHT_MonHocLop_TinhTrang_Udp",
                    "IN": {
                        "NienKhoa": "vueData.NienKhoa",
                        "MonHocLopID": "vueData.MonHocItem.MonHocLopID",
                        "LopID": "vueData.LopItem.LopID",
                        "TinhTrang": 2,
                        "MaNhomCotDiem": "vueData.MaNhomCotDiemItem.MaNhomCotDiem",
                        "IsSendToManager": true
                    },
                    "MESS": "Gửi điểm thành công",
                    "CALLBACK": [
                        {
                            "CALL": "getHocSinhBangDiem"
                        },
                        {
                            "dataBeforeInsertToDB": []
                        }
                    ]
                }
            }
        },
        {
            "CALL": [
                {
                    "CALL": "getKhoi"
                },
                {
                    "EXE": "vueData.onLuuDiem = onLuuDiem; vueData.isShowReasonReject  = isShowReasonReject; vueData.renderText_Person_Reject = renderText_Person_Reject"
                }
            ]
        }
    ],
    "watch": {
        "KhoiItem": {
            "IF": "vueData.KhoiItem.KhoiID > 0",
            "THEN": [
                {
                    "LopItem": null,
                    "MonHocItem": null,
                    "MaNhomCotDiemItem": null,
                    "DSLop": [],
                    "DSMonHoc": [],
                    "DSNhomDiem": [],
                    "DSHocSinh": []
                },
                {
                    "CALL": "getLop"
                }
            ]
        },
        "LopItem": {
            "CALL": [
                {
                    "IF": "typeof vueData.LopItem?.LopID === 'number'",
                    "THEN": {
                        "CALL": [
                            {
                                "DSHocSinh": [],
                                "DSNhomDiem": [],
                                "MonHocItem": null,
                                "MaNhomCotDiemItem": null
                            },
                            {
                                "CALL": "getMonHoc"
                            }
                        ]
                    }
                },
                {
                    "IF": "typeof vueData.LopItem?.LopID === 'string'",
                    "THEN": {
                        "CALL": [
                            {
                                "DSHocSinh": [],
                                "MonHocItem": null,
                                "MaNhomCotDiemItem": null
                            },
                            {
                                "CALL": "getMonHoc"
                            }
                        ]
                    }
                }
            ]
        },
        "MonHocItem": {
            "IF": "vueData.MonHocItem?.MonHocID > 0",
            "THEN": [
                {
                    "MaNhomCotDiemItem": null,
                    "DSHocSinh": []
                },
                {
                    "CALL": "getNhomDiem"
                }
            ]
        },
        "MaNhomCotDiemItem": {
            "IF": "vueData.MaNhomCotDiemItem?.MaNhomCotDiem?.length > 0",
            "THEN": {
                "CALL": "getHocSinhBangDiem"
            }
        }
    },
    "controls": [
        {
            "prop": "fluid grid-list-md",
            "rows": [
                {
                    "prop": "class='pt-0'",
                    "cols": [
                        {
                            "el": "v-card",
                            "attr": {
                                "class": "sticky-filter "
                            },
                            "innerHTML": [
                                {
                                    "el": "v-card-title",
                                    "attr": {
                                        "class": "text-primary px-0 pt-0"
                                    },
                                    "innerHTML": "{{TitlePage}}"
                                },
                                {
                                    "el": "v-card-text",
                                    "attr": {
                                        "class": "pa-0"
                                    },
                                    "innerHTML": [
                                        {
                                            "el": "v-row",
                                            "attr": {
                                                "dense": ""
                                            },
                                            "innerHTML": [
                                                {
                                                    "el": "v-col",
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-select",
                                                            "attr": {
                                                                "v-model": "KhoiItem",
                                                                "label": "Chọn khối",
                                                                ":items": "DSKhoi",
                                                                "item-title": "TenKhoiHoc",
                                                                "item-value": "KhoiID",
                                                                ":return-object": true,
                                                                "hide-details": "auto"
                                                            }
                                                        }
                                                    ]
                                                },
                                                {
                                                    "el": "v-col",
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-select",
                                                            "attr": {
                                                                "v-model": "LopItem",
                                                                "label": "Chọn lớp",
                                                                ":items": "DSLop",
                                                                "item-title": "TenLop",
                                                                "item-value": "LopID",
                                                                ":return-object": true,
                                                                "hide-details": "auto"
                                                            }
                                                        }
                                                    ]
                                                },
                                                {
                                                    "el": "v-col",
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-select",
                                                            "attr": {
                                                                "v-model": "MonHocItem",
                                                                "label": "Chọn môn học",
                                                                ":items": "DSMonHoc",
                                                                "item-title": "MonHocName",
                                                                "item-value": "MonHocID",
                                                                ":return-object": true,
                                                                "hide-details": "auto"
                                                            }
                                                        }
                                                    ]
                                                },
                                                {
                                                    "el": "v-col",
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-select",
                                                            "attr": {
                                                                "v-model": "MaNhomCotDiemItem",
                                                                "label": "Chọn nhóm điểm",
                                                                ":items": "DSNhomDiem",
                                                                "item-title": "TenNhomCotDiem_VI",
                                                                "item-value": "MaNhomCotDiem",
                                                                ":return-object": true,
                                                                "hide-details": "auto"
                                                            }
                                                        }
                                                    ]
                                                },
                                                {
                                                    "el": "v-col",
                                                    "innerHTML": "<f-button label='Làm mới' variant='tonal' :action='getHocSinhBangDiem' color='primary' />"
                                                }
                                            ]
                                        }
                                    ]
                                }
                            ],
                            "w": 12
                        },
                        {
                            "el": "v-card",
                            "innerHTML": [
                                {
                                    "el": "v-card-title",
                                    "innerHTML": [
                                        {
                                            "el": "div",
                                            "attr": {
                                                "class": "text-primary d-flex ga-2"
                                            },
                                            "innerHTML": [
                                                {
                                                    "el": "p",
                                                    "innerHTML": "Ban Giám Hiệu - Duyệt điểm / Đánh Giá"
                                                },
                                                {
                                                    "el": "v-chip",
                                                    "attr": {
                                                        "color": "primary",
                                                        "class": "font-weight-medium"
                                                    },
                                                    "innerHTML": "Tổng số học sinh: {{DSHocSinh.length}}"
                                                },
                                                {
                                                    "el": "v-chip",
                                                    "attr": {
                                                        "v-if": "DSHocSinh.length > 0 ",
                                                        ":color": "DSCotDiem[0]?.MauTinhTrang",
                                                        ":text": "DSCotDiem[0]?.TenTinhTrang"
                                                    }
                                                }
                                            ]
                                        },
                                        {
                                            "attr": {},
                                            "el": "v-spacer"
                                        },
                                        {
                                            "el": "v-btn",
                                            "attr": {
                                                "v-on:click": "IsShowDialogReject = true",
                                                "color": "error",
                                                "variant": "elevated"
                                            },
                                            "innerHTML": "Từ chối"
                                        },
                                        {
                                            "el": "f-button",
                                            "attr": {
                                                "class": "ml-2",
                                                "label": "Duyệt",
                                                "color": "success",
                                                "variant": "elevated",
                                                ":action": {
                                                    "CONFIRM": "Xác nhận duyệt điểm (Công bố phụ huynh)",
                                                    "API": "lms/KQHT_MonHocLop_TinhTrang_Udp_C2_C3",
                                                    "IN": {
                                                        "NienKhoa": "vueData.NienKhoa",
                                                        "LopID": "vueData.LopItem.LopID",
                                                        "MonHocLopID": "vueData.MonHocItem.MonHocLopID",
                                                        "MaNhomCotDiem": "vueData.MaNhomCotDiemItem.MaNhomCotDiem",
                                                        "TinhTrang": 4
                                                    },
                                                    "MESS": "Duyệt điểm thành công",
                                                    "CALLBACK": {
                                                        "CALL": "getHocSinhBangDiem"
                                                    }
                                                }
                                            }
                                        }
                                    ]
                                },
                                {
                                    "el": "v-card-text",
                                    "attr": {
                                        "class": "d-flex justify-space-between ga-4 pb-0"
                                    },
                                    "innerHTML": [
                                        {
                                            "el": "div",
                                            "attr": {
                                                "v-show": "DSHocSinh.length > 0 && isShowReasonReject().disabled",
                                                "class": "text-black text-body-2"
                                            },
                                            "innerHTML": [
                                                {
                                                    "el": "p",
                                                    "attr": {
                                                        "class": "text-body-2 font-weight-medium"
                                                    },
                                                    "innerHTML": "{{ renderText_Person_Reject( isShowReasonReject().TinhTrang ) }}"
                                                },
                                                {
                                                    "el": "p",
                                                    "innerHTML": "Lý do từ chối: <span class='text-red'>{{ isShowReasonReject().NoiDungNhanXet}}</span>"
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "el": "v-card-text",
                                    "attr": {
                                        "class": "pt-1"
                                    },
                                    "innerHTML": "<uc-nhap-diem />"
                                },
                                {
                                    "el": "f-dialog",
                                    "attr": {
                                        "v-model": "IsShowDialogReject",
                                        "title": "Lý do từ chối",
                                        ":width": "900",
                                        ":controls": [
                                            {
                                                "el": "v-textarea",
                                                "attr": {
                                                    "v-model": "ReasonReject",
                                                    "placeholder": "Nhập lý do từ chối..."
                                                }
                                            }
                                        ],
                                        ":button": [
                                            {
                                                "label": "Đóng",
                                                "action": [
                                                    {
                                                        "IsShowDialogReject": false
                                                    }
                                                ]
                                            },
                                            {
                                                "label": "Xác nhận",
                                                "action": [
                                                    {
                                                        "CONFIRM": "Xác nhận lý do từ chối",
                                                        "API": "lms/KQHT_MonHocLop_TinhTrang_Udp_C2_C3",
                                                        "IN": {
                                                            "NienKhoa": "vueData.NienKhoa",
                                                            "LopID": "vueData.LopItem.LopID",
                                                            "TinhTrang": 3,
                                                            "MonHocLopID": "vueData.MonHocItem.MonHocLopID",
                                                            "MaNhomCotDiem": "vueData.MaNhomCotDiemItem.MaNhomCotDiem",
                                                            "ReasonReject": "ReasonReject"
                                                        },
                                                        "MESS": "Từ chối thành công",
                                                        "CALLBACK": [
                                                            {
                                                                "IsShowDialogReject": false
                                                            },
                                                            {
                                                                "CALL": "getHocSinhBangDiem"
                                                            }
                                                        ]
                                                    }
                                                ]
                                            }
                                        ]
                                    }
                                }
                            ]
                        }
                    ]
                }
            ]
        }
    ],
    "set": {}
}