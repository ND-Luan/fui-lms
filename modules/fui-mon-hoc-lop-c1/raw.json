{
    "data": [
        {
            "headers": [
                {
                    "title": "Tên lớp",
                    "value": "TenLop"
                },
                {
                    "el": "t-button",
                    "key": "xem-diem",
                    "title": "Xem điểm",
                    "value": "",
                    "align": "center",
                    "attr": {
                        "icon": "mdi-format-list-numbered",
                        "v-on:click": "vueData.diemRecord = []; vueData.diemRecord = item; vueData.IsShowDialogDiem = true"
                    },
                    "innerHTML": "!23"
                }
            ],
            "items": [],
            "headersDiem": [
                {
                    "title": "STT",
                    "value": "STT"
                },
                {
                    "title": "Tên lớp",
                    "value": "TenLop"
                },
                {
                    "title": "Mã học sinh",
                    "value": "HocSinhID"
                },
                {
                    "title": "Họ tên",
                    "value": "HoTen"
                },
                {
                    "title": "Ngày sinh",
                    "value": "NgaySinh"
                },
                {
                    "title": "ThoiDiemDanhGia",
                    "value": "ThoiDiemDanhGia"
                },
                {
                    "title": "TenLop",
                    "value": "TenLop"
                },
                {
                    "title": "TenMon",
                    "value": "TenMon"
                },
                {
                    "title": "DiemMonHoc",
                    "value": "DiemMonHoc"
                },
                {
                    "title": "MucDoDanhGia",
                    "value": "MucDoDanhGia"
                },
                {
                    "title": "NhanXet",
                    "value": "NhanXet",
                    "attr": {
                        "minWidth": 1000
                    }
                }
            ],
            "diemItems": [],
            "controlsDiem": [],
            "diemRecord": null,
            "IsShowDialogDiem": false,
            "tableKey": 0,
            "widthFullDialog": "window.innerWidth",
            "KyDanhGia": 1
        },
        {
            "getMonHocLopC1": {
                "API": "lms/MonHocLop_CapID_1_Get",
                "OUT": "items"
            },
            "getDiemC1": {
                "API": "psmark1/LMS_GetDanhGiaHocSinh",
                "IN": {
                    "LopID": "vueData.diemRecord?.LopID",
                    "KyDanhGia": "vueData.KyDanhGia",
                    "NamHoc": 2024
                },
                "OUT": "diemItems",
                "CALLBACK": {
                    "diemItems": "diemItems.map( x => ({...x, NgaySinh: moment(x.NgaySinh, 'DD/MM/YYYY').format('DD/MM/YYYY') }))",
                    "tableKey": "tableKey+1"
                }
            }
        },
        {
            "CALL": "getMonHocLopC1"
        },
        {
            "EXE": "vueData.fn_Save = fn_Save"
        }
    ],
    "watch": {
        "IsShowDialogDiem": {
            "IF": "vueData.IsShowDialogDiem",
            "THEN": {
                "CALL": "getDiemC1"
            }
        }
    },
    "controls": [
        {
            "prop": "fluid",
            "rows": [
                {
                    "prop": "",
                    "cols": [
                        {
                            "el": "v-card",
                            "innerHTML": [
                                {
                                    "el": "v-card-text",
                                    "innerHTML": [
                                        {
                                            "el": "v-row",
                                            "innerHTML": [
                                                {
                                                    "el": "v-col",
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-select",
                                                            "attr": {
                                                                "v-model": "KyDanhGia",
                                                                "label": "Kỳ đánh giá",
                                                                ":items": [
                                                                    1,
                                                                    2,
                                                                    3,
                                                                    4
                                                                ]
                                                            }
                                                        }
                                                    ]
                                                },
                                                {
                                                    "el": "v-col",
                                                    "attr": {
                                                        "class": "d-flex justify-end"
                                                    },
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-btn",
                                                            "attr": {
                                                                "color": "primary",
                                                                "v-on:click": "() => { fn_Save() }"
                                                            },
                                                            "innerHTML": "Lưu"
                                                        }
                                                    ]
                                                }
                                            ]
                                        }
                                    ]
                                }
                            ]
                        },
                        {
                            "el": "f-table",
                            "attr": {
                                "label": "Danh sách môn học lớp C1",
                                ":headers": "headers",
                                ":items": "items"
                            },
                            "w": 12
                        },
                        {
                            "el": "f-dialog",
                            "attr": {
                                "v-model": "IsShowDialogDiem",
                                ":width": "widthFullDialog",
                                ":fullscreen": true,
                                "title": "Xem điểm",
                                ":controls": [
                                    {
                                        "el": "f-table",
                                        ":label": "'Điểm C1' + vueData.diemRecord",
                                        "attr": {
                                            ":headers": "vueData.headersDiem",
                                            ":items": "vueData.diemItems"
                                        }
                                    }
                                ],
                                ":button": [
                                    {
                                        "label": "Đóng",
                                        "action": [
                                            {
                                                "IsShowDialogDiem": false
                                            }
                                        ]
                                    }
                                ]
                            },
                            "w": 12
                        }
                    ]
                }
            ]
        }
    ],
    "set": {}
}