{
    "data": [
        {
            "EXE": "IsCheck_NotRoleParent(vueData.user)"
        },
        {
            "tab": 0,
            "itemTabs": [
                {
                    "title": "Phân phối điểm",
                    "value": 0
                },
                {
                    "title": "Tương quan điểm giữa kì và cuối kì",
                    "value": 3
                }
            ],
            "CapID": 2,
            "MonHocID": null,
            "KhoiID": null,
            "DSKhoi": [],
            "DSMonHoc": []
        },
        {
            "MonHoc_GetByKhoiID": {
                "API": "lms/MonHoc_GetByKhoiID",
                "IN": {
                    "NienKhoa": "vueData.NienKhoa",
                    "KhoiID": "vueData.KhoiID",
                    "HocKi": "vueData.NienKhoaItem.HocKi"
                },
                "OUT": "DSMonHoc",
                "CALLBACK": {
                    "DSMonHoc": "DSMonHoc.filter(x => x.MonHocID !== 48)"
                }
            }
        },
        {
            "CALL": [
                {
                    "EXE": "vueData.renderDSKhoi = renderDSKhoi"
                },
                {
                    "EXE": "vueData.DSKhoi = renderDSKhoi().filter(x=> x.CapID == vueData.CapID)"
                },
                {
                    "EXE": "vueData.KhoiID = localStorage.getItem('KhoiID_Mon_C'+ parseInt(vueData.CapID)) ? parseInt(localStorage.getItem('KhoiID_Mon_C'+ parseInt(vueData.CapID))) : null"
                },
                {
                    "EXE": "vueData.MonHocID = localStorage.getItem('MonHocID_Mon_C'+ parseInt(vueData.CapID)) ? parseInt(localStorage.getItem('MonHocID_Mon_C'+ parseInt(vueData.CapID))) : null"
                },
                {
                    "IF": "vueData.KhoiID > 0 && vueData.NienKhoa",
                    "THEN": [
                        {
                            "CALL": "MonHoc_GetByKhoiID"
                        }
                    ]
                }
            ]
        }
    ],
    "watch": {
        "KhoiID": {
            "IF": "vueData.KhoiID > 0",
            "THEN": [
                {
                    "EXE": "localStorage.setItem('KhoiID_Mon_C'+ parseInt(vueData.CapID), vueData.KhoiID)"
                },
                {
                    "CALL": "MonHoc_GetByKhoiID"
                }
            ]
        },
        "MonHocID": {
            "IF": "vueData.MonHocID > 0",
            "THEN": [
                {
                    "EXE": "localStorage.setItem('MonHocID_Mon_C'+ parseInt(vueData.CapID), vueData.MonHocID)"
                }
            ]
        }
    },
    "controls": [
        {
            "prop": "fluid",
            "rows": [
                {
                    "prop": "",
                    "cols": [
                        {
                            "el": "v-card",
                            "attr": {
                                "style": "border-radius: 0"
                            },
                            "innerHTML": [
                                {
                                    "el": "v-toolbar",
                                    "attr": {
                                        "class": "pl-4",
                                        "color": "primary"
                                    },
                                    "innerHTML": [
                                        {
                                            "el": "v-toolbar-title",
                                            "innerHTML": "Tổng quan điểm - C{{CapID}}"
                                        },
                                        {
                                            "el": "v-spacer"
                                        },
                                        {
                                            "el": "v-select",
                                            "attr": {
                                                "v-model": "KhoiID",
                                                ":items": "DSKhoi",
                                                "item-title": "title",
                                                "item-value": "value",
                                                "bg-color": "white",
                                                "hide-details": false,
                                                "placeholder": "Chọn khối",
                                                "solo": true,
                                                "class": "mr-4",
                                                "style": "max-width: 200px"
                                            }
                                        },
                                        {
                                            "el": "v-select",
                                            "attr": {
                                                "v-model": "MonHocID",
                                                ":items": "DSMonHoc",
                                                "item-title": "MonHocName",
                                                "item-value": "MonHocID",
                                                "bg-color": "white",
                                                "hide-details": false,
                                                "placeholder": "Chọn môn học",
                                                "solo": true,
                                                "class": "mr-4",
                                                "style": "max-width: 200px"
                                            }
                                        },
                                        {
                                            "el": "template",
                                            "attr": {
                                                "v-slot:extension": ""
                                            },
                                            "innerHTML": "<v-tabs v-model='tab' align-tabs='center' selected-class='bg-white text-primary'><v-tab  v-for='(item, key) in itemTabs' :key='key' :text='item.title' :value='item.value'></v-tab></v-tabs>"
                                        }
                                    ]
                                },
                                {
                                    "el": "v-tabs-window",
                                    "attr": {
                                        "v-model": "tab"
                                    },
                                    "innerHTML": [
                                        {
                                            "el": "v-tabs-window-item",
                                            "attr": {
                                                ":value": 0
                                            },
                                            "innerHTML": "<uc-tab-phan-phoi-diem :dsmonhoc='DSMonHoc' :khoiid='KhoiID' :capID='CapID' :monhocid='MonHocID' v-if='NienKhoa'/>"
                                        },
                                        {
                                            "el": "v-tabs-window-item",
                                            "attr": {
                                                ":value": 1
                                            },
                                            "innerHTML": "<uc-tab-ky-nang :khoiID='KhoiID' :capID='CapID' :monhocid='MonHocID'  v-if='NienKhoa'/>"
                                        },
                                        {
                                            "el": "v-tabs-window-item",
                                            "attr": {
                                                ":value": 2
                                            },
                                            "innerHTML": "<uc-tab-chu-de :khoiID='KhoiID' :capID='CapID' :monhocid='MonHocID' v-if='NienKhoa'/>"
                                        },
                                        {
                                            "el": "v-tabs-window-item",
                                            "attr": {
                                                ":value": 3
                                            },
                                            "innerHTML": "<uc-tab-diem-trung-binh :dsmonhoc='DSMonHoc' :khoiID='KhoiID' :capID='CapID' :monhocid='MonHocID' v-if='NienKhoa'/>"
                                        },
                                        {
                                            "el": "v-tabs-window-item",
                                            "attr": {
                                                ":value": 4
                                            },
                                            "innerHTML": "<uc-tab-diem-tong :dsmonhoc='DSMonHoc' :khoiID='KhoiID' :capID='CapID' :monhocid='MonHocID' v-if='NienKhoa'/>"
                                        }
                                    ]
                                }
                            ]
                        }
                    ]
                }
            ]
        }
    ],
    "set": {}
}