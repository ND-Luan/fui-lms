{
    "data": [
        {
            "onboarding": 0,
            "drawerOnboarding": false,
            "drawerLanguage": false,
            "drawerSelectStudent": false,
            "keyComponentUcThang": 0,
            "keyComponentUcTiengAnh": 0,
            "keyComponentUcHocKy": 0,
            "DSHocTapThang": [],
            "DSHocTapThangTiengAnh": [],
            "bottomNavigation": "localStorage.getItem('tabBottomNavigation') ? parseInt(localStorage.getItem('tabBottomNavigation')) : 0",
            "HocSinhSelected": "localStorage.getItem('HocSinhSelected') ? JSON.parse(localStorage.getItem('HocSinhSelected')) : null",
            "IsLoadingStudent": true,
            "IsLanguage": "Boolean(localStorage.getItem('IsLanguage')) ?? false"
        },
        {
            "IF": "!!vueData.HocSinhSelected === false",
            "THEN": {
                "drawerOnboarding": true
            }
        },
        {
            "getDSHocSinh": {
                "API": "student/Calen_GetInfoStudentByPhuHuynhID",
                "OUT": "DSHocSinh",
                "CALLBACK": [
                    {
                        "EXE": "vueData.DSHocSinh.push({'StudentID': '20100024','HoTen': 'Trần Bảo Hân','TenLop': '05G','Khoi': 5,'HinhThucHoc': 'SN','MaDonVi': 1})"
                    },
                    {
                        "EXE": "vueData.DSHocSinh.push({'StudentID': '19100146','HoTen': 'Đào Bảo An','TenLop': '06A','Khoi': 6,'HinhThucHoc': 'SN','MaDonVi': 1})"
                    },
                    {
                        "EXE": "vueData.DSHocSinh.push({'StudentID': '15100018','HoTen': 'Nguyễn Doãn Minh Đức','TenLop': '10A','Khoi': 10,'HinhThucHoc': 'SN','MaDonVi': 1})"
                    },
                    {
                        "EXE": "vueData.DSHocSinh = vueData.DSHocSinh.map(x => ({...x, IsShow: x.Khoi > 0 }))"
                    },
                    {
                        "IsLoadingStudent": false
                    }
                ]
            }
        },
        {
            "CALL": "getDSHocSinh"
        },
        {
            "EXE": "vueData.onSelectedHocSinh  = onSelectedHocSinh"
        },
        {
            "EXE": "convertDSHocTapThang()"
        },
        {
            "EXE": "convertDSHocTapTiengAnh()"
        }
    ],
    "watch": {
        "bottomNavigation": {
            "CALL": [
                {
                    "EXE": "setUrlTab()"
                },
                {
                    "EXE": "localStorage.setItem('tabBottomNavigation', bottomNavigation)"
                }
            ]
        } 
    },
    "controls": [
        {
            "prop": "fluid grid-list-md style='padding:0'",
            "rows": [
                {
                    "prop": "",
                    "cols": [
                        {
                            "el": "v-toolbar",
                            "attr": {
                                "v-if": "!drawerOnboarding",
                                ":elevation": "2",
                                "color": "teal-darken-4"
                            },
                            "innerHTML": [
                                {
                                    "el": "v-app-bar-title",
                                    "attr": {
                                        "class": "none-overflow"
                                    },
                                    "innerHTML": "Báo cáo kết quả học tập"
                                },
                                {
                                    "el": "v-spacer"
                                },
                                {
                                    "el": "div",
                                    "attr": {
                                        "class": "mr-2"
                                    },
                                    "innerHTML": [
                                        {
                                            "el": "v-btn",
                                            "attr": {
                                                "icon": "",
                                                "v-if": "IsLanguage",
                                                "v-on:click": "drawerLanguage = true"
                                            },
                                            "innerHTML": [
                                                {
                                                    "el": "v-img",
                                                    "attr": {
                                                        "src": "/_cdn/lhbs-lms/img_page_ph/icon_english.png",
                                                        "width": 25
                                                    }
                                                }
                                            ]
                                        },
                                        {
                                            "el": "v-btn",
                                            "attr": {
                                                "icon": "",
                                                "v-if": "!IsLanguage",
                                                "v-on:click": "drawerLanguage = true"
                                            },
                                            "innerHTML": [
                                                {
                                                    "el": "v-img",
                                                    "attr": {
                                                        "src": "/_cdn/lhbs-lms/img_page_ph/icon_vietnam.png",
                                                        "width": 25
                                                    }
                                                }
                                            ]
                                        }
                                    ]
                                }
                            ],
                            "w": 12
                        },
                        {
                            "el": "div",
                            "attr": {
                                "class": "px-4 d-flex align-center justify-space-between"
                            },
                            "innerHTML": [
                                {
                                    "el": "p",
                                    "attr": {
                                        "class": "font-weight-medium"
                                    },
                                    "innerHTML": "{{ $t('message.selectedStudent') }}"
                                },
                                {
                                    "el": "v-btn",
                                    "attr": {
                                        "icon": "",
                                        "variant": "elevated",
                                        "v-on:click": "() => drawerSelectStudent = true"
                                    },
                                    "innerHTML": [
                                        {
                                            "el": "v-img",
                                            "attr": {
                                                "src": "/_cdn/lhbs-lms/hoc_sinh.png",
                                                "width": "30",
                                                "height": "30"
                                            }
                                        }
                                    ]
                                }
                            ],
                            "w": 12
                        },
                        {
                            "el": "v-skeleton-loader",
                            "attr": {
                                "v-if": "IsLoadingStudent",
                                "type": "list-item-avatar-two-line"
                            },
                            "w": 12
                        },
                        {
                            "el": "v-fade-transition",
                            "innerHTML": [
                                {
                                    "el": "v-card",
                                    "attr": {
                                        "v-if": "!IsLoadingStudent"
                                    },
                                    "innerHTML": [
                                        {
                                            "el": "v-list-item",
                                            "attr": {
                                                "v-if": "HocSinhSelected?.StudentID",
                                                ":title": "HocSinhSelected?.HoTen",
                                                ":subtitle": "'Lớp ' + HocSinhSelected?.TenLop + ' - ' + HocSinhSelected?.StudentID "
                                            },
                                            "innerHTML": [
                                                {
                                                    "el": "template",
                                                    "attr": {
                                                        "v-slot:prepend": "item"
                                                    },
                                                    "innerHTML": "<v-avatar > <v-img :src='v_Set.urlAvatarHocSinh + HocSinhSelected?.StudentID' contain/> </v-avatar>"
                                                }
                                            ]
                                        },
                                        {
                                            "el": "uc-empty",
                                            "attr": {
                                                "v-if": "!HocSinhSelected?.StudentID",
                                                ":text": "$t('message.studentNotFound')"
                                            }
                                        }
                                    ]
                                }
                            ]
                        },
                        {
                            "el": "div",
                            "attr": {
                                "class": "fpScrollbar",
                                "style": "height: calc(100dvh - 256px); overflow: auto !important"
                            },
                            "innerHTML": [
                                {
                                    "el": "keep-alive",
                                    "innerHTML": [
                                        {
                                            "el": "uc-thang",
                                            "attr": {
                                                ":key": "keyComponentUcThang",
                                                "v-if": "bottomNavigation === 0 && HocSinhSelected?.Khoi <= 5"
                                            }
                                        }
                                    ]
                                },
                                {
                                    "el": "keep-alive",
                                    "innerHTML": [
                                        {
                                            "el": "uc-tieng-anh",
                                            "attr": {
                                                ":key": "keyComponentUcTiengAnh",
                                                "v-if": "bottomNavigation === 1"
                                            }
                                        }
                                    ]
                                },
                                {
                                    "el": "keep-alive",
                                    "innerHTML": [
                                        {
                                            "el": "uc-hoc-ky",
                                            "attr": {
                                                ":key": "keyComponentUcHocKy",
                                                "v-if": "bottomNavigation === 2"
                                            }
                                        }
                                    ]
                                }
                            ],
                            "w": 12
                        },
                        {
                            "el": "v-layout",
                            "attr": {
                                "class": "overflow-visible",
                                "style": "height: 56px"
                            },
                            "innerHTML": [
                                {
                                    "el": "v-bottom-navigation",
                                    "attr": {
                                        "v-model": "bottomNavigation",
                                        "color": "primary",
                                        ":mandatory": true,
                                        ":grow": true
                                    },
                                    "innerHTML": [
                                        {
                                            "el": "v-btn",
                                            "attr": {
                                                "v-show": "HocSinhSelected?.Khoi <= 5",
                                                ":value": 0
                                            },
                                            "innerHTML": [
                                                {
                                                    "el": "v-icon",
                                                    "innerHTML": "mdi-text-box-outline"
                                                },
                                                {
                                                    "el": "p",
                                                    "innerHTML": "{{ $t('message.month') }}"
                                                }
                                            ]
                                        },
                                        {
                                            "el": "v-btn",
                                            "attr": {
                                                ":value": 1
                                            },
                                            "innerHTML": [
                                                {
                                                    "el": "v-icon",
                                                    "innerHTML": "mdi-text-box-outline"
                                                },
                                                {
                                                    "el": "p",
                                                    "innerHTML": "{{ $t('message.english') }}"
                                                }
                                            ]
                                        },
                                        {
                                            "el": "v-btn",
                                            "attr": {
                                                ":value": 2
                                            },
                                            "innerHTML": [
                                                {
                                                    "el": "v-icon",
                                                    "innerHTML": "mdi-text-box-outline"
                                                },
                                                {
                                                    "el": "p",
                                                    "innerHTML": "{{ $t('message.semester') }}"
                                                }
                                            ]
                                        }
                                    ]
                                }
                            ],
                            "w": 12
                        },
                        {
                            "el": "div",
                            "innerHTML": [
                                {
                                    "el": "v-navigation-drawer",
                                    "attr": {
                                        "v-model": "drawerOnboarding",
                                        ":location": "$vuetify.display.mobile ? 'bottom' : undefined",
                                        ":temporary": true,
                                        "style": "min-height: 100dvh;",
                                        ":persistent": true,
                                        "width": "800"
                                    },
                                    "innerHTML": [
                                        {
                                            "el": "v-card",
                                            "innerHTML": [
                                                {
                                                    "el": "v-window",
                                                    "attr": {
                                                        "v-model": "onboarding"
                                                    },
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-window-item",
                                                            "attr": {
                                                                "key": 0,
                                                                "value": 0,
                                                                "style": "min-height: calc(100dvh - 53px);"
                                                            },
                                                            "innerHTML": [
                                                                {
                                                                    "el": "uc-chon-ngon-ngu",
                                                                    "attr": {}
                                                                }
                                                            ]
                                                        },
                                                        {
                                                            "el": "v-window-item",
                                                            "attr": {
                                                                "key": 1,
                                                                "value": 1,
                                                                "style": "min-height: calc(100dvh - 53px);"
                                                            },
                                                            "innerHTML": [
                                                                {
                                                                    "el": "uc-chon-hoc-sinh",
                                                                    "attr": {
                                                                        ":dshocsinh": "DSHocSinh"
                                                                    }
                                                                }
                                                            ]
                                                        }
                                                    ]
                                                },
                                                {
                                                    "el": "v-card-actions",
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-btn",
                                                            "attr": {
                                                                "v-if": "onboarding > 0",
                                                                "variant": "text",
                                                                "v-on:click": "onboarding--"
                                                            },
                                                            "innerHTML": "{{$t('message.back') }}"
                                                        },
                                                        {
                                                            "el": "v-spacer"
                                                        },
                                                        {
                                                            "el": "v-btn",
                                                            "attr": {
                                                                "v-if": "onboarding < 1",
                                                                "color": "primary",
                                                                "variant": "flat",
                                                                "v-on:click": "onboarding++"
                                                            },
                                                            "innerHTML": "{{$t('message.next') }}"
                                                        }
                                                    ]
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "el": "v-navigation-drawer",
                                    "attr": {
                                        "v-model": "drawerLanguage",
                                        ":location": "$vuetify.display.mobile ? 'bottom' : undefined",
                                        ":temporary": true,
                                        "style": "min-height: calc(100dvh)"
                                    },
                                    "innerHTML": [
                                        {
                                            "el": "uc-chon-ngon-ngu",
                                            "attr": {
                                                ":isonbroading": false,
                                                "v-on:onchangelanguage": "(_isLanguage) => IsLanguage =  _isLanguage"
                                            }
                                        }
                                    ]
                                },
                                {
                                    "el": "v-navigation-drawer",
                                    "attr": {
                                        "v-model": "drawerSelectStudent",
                                        ":location": "$vuetify.display.mobile ? 'bottom' : undefined",
                                        ":temporary": true,
                                        "width": "800",
                                        "style": "min-height: calc(100dvh)"
                                    },
                                    "innerHTML": [
                                        {
                                            "el": "uc-chon-hoc-sinh",
                                            "attr": {
                                                ":dshocsinh": "DSHocSinh"
                                            }
                                        }
                                    ]
                                }
                            ]
                        }
                    ]
                }
            ]
        }
    ],
    "set": {
        "menu": false
    }
}