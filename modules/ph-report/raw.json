{
    "ModuleName": "LMS System",
    "data": [
        {
            "NienKhoa": null,
            "onboarding": 0,
            "drawerOnboarding": false,
            "drawerLanguage": false,
            "drawerSelectStudent": false,
            "keyComponentUcThang": 0,
            "keyComponentUcTiengAnh": 0,
            "keyComponentUcHocKy": 0,
            "keyComponentUcTongDiemQuaTrinh": 0,
            "DSHocTapThang": [],
            "DSHocTapThangTiengAnh": [],
            "IsLoadingStudent": true,
            "isLowScreen": false,
            "IsPassRoleParent": null,
            "HocSinhID": "vueData.HocSinhID",
            "HocSinhSelected": null,
            "IsFinishLoad_getDSHocSinh": false,
            "DSNienKhoa": []
        },
        {
            "getDSHocSinh": {
                "API": "student/Calen_GetInfoStudentByPhuHuynhID",
                "OUT": "DSHocSinh",
                "CALLBACK": [
                    {
                        "EXE": "vueData.DSHocSinh = vueData.DSHocSinh.map(x => ({...x,HocSinhID: x.StudentID, IsShow: x.Khoi > 0 }))"
                    },
                    {
                        "IsLoadingStudent": false
                    },
                    {
                        "EXE": "vueData.onSelectedHocSinh({ HocSinhID: vueData.HocSinhID })"
                    },
                    {
                        "EXE": "vueData.IsFinishLoad_getDSHocSinh = true"
                    }
                ]
            },
            "getDSThang": {
                "API": "lms/PH_Thang_NhanXetThang_Lop_Get",
                "IN": {
                    "LopID": "vueData.HocSinhSelected.LopID",
                    "HSLopID": "vueData.HocSinhSelected.HSLopID"
                },
                "OUT": "DSHocTapThang"
            },
            "getDSThang_GV": {
                "API": "lms/GV_Thang_NhanXetThang_Lop_Get",
                "IN": {
                    "LopID": "vueData.HocSinhSelected.LopID",
                    "HSLopID": "vueData.HocSinhSelected.HSLopID"
                },
                "OUT": "DSHocTapThang"
            }
        },
        {
            "API": "/lms/NienKhoa_Get",
            "OUT": "DSNienKhoa_ROOT",
            "CALLBACK": {
                "EXE": " vueData.NienKhoa = vueData.DSNienKhoa_ROOT.find(x=> x.IsActive)?.NienKhoa ?? 0"
            }
        },
        {
            "CALL": "getDSHocSinh"
        },
        {
            "EXE": "initPage()"
        },
        {
            "EXE": "HandleWidth()"
        }
    ],
    "watch": {
        "NienKhoa": [
            {
                "IF": "vueData.NienKhoa !== null && vueData.IsFinishLoad_getDSHocSinh",
                "THEN": {
                    "EXE": "vueData.onSelectedHocSinh({ HocSinhID: vueData.HocSinhSelected.HocSinhID })"
                }
            }
        ],
        "bottomNavigation": {
            "CALL": [
                {
                    "EXE": "setUrlTab()"
                },
                {
                    "EXE": "localStorage.setItem('tabBottomNavigation', vueData.bottomNavigation)"
                },
                {
                    "EXE": "setActiveComponentKey()"
                }
            ]
        }
    },
    "controls": [
        {
            "prop": "fluid pa-0",
            "rows": [
                {
                    "prop": ":no-gutters='true'",
                    "attr": {
                        "style": "padding-bottom:30px"
                    },
                    "cols": [
                        {
                            "el": "v-toolbar",
                            "attr": {
                                "v-if": "!drawerOnboarding",
                                ":elevation": "2",
                                "density": "compact",
                                "color": "#1d581e"
                            },
                            "innerHTML": [
                                {
                                    "el": "v-app-bar-title",
                                    "attr": {
                                        "class": "none-overflow"
                                    },
                                    "innerHTML": "{{$t('message.nameProject')}}"
                                },
                                {
                                    "el": "v-spacer"
                                },
                                {
                                    "el": "div",
                                    "attr": {
                                        "class": "mr-2"
                                    },
                                    "innerHTML": [
                                        {
                                            "el": "v-btn",
                                            "attr": {
                                                "icon": "",
                                                "v-if": "IsLanguage",
                                                "v-on:click": "drawerLanguage = true"
                                            },
                                            "innerHTML": [
                                                {
                                                    "el": "v-img",
                                                    "attr": {
                                                        "src": "/_cdn/lhbs-lms/img_page_ph/icon_english.png",
                                                        "width": 25
                                                    }
                                                }
                                            ]
                                        },
                                        {
                                            "el": "v-btn",
                                            "attr": {
                                                "icon": "",
                                                "v-if": "!IsLanguage",
                                                "v-on:click": "drawerLanguage = true"
                                            },
                                            "innerHTML": [
                                                {
                                                    "el": "v-img",
                                                    "attr": {
                                                        "src": "/_cdn/lhbs-lms/img_page_ph/icon_vietnam.png",
                                                        "width": 25
                                                    }
                                                }
                                            ]
                                        }
                                    ]
                                }
                            ],
                            "w": 12
                        },
                        {
                            "el": "div",
                            "attr": {
                                "class": "px-4 mt-2 d-flex align-center"
                            },
                            "innerHTML": [
                                {
                                    "el": "p",
                                    "attr": {
                                        "class": "font-weight-medium"
                                    },
                                    "innerHTML": "{{ $t('message.selectedStudent') }}"
                                },
                                {
                                    "el": "v-spacer"
                                },
                                {
                                    "el": "uc-nien-khoa",
                                    "attr": {
                                        "v-model:dsnienkhoacustom": "DSNienKhoa",
                                        ":is-Show-Title": "false",
                                        ":class-Custom": "true",
                                        ":is-Show-Bottom-Sheet": true
                                    }
                                }
                            ],
                            "w": 12
                        },
                        {
                            "el": "v-skeleton-loader",
                            "attr": {
                                ":loading": "IsLoadingStudent",
                                "type": "list-item-avatar-two-line"
                            },
                            "innerHTML": [
                                {
                                    "el": "v-responsive",
                                    "innerHTML": [
                                        {
                                            "el": "v-fade-transition",
                                            "innerHTML": [
                                                {
                                                    "el": "v-card",
                                                    "attr": {
                                                        "v-if": "!IsLoadingStudent"
                                                    },
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-list-item",
                                                            "attr": {
                                                                "v-if": "HocSinhSelected?.HocSinhID",
                                                                ":title": "HocSinhSelected?.HoTen",
                                                                ":subtitle": "$t('message.class')+' ' + HocSinhSelected?.TenLop + ' • ' + HocSinhSelected?.HocSinhID "
                                                            },
                                                            "innerHTML": [
                                                                {
                                                                    "el": "template",
                                                                    "attr": {
                                                                        "v-slot:prepend": "item"
                                                                    },
                                                                    "innerHTML": "<uc-avatar :user='HocSinhSelected' />"
                                                                },
                                                                {
                                                                    "el": "template",
                                                                    "attr": {
                                                                        "v-slot:append": "item"
                                                                    },
                                                                    "innerHTML": "<v-chip class='mt-1' color='primary' variant='tonal' v-on:click='() => drawerSelectStudent = true' size='small' text='Chọn con' />"
                                                                }
                                                            ]
                                                        },
                                                        {
                                                            "el": "uc-empty",
                                                            "attr": {
                                                                "v-if": "!HocSinhSelected?.HocSinhID",
                                                                ":text": "$t('message.studentNotFound')"
                                                            }
                                                        }
                                                    ]
                                                }
                                            ]
                                        }
                                    ]
                                }
                            ],
                            "w": 12
                        },
                        {
                            "el": "div",
                            "attr": {
                                "class": "fpScrollbar"
                            },
                            "innerHTML": [
                                {
                                    "el": "uc-thang",
                                    "attr": {
                                        ":key": "keyComponentUcThang",
                                        "v-if": "bottomNavigation === 0 && NienKhoa && HocSinhSelected"
                                    }
                                },
                                {
                                    "el": "keep-alive",
                                    "innerHTML": [
                                        {
                                            "el": "uc-tieng-anh",
                                            "attr": {
                                                ":key": "keyComponentUcTiengAnh",
                                                "v-if": "bottomNavigation === 1 && NienKhoa && HocSinhSelected"
                                            }
                                        }
                                    ],
                                    "attr": {}
                                },
                                {
                                    "el": "keep-alive",
                                    "innerHTML": [
                                        {
                                            "el": "uc-hoc-ky-2",
                                            "attr": {
                                                ":key": "keyComponentUcHocKy",
                                                "v-if": "bottomNavigation === 2 && NienKhoa && HocSinhSelected"
                                            }
                                        }
                                    ],
                                    "attr": {}
                                },
                                {
                                    "__attr": {},
                                    "attr": {},
                                    "el": "keep-alive",
                                    "innerHTML": [
                                        {
                                            "el": "uc-tong-diem-qua-trinh",
                                            "attr": {
                                                ":key": "keyComponentUcTongDiemQuaTrinh",
                                                "v-if": "bottomNavigation === 3"
                                            }
                                        }
                                    ]
                                }
                            ],
                            "w": 12
                        },
                        {
                            "el": "v-layout",
                            "attr": {
                                "class": "overflow-visible",
                                "style": "height: 56px;"
                            },
                            "innerHTML": [
                                {
                                    "el": "v-bottom-navigation",
                                    "attr": {
                                        "v-model": "bottomNavigation",
                                        "color": "primary",
                                        ":mandatory": true,
                                        ":grow": true,
                                        "style": "position: fixed; bottom:0px"
                                    },
                                    "innerHTML": [
                                        {
                                            "el": "v-btn",
                                            "attr": {
                                                ":value": 0
                                            },
                                            "innerHTML": [
                                                {
                                                    "el": "v-icon",
                                                    "innerHTML": "mdi-calendar-month-outline"
                                                },
                                                {
                                                    "el": "p",
                                                    "innerHTML": "{{ $t('message.month') }}"
                                                }
                                            ]
                                        },
                                        {
                                            "el": "v-btn",
                                            "attr": {
                                                ":value": 1
                                            },
                                            "innerHTML": [
                                                {
                                                    "el": "v-icon",
                                                    "innerHTML": "mdi-text-box-outline"
                                                },
                                                {
                                                    "el": "p",
                                                    "innerHTML": "{{ $t('message.english') }}"
                                                }
                                            ]
                                        },
                                        {
                                            "el": "v-btn",
                                            "attr": {
                                                ":value": 2
                                            },
                                            "innerHTML": [
                                                {
                                                    "el": "v-icon",
                                                    "innerHTML": "mdi-calendar-multiple"
                                                },
                                                {
                                                    "el": "p",
                                                    "innerHTML": "{{ $t('message.semester') }}"
                                                }
                                            ]
                                        },
                                        {
                                            "__el": "v-btn",
                                            "attr": {
                                                ":value": 3
                                            },
                                            "innerHTML": [
                                                {
                                                    "el": "v-icon",
                                                    "innerHTML": "mdi-sigma"
                                                },
                                                {
                                                    "el": "p",
                                                    "innerHTML": "{{ $t('message.totalResults') }}"
                                                }
                                            ]
                                        }
                                    ]
                                }
                            ],
                            "w": 12
                        },
                        {
                            "el": "div",
                            "innerHTML": [
                                {
                                    "el": "v-navigation-drawer",
                                    "attr": {
                                        "v-model": "drawerOnboarding",
                                        ":location": "$vuetify.display.mobile ? 'bottom' : undefined",
                                        ":temporary": true,
                                        "style": "min-height: 100dvh;",
                                        ":persistent": true,
                                        "width": "800"
                                    },
                                    "innerHTML": [
                                        {
                                            "el": "v-card",
                                            "innerHTML": [
                                                {
                                                    "el": "v-window",
                                                    "attr": {
                                                        "v-model": "onboarding"
                                                    },
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-window-item",
                                                            "attr": {
                                                                "key": 0,
                                                                "value": 0,
                                                                "style": "min-height: calc(100dvh - 53px);"
                                                            },
                                                            "innerHTML": [
                                                                {
                                                                    "el": "uc-chon-ngon-ngu",
                                                                    "attr": {}
                                                                }
                                                            ]
                                                        },
                                                        {
                                                            "el": "v-window-item",
                                                            "attr": {
                                                                "key": 1,
                                                                "value": 1,
                                                                "style": "min-height: calc(100dvh - 53px);"
                                                            },
                                                            "innerHTML": [
                                                                {
                                                                    "el": "uc-chon-hoc-sinh",
                                                                    "attr": {
                                                                        ":dshocsinh": "DSHocSinh"
                                                                    }
                                                                }
                                                            ]
                                                        }
                                                    ]
                                                },
                                                {
                                                    "el": "v-card-actions",
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-btn",
                                                            "attr": {
                                                                "v-if": "onboarding > 0",
                                                                "variant": "text",
                                                                "v-on:click": "onboarding--"
                                                            },
                                                            "innerHTML": "{{$t('message.back') }}"
                                                        },
                                                        {
                                                            "el": "v-spacer"
                                                        },
                                                        {
                                                            "el": "v-btn",
                                                            "attr": {
                                                                "v-if": "onboarding < 1",
                                                                "color": "primary",
                                                                "variant": "flat",
                                                                "v-on:click": "onboarding++"
                                                            },
                                                            "innerHTML": "{{$t('message.next') }}"
                                                        }
                                                    ]
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "el": "v-navigation-drawer",
                                    "attr": {
                                        "v-model": "drawerLanguage",
                                        ":location": "$vuetify.display.mobile ? 'bottom' : undefined",
                                        ":temporary": true,
                                        "style": "min-height: calc(100dvh)"
                                    },
                                    "innerHTML": [
                                        {
                                            "el": "uc-chon-ngon-ngu",
                                            "attr": {
                                                ":isonbroading": false,
                                                "v-on:onchangelanguage": "(_isLanguage) => IsLanguage =  _isLanguage"
                                            }
                                        }
                                    ]
                                },
                                {
                                    "el": "v-navigation-drawer",
                                    "attr": {
                                        "v-model": "drawerSelectStudent",
                                        ":location": "$vuetify.display.mobile ? 'bottom' : undefined",
                                        ":temporary": true,
                                        "width": "800",
                                        "style": "min-height: calc(100dvh)"
                                    },
                                    "innerHTML": [
                                        {
                                            "el": "uc-chon-hoc-sinh",
                                            "attr": {
                                                ":dshocsinh": "DSHocSinh"
                                            }
                                        }
                                    ]
                                }
                            ],
                            "attr": {}
                        }
                    ],
                    "w": 12
                }
            ]
        }
    ],
    "set": {
        "menu": false,
        "menuLeft": false
    }
}