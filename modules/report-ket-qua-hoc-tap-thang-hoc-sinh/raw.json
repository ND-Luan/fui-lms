                                                                        },
                                                                        {
                                                                            "el": "v-card-text",
                                                                            "attr": {
                                                                                "v-html": "NoiDungThang?.NoiDungKienThuc_HTML"
                                                                            }
                                                                        }
                                                                    ]
                                                                }
                                                            ]
                                                        },
                                                        {
                                                            "el": "v-col",
                                                            "attr": {
                                                                "cols": "12",
                                                                "v-if": "NoiDungThang?.NoiDungNangLuc_HTML"
