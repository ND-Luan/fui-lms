                                                            "innerHTML": [
                                                                {
                                                                    "el": "v-card",
                                                                    "innerHTML": [
                                                                        {
                                                                            "el": "v-card-title",
                                                                            "innerHTML": "Năng lực"
                                                                        },
                                                                        {
                                                                            "el": "v-card-text",
                                                                            "attr": {
                                                                                "v-html": "NoiDungThang?.NoiDungNangLuc_HTML"
