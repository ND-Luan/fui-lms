{
    "data": [
        {
            "HocSinhID": "parseInt(id)",
            "Lop_NhanXetThangID": "parseInt(lop_nxtid)",
            "Nam": "parseInt(nam)",
            "HocSinhDetail": null,
            "NoiDungThang": null,
            "IsShowDialogComment": false,
            "Parent_Comment": null
        },
        {
            "API": "lms/HocSinh_Detail_GetBy_HocSinhID",
            "IN": {
                "HocSinhID": "vueData.HocSinhID"
            },
            "OUT": "HocSinhDetail"
        },
        {
            "PH_Thang_Get_By_HocSinhID": {
                "API": "lms/PH_Thang_Get_By_HocSinhID",
                "IN": {
                    "HocSinhID": "vueData.HocSinhID",
                    "Lop_NhanXetThangID": "vueData.Lop_NhanXetThangID"
                },
                "OUT": "NoiDungThang"
            }
        },
        {
            "CALL": "PH_Thang_Get_By_HocSinhID"
        }
    ],
