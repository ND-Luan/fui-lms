                                                },
                                                {
                                                    "el": "uc-empty",
                                                    "attr": {
                                                        "v-if": "!NoiDungThang?.NoiDungKienThuc_HTML && !NoiDungThang?.NoiDungNangLuc_HTML && !NoiDungThang?.NoiDungHoatDongKhac_HTML"
                                                    }
                                                }
                                            ]
                                        }
                                    ]
                                },
                                {
                                    "el": "div",
                                    "attr": {
                                        "class": "text-primary font-weight-medium pt-2 pb-2"
                                    },
                                    "innerHTML": "{{ $t('message.comment') }}"
                                },
                                {
                                    "el": "v-card",
                                    "attr": {},
                                    "innerHTML": [
                                        {
                                            "el": "v-card-text",
                                            "attr": {
                                                "v-if": "NoiDungThang?.Parent_Comment"
                                            },
                                            "innerHTML": "{{NoiDungThang?.Parent_Comment}}"
                                        },
                                        {
                                            "el": "uc-empty",
                                            "attr": {
                                                "v-else": ""
                                            }
                                        }
                                    ]
                                }
                            ]
                        },
                        {
                            "el": "v-btn",
                            "attr": {
                                "v-if": "NoiDungThang?.Parent_Comment === null && Object.keys(NoiDungThang ?? {})?.length === 0",
                                "class": "position-fixed elevated-8",
                                "style": "bottom: 16px; right: 16px",
                                "icon": "",
                                "v-on:click": "IsShowDialogComment = true"
                            },
                            "innerHTML": "<v-img src='/_cdn/lhbs-lms/img_page_ph/icon_ph_comment.png' width='50'/>",
                            "w": 12
                        },
                        {
                            "el": "f-dialog",
                            "attr": {
                                "v-model": "IsShowDialogComment",
                                "title": "Nhận xét dành cho phụ huynh",
                                ":controls": [
                                    {
                                        "el": "v-textarea",
                                        "attr": {
                                            "v-model": "Parent_Comment",
                                            "label": "Nhận xét"
                                        }
                                    }
                                ],
                                ":button": [
                                    {
                                        "label": "Đóng",
                                        "action": {
                                            "IsShowDialogComment": false
                                        }
                                    },
                                    {
                                        "label": "Xác nhận",
                                        "action": {
                                            "API": "lms/PH_Thang_Parent_Confirm_Ins",
                                            "IN": {
                                                "Lop_NhanXetThangID": "vueData.Lop_NhanXetThangID",
                                                "HSLopID": "vueData.HocSinhDetail.HSLopID",
                                                "Parent_Comment": "vueData.Parent_Comment"
                                            },
                                            "CALLBACK": {
                                                "CALL": [
                                                    {
                                                        "EXE": "IsShowDialogComment = false"
                                                    },
                                                    {
                                                        "EXE": "vueData.Parent_Comment = null"
                                                    },
                                                    {
                                                        "CALL": "PH_Thang_Get_By_HocSinhID"
                                                    }
                                                ]
                                            }
                                        }
                                    }
                                ]
                            },
                            "w": 12
                        }
                    ]
                }
            ]
        }
    ],
    "set": {
        "menu": false
    }
}