                                                                        {
                                                                            "el": "v-card-title",
                                                                            "innerHTML": "Hoạt động khác"
                                                                        },
                                                                        {
                                                                            "el": "v-card-text",
                                                                            "attr": {
                                                                                "v-html": "NoiDungThang?.NoiDungHoatDongKhac_HTML"
