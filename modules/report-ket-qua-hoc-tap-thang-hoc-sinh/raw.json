{
    "data": [
        {
            "HocSinhID": "parseInt(id)",
            "Thang": "parseInt(thang)",
            "Nam": "parseInt(nam)",
            "HocSinhDetail": null,
            "NoiDungThang": null
        },
        {
            "API": "lms/HocSinh_Detail_GetBy_HocSinhID",
            "IN": {
                "HocSinhID": "vueData.HocSinhID"
            },
            "OUT": "HocSinhDetail"
        },
        {
            "API": "lms/PH_Thang_Get_By_HocSinhID",
            "IN": {
                "HocSinhID": "vueData.HocSinhID",
                "Thang": "vueData.Thang",
                "Nam": "vueData.Nam"
            },
            "OUT": "NoiDungThang"
        }
    ],
    "watch": {},
    "controls": [
        {
            "prop": "screen-devices style='min-height: 100dvh'",
            "rows": [
                {
                    "prop": "",
                    "cols": [
                        {
                            "el": "div",
                            "attr": {
                                "class": "font-weight-medium text-primary d-flex justify-space-between align-center"
                            },
                            "innerHTML": [
                                {
                                    "el": "uc-run-language"
                                },
                                {
                                    "el": "p",
                                    "innerHTML": " {{ $t('message.studyResult') }}"
                                },
                                {
                                    "el": "v-chip",
                                    "attr": {
                                        "label": "",
                                        "size": "large",
                                        "color": "primary"
                                    },
                                    "innerHTML": "Tháng {{ Thang }}"
                                }
                            ],
                            "w": 12
                        },
                        {
                            "el": "div",
                            "innerHTML": [
                                {
                                    "el": "p",
                                    "attr": {
                                        "class": "text-primary  font-weight-medium mb-2"
                                    },
                                    "innerHTML": "{{ $t('message.selectedStudent') }}"
                                },
                                {
                                    "el": "v-skeleton-loader",
                                    "attr": {
                                        ":loading": "HocSinhDetail === null",
                                        "type": "article"
                                    },
                                    "innerHTML": [
                                        {
                                            "el": "v-responsive",
                                            "innerHTML": [
                                                {
                                                    "el": "v-card",
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-card-text",
                                                            "attr": {
                                                                "v-if": "HocSinhDetail"
                                                            },
                                                            "innerHTML": [
                                                                {
                                                                    "el": "v-row",
                                                                    "innerHTML": [
                                                                        {
                                                                            "el": "v-col",
                                                                            "attr": {
                                                                                "sm": "4",
                                                                                "md": 4,
                                                                                "lg": 4,
                                                                                "class": "d-flex justify-center align-center"
                                                                            },
                                                                            "innerHTML": [
                                                                                {
                                                                                    "el": "v-avatar",
                                                                                    "attr": {
                                                                                        "size": "100",
                                                                                        "class": "elevation-4"
                                                                                    },
                                                                                    "innerHTML": [
                                                                                        {
                                                                                            "el": "v-img",
                                                                                            "attr": {
                                                                                                ":src": "v_Set.urlAvatarHocSinh + HocSinhDetail?.HocSinhID"
                                                                                            }
                                                                                        }
                                                                                    ]
                                                                                }
                                                                            ]
                                                                        },
                                                                        {
                                                                            "el": "v-col",
                                                                            "attr": {
                                                                                "sm": "8",
                                                                                "md": 8,
                                                                                "lg": 8
                                                                            },
                                                                            "innerHTML": [
                                                                                {
                                                                                    "el": "div",
                                                                                    "attr": {
                                                                                        "class": "d-flex flex-column justify-center algin-center ga-1"
                                                                                    },
                                                                                    "innerHTML": [
                                                                                        {
                                                                                            "el": "div",
                                                                                            "attr": {
                                                                                                "class": "text-h6 text-primary"
                                                                                            },
                                                                                            "innerHTML": [
                                                                                                {
                                                                                                    "el": "div",
                                                                                                    "innerHTML": [
                                                                                                        {
                                                                                                            "el": "span",
                                                                                                            "innerHTML": "{{ HocSinhDetail?.HoTen }}"
                                                                                                        },
                                                                                                        {
                                                                                                            "el": "v-icon",
                                                                                                            "attr": {
                                                                                                                "class": "ml-1 mb-1",
                                                                                                                "size": "20",
                                                                                                                "v-if": "!HocSinhDetail?.Nu"
                                                                                                            },
                                                                                                            "innerHTML": "mdi-face-man"
                                                                                                        },
                                                                                                        {
                                                                                                            "el": "v-icon",
                                                                                                            "attr": {
                                                                                                                "class": "ml-1 mb-1",
                                                                                                                "size": "20",
                                                                                                                "v-else": ""
                                                                                                            },
                                                                                                            "innerHTML": "mdi-face-woman"
                                                                                                        }
                                                                                                    ]
                                                                                                }
                                                                                            ]
                                                                                        },
                                                                                        {
                                                                                            "el": "p",
                                                                                            "attr": {
                                                                                                "class": "text-caption"
                                                                                            },
                                                                                            "innerHTML": "{{ HocSinhDetail?.HocSinhID }} • {{ HocSinhDetail?.NgaySinh }}"
                                                                                        },
                                                                                        {
                                                                                            "el": "v-divider",
                                                                                            "attr": {
                                                                                                "class": "mt-1 mb-1",
                                                                                                "style": "height: 4px;"
                                                                                            }
                                                                                        },
                                                                                        {
                                                                                            "el": "div",
                                                                                            "attr": {
                                                                                                "class": "d-flex justify-space-evenly align-center"
                                                                                            },
                                                                                            "innerHTML": [
                                                                                                {
                                                                                                    "el": "div",
                                                                                                    "attr": {
                                                                                                        "class": "text-center"
                                                                                                    },
                                                                                                    "innerHTML": [
                                                                                                        {
                                                                                                            "el": "p",
                                                                                                            "innerHTML": "{{ $t('message.grade') }}"
                                                                                                        },
                                                                                                        {
                                                                                                            "el": "p",
                                                                                                            "attr": {
                                                                                                                "class": "text-subtitle-2"
                                                                                                            },
                                                                                                            "innerHTML": "{{ HocSinhDetail?.KhoiID }}"
                                                                                                        }
                                                                                                    ]
                                                                                                },
                                                                                                {
                                                                                                    "el": "v-divider",
                                                                                                    "attr": {
                                                                                                        "vertical": ""
                                                                                                    }
                                                                                                },
                                                                                                {
                                                                                                    "el": "div",
                                                                                                    "attr": {
                                                                                                        "class": "text-center"
                                                                                                    },
                                                                                                    "innerHTML": [
                                                                                                        {
                                                                                                            "el": "p",
                                                                                                            "innerHTML": "{{ $t('message.class') }}"
                                                                                                        },
                                                                                                        {
                                                                                                            "el": "p",
                                                                                                            "attr": {
                                                                                                                "class": "text-subtitle-2"
                                                                                                            },
                                                                                                            "innerHTML": "{{ HocSinhDetail?.TenLop }}"
                                                                                                        }
                                                                                                    ]
                                                                                                }
                                                                                            ]
                                                                                        }
                                                                                    ]
                                                                                }
                                                                            ]
                                                                        }
                                                                    ]
                                                                }
                                                            ]
                                                        },
                                                        {
                                                            "el": "v-card-text",
                                                            "attr": {
                                                                "v-else": ""
                                                            },
                                                            "innerHTML": [
                                                                {
                                                                    "el": "uc-empty",
                                                                    "attr": {
                                                                        ":text": "$t('message.studentNotFound')"
                                                                    }
                                                                }
                                                            ]
                                                        }
                                                    ]
                                                }
                                            ]
                                        }
                                    ]
                                }
                            ],
                            "w": 12
                        },
                        {
                            "el": "div",
                            "innerHTML": [
                                {
                                    "el": "div",
                                    "attr": {
                                        "class": "text-primary font-weight-medium pb-2"
                                    },
                                    "innerHTML": "{{ $t('message.evaluation') }}"
                                },
                                {
                                    "el": "v-skeleton-loader",
                                    "attr": {
                                        ":loading": "NoiDungThang === null",
                                        "type": "article, article, article"
                                    },
                                    "innerHTML": [
                                        {
                                            "el": "v-responsive",
                                            "innerHTML": [
                                                {
                                                    "el": "v-row",
                                                    "attr": {
                                                        "class": "mt-2"
                                                    },
                                                    "innerHTML": [
                                                        {
                                                            "el": "v-col",
                                                            "attr": {
                                                                "cols": "12",
                                                                "v-if": "NoiDungThang?.NoiDungKienThuc"
                                                            },
                                                            "innerHTML": [
                                                                {
                                                                    "el": "v-card",
                                                                    "innerHTML": [
                                                                        {
                                                                            "el": "v-card-title",
                                                                            "innerHTML": "Kiến thức"
                                                                        },
                                                                        {
                                                                            "el": "v-card-text",
                                                                            "attr": {
                                                                                "v-html": "NoiDungThang?.NoiDungKienThuc"
                                                                            }
                                                                        }
                                                                    ]
                                                                }
                                                            ]
                                                        },
                                                        {
                                                            "el": "v-col",
                                                            "attr": {
                                                                "cols": "12",
                                                                "v-if": "NoiDungThang?.NoiDungNangLuc"
                                                            },
                                                            "innerHTML": [
                                                                {
                                                                    "el": "v-card",
                                                                    "innerHTML": [
                                                                        {
                                                                            "el": "v-card-title",
                                                                            "innerHTML": "Năng lực"
                                                                        },
                                                                        {
                                                                            "el": "v-card-text",
                                                                            "attr": {
                                                                                "v-html": "NoiDungThang?.NoiDungNangLuc"
                                                                            }
                                                                        }
                                                                    ]
                                                                }
                                                            ]
                                                        },
                                                        {
                                                            "el": "v-col",
                                                            "attr": {
                                                                "cols": "12",
                                                                "v-if": "NoiDungThang?.NoiDungHoatDongKhac"
                                                            },
                                                            "innerHTML": [
                                                                {
                                                                    "el": "v-card",
                                                                    "innerHTML": [
                                                                        {
                                                                            "el": "v-card-title",
                                                                            "innerHTML": "Hoạt động khác"
                                                                        },
                                                                        {
                                                                            "el": "v-card-text",
                                                                            "attr": {
                                                                                "v-html": "NoiDungThang?.NoiDungHoatDongKhac"
                                                                            }
                                                                        }
                                                                    ]
                                                                }
                                                            ]
                                                        }
                                                    ]
                                                },
                                                {
                                                    "el": "uc-empty",
                                                    "attr": {
                                                        "v-if": "!NoiDungThang?.NoiDungKienThuc && !NoiDungThang?.NoiDungNangLuc && !NoiDungThang?.NoiDungHoatDongKhac"
                                                    }
                                                }
                                            ]
                                        }
                                    ]
                                }
                            ]
                        }
                    ]
                }
            ]
        }
    ],
    "set": {
        "menu": false
    }
}