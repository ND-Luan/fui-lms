                                                        {
                                                            "el": "v-col",
                                                            "attr": {
                                                                "cols": "12",
                                                                "v-if": "NoiDungThang?.NoiDungHoatDongKhac_HTML"
                                                            },
                                                            "innerHTML": [
                                                                {
                                                                    "el": "v-card",
