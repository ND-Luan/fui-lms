{
    "data": [
        {
            "EXE": "IsCheck_NotRoleParent(vueData.user)"
        },
        {
            "focusTasks": [],
            "focusTasks_student": [],
            "dataReady": false,
            "teachingGroups": [],
            "schedule": [],
            "activities": [],
            "contentLibrary": [],
            "selectedKhoiID": null,
            "winData": {},
            "isOpenWindowCustom": false,
            "arrWindowID": [],
            "domHeaderLength": 0,
            "GiaoVienID_Selected": null
        },
        {
            "getLop": {
                "API": "/lms/Lop_Get_ByKhoiID",
                "IN": {
                    "KhoiID": "selectedKhoiID",
                    "NienKhoa": "vueData.NienKhoa"
                },
                "OUT": "dsLop"
            }
        },
        {
            "getTuanByNienKhoa": {
                "API": "/lms/TuanHocTap_Get",
                "IN": {
                    "NienKhoa": "vueData.NienKhoa"
                },
                "OUT": "DSTuanHoc"
            }
        },
        {
            "EXE": "initPage()"
        }
    ],
    "watch": {
        "NienKhoa": {
            "CALL": "getTuanByNienKhoa"
        },
        "domHeaderLength": {
            "EXE": "console.log('domHeaderLength',vueData.domHeaderLength)"
        }
    },
    "controls": [
        {
            "prop": "fluid pa-0",
            "rows": [
                {
                    "prop": ":no-gutters='true'",
                    "cols": [
                        {
                            "el": "uc-lms-tc-dashboard-v2",
                            "attr": {
                                "v-if": "dataReady===true",
                                ":focus-tasks": "focusTasks",
                                ":teaching-groups": "teachingGroups",
                                ":schedule": "schedule",
                                ":activities": "activities",
                                "v-model:content-library": "contentLibrary",
                                ":on-view-class": "goToClassPage",
                                ":on-grade-class": "goToGradingPage",
                                ":on-create-assignment": "createAssignmentForGroup"
                            }
                        }
                    ]
                }
            ]
        }
    ],
    "set": {}
}